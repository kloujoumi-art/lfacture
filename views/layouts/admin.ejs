<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title : 'Admin — LFacture' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .admin-link { display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;font-size:13px;font-weight:500;color:#94a3b8;transition:all .15s; }
    .admin-link:hover { background:rgba(255,255,255,.06);color:#e2e8f0; }
    .admin-link.active { background:rgba(239,68,68,.15);color:#fca5a5; }
    .admin-link.active svg { color:#f87171; }
    .stat-card { background:#1e293b;border:1px solid #334155;border-radius:12px;padding:20px; }
    .btn-red { background:#ef4444;color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;transition:all .15s; }
    .btn-red:hover { background:#dc2626; }
    .btn-green { background:#10b981;color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;transition:all .15s; }
    .btn-green:hover { background:#059669; }
    .btn-blue { background:#3b82f6;color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;transition:all .15s; }
    .btn-blue:hover { background:#2563eb; }
    .btn-gray { background:#334155;color:#e2e8f0;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;transition:all .15s; }
    .btn-gray:hover { background:#475569; }
    .flash-success { background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);color:#6ee7b7; }
    .flash-error { background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#fca5a5; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
    .animate-fade-in { animation:fadeIn .3s ease forwards; }
    tr:hover td { background:rgba(255,255,255,.02); }
  </style>
</head>
<body style="background:#0f172a;color:#e2e8f0;font-family:'Inter',sans-serif;">

<div class="flex h-screen overflow-hidden">

  <!-- Sidebar -->
  <aside style="width:220px;background:#1e293b;border-right:1px solid #334155;flex-shrink:0;display:flex;flex-direction:column;">
    <!-- Logo -->
    <div style="padding:20px 16px;border-bottom:1px solid #334155;">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:6px;background:linear-gradient(135deg,#ef4444,#dc2626);display:flex;align-items:center;justify-content:center;">
          <span style="color:#fff;font-weight:900;font-size:12px;">A</span>
        </div>
        <div>
          <p style="font-weight:800;font-size:13px;color:#f1f5f9;">LFacture</p>
          <p style="font-size:10px;color:#ef4444;font-weight:600;letter-spacing:.5px;">ADMIN</p>
        </div>
      </div>
    </div>

    <!-- Admin badge -->
    <div style="padding:12px 16px;border-bottom:1px solid #334155;">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:32px;height:32px;border-radius:50%;background:#ef4444;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:12px;flex-shrink:0;">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div style="min-width:0;">
          <p style="font-size:12px;font-weight:600;color:#f1f5f9;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= user.name %></p>
          <p style="font-size:10px;color:#ef4444;font-weight:600;">Administrateur</p>
        </div>
      </div>
    </div>

    <!-- Nav -->
    <nav style="padding:12px 8px;flex:1;overflow-y:auto;">
      <p style="font-size:10px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.8px;padding:0 8px;margin-bottom:6px;">Navigation</p>
      <a href="/admin" class="admin-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
        <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <a href="/admin/users" class="admin-link <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'active' : '' %>">
        <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        Utilisateurs
      </a>
      <a href="/admin/invoices" class="admin-link <%= typeof activePage !== 'undefined' && activePage === 'invoices' ? 'active' : '' %>">
        <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Factures
      </a>

      <p style="font-size:10px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.8px;padding:0 8px;margin:16px 0 6px;">Application</p>
      <a href="/dashboard" class="admin-link" target="_blank">
        <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Voir l'app
      </a>
    </nav>

    <!-- Logout -->
    <div style="padding:8px;border-top:1px solid #334155;">
      <form action="/logout" method="POST">
        <button type="submit" class="admin-link w-full" style="color:#f87171;width:100%;">
          <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Déconnexion
        </button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;">
    <!-- Topbar -->
    <header style="background:#1e293b;border-bottom:1px solid #334155;padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
      <h1 style="font-size:16px;font-weight:700;color:#f1f5f9;"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Admin' %></h1>
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="background:rgba(239,68,68,.15);color:#fca5a5;font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;border:1px solid rgba(239,68,68,.3);">🔴 ADMIN MODE</span>
      </div>
    </header>

    <!-- Flash -->
    <div style="padding:0 24px;" id="flashContainer">
      <% if (success && success.length > 0) { success.forEach(msg => { %>
      <div class="flash-success animate-fade-in" style="margin-top:12px;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;">
        <svg style="width:16px;height:16px;flex-shrink:0;color:#10b981;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <p style="font-size:13px;font-weight:500;"><%= msg %></p>
      </div>
      <% }); } %>
      <% if (error && error.length > 0) { error.forEach(msg => { %>
      <div class="flash-error animate-fade-in" style="margin-top:12px;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;">
        <svg style="width:16px;height:16px;flex-shrink:0;color:#ef4444;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        <p style="font-size:13px;font-weight:500;"><%= msg %></p>
      </div>
      <% }); } %>
    </div>

    <!-- Content -->
    <div style="flex:1;overflow-y:auto;padding:24px;">
      <%- body %>
    </div>
  </div>
</div>

<script>
  setTimeout(() => {
    document.querySelectorAll('#flashContainer > div').forEach(el => {
      el.style.transition = 'opacity .5s';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 500);
    });
  }, 5000);
</script>
</body>
</html>
