<!-- Hero -->
<section style="background:linear-gradient(135deg,#f5f3ff 0%,#ede9fe 50%,#e0e7ff 100%);padding:80px 20px 60px;">
  <div style="max-width:800px;margin:0 auto;text-align:center;">
    <span style="display:inline-block;background:rgba(99,102,241,.1);color:#4F46E5;font-size:12px;font-weight:700;padding:6px 16px;border-radius:20px;border:1px solid rgba(99,102,241,.2);margin-bottom:16px;letter-spacing:.5px;text-transform:uppercase;">Blog LFacture</span>
    <h1 style="font-size:42px;font-weight:900;color:#1a1a2e;line-height:1.15;margin:0 0 16px;">Conseils & Astuces<br><span style="background:linear-gradient(135deg,#4F46E5,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Facturation & Gestion</span></h1>
    <p style="font-size:17px;color:#6b7280;line-height:1.7;margin:0;max-width:540px;margin:0 auto;">Des guides pratiques pour les indépendants et PME françaises : facturation, devis, comptabilité, gestion clients.</p>
  </div>
</section>

<!-- Articles -->
<section style="max-width:1100px;margin:0 auto;padding:60px 20px;">
  <% if (posts.length === 0) { %>
  <div style="text-align:center;padding:80px 20px;">
    <div style="font-size:64px;margin-bottom:16px;">✍️</div>
    <h2 style="color:#374151;font-size:22px;font-weight:700;margin:0 0 8px;">Pas encore d'articles</h2>
    <p style="color:#9ca3af;font-size:15px;margin:0 0 24px;">Revenez bientôt, des articles sont en cours de rédaction.</p>
    <a href="/" style="display:inline-block;background:linear-gradient(135deg,#4F46E5,#7C3AED);color:#fff;padding:12px 28px;border-radius:8px;text-decoration:none;font-weight:700;font-size:14px;">Retour à l'accueil</a>
  </div>
  <% } else { %>

  <!-- Article à la une -->
  <% const featured = posts[0]; %>
  <a href="/blog/<%= featured.slug %>" style="display:block;text-decoration:none;margin-bottom:48px;background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06),0 4px 20px rgba(0,0,0,.08);transition:transform .2s,box-shadow .2s;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 40px rgba(0,0,0,.12)';" onmouseout="this.style.transform='';this.style.boxShadow='0 1px 3px rgba(0,0,0,.06),0 4px 20px rgba(0,0,0,.08)';">
    <div style="display:grid;grid-template-columns:<%= featured.cover_image ? '1fr 1fr' : '1fr' %>;min-height:280px;">
      <% if (featured.cover_image) { %>
      <div style="overflow:hidden;">
        <img src="<%= featured.cover_image %>" alt="<%= featured.title %>" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'"/>
      </div>
      <% } %>
      <div style="padding:40px;display:flex;flex-direction:column;justify-content:center;">
        <span style="display:inline-block;background:rgba(99,102,241,.1);color:#4F46E5;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:16px;width:fit-content;">⭐ À la une</span>
        <h2 style="font-size:26px;font-weight:900;color:#1a1a2e;line-height:1.3;margin:0 0 12px;"><%= featured.title %></h2>
        <% if (featured.excerpt) { %>
        <p style="color:#6b7280;font-size:15px;line-height:1.6;margin:0 0 20px;"><%= featured.excerpt %></p>
        <% } %>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
          <span style="color:#9ca3af;font-size:13px;">
            <%= new Date(featured.published_at || featured.created_at).toLocaleDateString('fr-FR', {day:'numeric', month:'long', year:'numeric'}) %>
          </span>
          <% if (featured.tags) { featured.tags.split(',').slice(0,2).forEach(tag => { %>
          <span style="background:#f3f4f6;color:#6b7280;font-size:11px;padding:3px 10px;border-radius:20px;"><%= tag.trim() %></span>
          <% }); } %>
        </div>
        <span style="display:inline-flex;align-items:center;gap:6px;margin-top:20px;color:#4F46E5;font-weight:700;font-size:14px;">Lire l'article <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
      </div>
    </div>
  </a>

  <!-- Grille articles -->
  <% if (posts.length > 1) { %>
  <h2 style="font-size:20px;font-weight:800;color:#1a1a2e;margin:0 0 24px;">Tous les articles</h2>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;">
    <% posts.slice(1).forEach(post => { %>
    <a href="/blog/<%= post.slug %>" style="display:block;text-decoration:none;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.05),0 4px 16px rgba(0,0,0,.07);transition:transform .2s,box-shadow .2s;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 32px rgba(0,0,0,.12)';" onmouseout="this.style.transform='';this.style.boxShadow='0 1px 3px rgba(0,0,0,.05),0 4px 16px rgba(0,0,0,.07)';">
      <% if (post.cover_image) { %>
      <div style="height:180px;overflow:hidden;">
        <img src="<%= post.cover_image %>" alt="<%= post.title %>" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.parentElement.style.display='none'"/>
      </div>
      <% } else { %>
      <div style="height:8px;background:linear-gradient(135deg,#4F46E5,#7C3AED);"></div>
      <% } %>
      <div style="padding:24px;">
        <h3 style="font-size:16px;font-weight:800;color:#1a1a2e;line-height:1.35;margin:0 0 10px;"><%= post.title %></h3>
        <% if (post.excerpt) { %>
        <p style="color:#6b7280;font-size:13px;line-height:1.6;margin:0 0 16px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;"><%= post.excerpt %></p>
        <% } %>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;">
          <span style="color:#9ca3af;font-size:12px;">
            <%= new Date(post.published_at || post.created_at).toLocaleDateString('fr-FR', {day:'numeric', month:'short', year:'numeric'}) %>
          </span>
          <% if (post.tags) { %>
          <span style="background:#f3f4f6;color:#6b7280;font-size:11px;padding:2px 10px;border-radius:20px;"><%= post.tags.split(',')[0].trim() %></span>
          <% } %>
        </div>
      </div>
    </a>
    <% }); %>
  </div>
  <% } %>
  <% } %>
</section>

<!-- CTA bas de page -->
<section style="background:linear-gradient(135deg,#4F46E5,#7C3AED);padding:60px 20px;margin-top:40px;">
  <div style="max-width:600px;margin:0 auto;text-align:center;">
    <h2 style="color:#fff;font-size:28px;font-weight:900;margin:0 0 12px;">Prêt à simplifier votre facturation ?</h2>
    <p style="color:rgba(255,255,255,.8);font-size:16px;margin:0 0 28px;">Factures et devis illimités, gratuitement — Sans carte bancaire</p>
    <a href="/register" style="display:inline-block;background:#fff;color:#4F46E5;font-weight:900;font-size:15px;padding:14px 36px;border-radius:10px;text-decoration:none;">
      Commencer gratuitement →
    </a>
  </div>
</section>
