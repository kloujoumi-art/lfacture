<!-- Tabs -->
<div style="display:flex;gap:8px;margin-bottom:24px;border-bottom:1px solid #334155;padding-bottom:0;">
  <button onclick="switchTab('articles')" id="tab-articles"
    style="padding:10px 20px;border:none;border-bottom:2px solid #4F46E5;background:transparent;color:#e2e8f0;font-weight:700;font-size:13px;cursor:pointer;">
    ✍️ Articles
  </button>
  <button onclick="switchTab('campaigns')" id="tab-campaigns"
    style="padding:10px 20px;border:none;border-bottom:2px solid transparent;background:transparent;color:#64748b;font-weight:600;font-size:13px;cursor:pointer;">
    🤖 Campagnes Auto
  </button>
</div>

<!-- ── ARTICLES TAB ── -->
<div id="panel-articles">

<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Total articles</p>
    <p style="font-size:28px;font-weight:900;color:#6366f1;margin:0;"><%= stats.total %></p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Publiés</p>
    <p style="font-size:28px;font-weight:900;color:#10b981;margin:0;"><%= stats.published %></p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Brouillons</p>
    <p style="font-size:28px;font-weight:900;color:#f59e0b;margin:0;"><%= stats.drafts %></p>
  </div>
</div>

<!-- Header actions -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
  <h2 style="color:#e2e8f0;font-size:16px;font-weight:700;margin:0;">Articles du blog</h2>
  <div style="display:flex;gap:10px;">
    <a href="/blog" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:#334155;color:#94a3b8;border-radius:8px;text-decoration:none;font-size:12px;font-weight:600;border:1px solid #475569;">
      ↗ Voir le blog
    </a>
    <a href="/admin/blog/create" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#4F46E5;color:#fff;border-radius:8px;text-decoration:none;font-size:13px;font-weight:700;">
      + Nouvel article
    </a>
  </div>
</div>

<!-- Table -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;overflow:hidden;">
  <% if (posts.length === 0) { %>
  <div style="text-align:center;padding:60px 20px;color:#64748b;">
    <div style="font-size:48px;margin-bottom:12px;">✍️</div>
    <p style="font-size:15px;margin:0 0 8px;">Aucun article pour le moment</p>
    <p style="font-size:13px;margin:0 0 20px;">Créez un article manuellement ou lancez une campagne automatique.</p>
    <a href="/admin/blog/create" style="display:inline-block;background:#4F46E5;color:#fff;padding:10px 24px;border-radius:8px;text-decoration:none;font-weight:700;font-size:13px;">
      + Créer un article
    </a>
  </div>
  <% } else { %>
  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="background:#0f172a;border-bottom:1px solid #334155;">
        <th style="text-align:left;padding:12px 16px;color:#64748b;font-weight:600;font-size:12px;">Titre</th>
        <th style="text-align:center;padding:12px;color:#64748b;font-weight:600;font-size:12px;">Source</th>
        <th style="text-align:center;padding:12px;color:#64748b;font-weight:600;font-size:12px;">Statut</th>
        <th style="text-align:left;padding:12px;color:#64748b;font-weight:600;font-size:12px;">Tags</th>
        <th style="text-align:left;padding:12px;color:#64748b;font-weight:600;font-size:12px;">Date</th>
        <th style="text-align:center;padding:12px;color:#64748b;font-weight:600;font-size:12px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach(post => { %>
      <tr style="border-bottom:1px solid #1e293b;transition:background .15s;" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="this.style.background=''">
        <td style="padding:14px 16px;max-width:280px;">
          <p style="margin:0 0 2px;color:#e2e8f0;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= post.title %></p>
          <p style="margin:0;color:#475569;font-size:11px;font-family:monospace;">/blog/<%= post.slug %></p>
        </td>
        <td style="padding:14px;text-align:center;">
          <span style="font-size:11px;padding:3px 8px;border-radius:20px;font-weight:700;<%- post.source === 'campaign' ? 'background:rgba(139,92,246,.15);color:#a78bfa;' : 'background:rgba(30,41,59,1);color:#64748b;border:1px solid #334155;' %>">
            <%= post.source === 'campaign' ? '🤖 Auto' : '✍️ Manuel' %>
          </span>
        </td>
        <td style="padding:14px;text-align:center;">
          <form method="POST" action="/admin/blog/<%= post.id %>/toggle" style="display:inline;">
            <button type="submit" style="border:none;background:none;cursor:pointer;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;<%- post.published ? 'background:rgba(16,185,129,.15);color:#6ee7b7;' : 'background:rgba(245,158,11,.1);color:#fbbf24;' %>">
              <%= post.published ? '✅ Publié' : '📝 Brouillon' %>
            </button>
          </form>
        </td>
        <td style="padding:14px;">
          <% if (post.tags) { post.tags.split(',').slice(0,2).forEach(tag => { %>
          <span style="display:inline-block;background:#0f172a;color:#94a3b8;font-size:11px;padding:2px 7px;border-radius:4px;margin:2px;border:1px solid #334155;"><%= tag.trim() %></span>
          <% }); } else { %><span style="color:#475569;font-size:12px;">—</span><% } %>
        </td>
        <td style="padding:14px;color:#64748b;font-size:12px;white-space:nowrap;">
          <%= new Date(post.created_at).toLocaleDateString('fr-FR', {day:'numeric', month:'short', year:'numeric'}) %>
        </td>
        <td style="padding:14px;text-align:center;">
          <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
            <a href="/admin/blog/<%= post.id %>/edit" style="display:inline-flex;align-items:center;gap:4px;padding:5px 10px;background:rgba(59,130,246,.1);color:#60a5fa;border:1px solid rgba(59,130,246,.2);border-radius:6px;text-decoration:none;font-size:11px;font-weight:600;">✏️ Éditer</a>
            <% if (post.published) { %>
            <a href="/blog/<%= post.slug %>" target="_blank" style="display:inline-flex;align-items:center;padding:5px 8px;background:#1e293b;color:#64748b;border:1px solid #334155;border-radius:6px;text-decoration:none;font-size:11px;">↗</a>
            <% } %>
            <form method="POST" action="/admin/blog/<%= post.id %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer cet article ?')">
              <button type="submit" style="padding:5px 8px;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);border-radius:6px;font-size:11px;cursor:pointer;">🗑️</button>
            </form>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>
</div>

<!-- ── CAMPAIGNS TAB ── -->
<div id="panel-campaigns" style="display:none;">

  <div id="camp-msg" style="display:none;margin-bottom:16px;padding:12px 16px;border-radius:8px;font-size:13px;font-weight:600;"></div>

  <!-- Stats campagnes -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div class="stat-card">
      <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Campagnes</p>
      <p style="font-size:28px;font-weight:900;color:#8b5cf6;margin:0;" id="camp-count"><%= campaigns.length %></p>
    </div>
    <div class="stat-card">
      <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Actives</p>
      <p style="font-size:28px;font-weight:900;color:#10b981;margin:0;" id="camp-active-count"><%= campaigns.filter(c => c.is_active).length %></p>
    </div>
    <div class="stat-card">
      <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Articles générés</p>
      <p style="font-size:28px;font-weight:900;color:#f59e0b;margin:0;"><%= campaigns.reduce((s,c) => s + (c.success_count||0), 0) %></p>
    </div>
  </div>

  <!-- Header actions -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
    <h2 style="color:#e2e8f0;font-size:16px;font-weight:700;margin:0;">Campagnes d'automatisation</h2>
    <button onclick="toggleNewForm()" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#8b5cf6;color:#fff;border-radius:8px;font-size:13px;font-weight:700;border:none;cursor:pointer;">
      + Nouvelle campagne
    </button>
  </div>

  <!-- New campaign form (hidden by default) -->
  <div id="new-camp-form" style="display:none;background:#1e293b;border:1px solid rgba(139,92,246,.3);border-radius:12px;padding:20px;margin-bottom:24px;">
    <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 16px;">🤖 Nouvelle campagne d'automatisation</h3>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div>
        <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:6px;">Nom de la campagne *</label>
        <input id="f-name" type="text" placeholder="Ex: Blog SEO Facturation"
          style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;box-sizing:border-box;"
          onfocus="this.style.borderColor='#8b5cf6'" onblur="this.style.borderColor='#334155'"/>
      </div>
      <div>
        <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:6px;">Langue</label>
        <select id="f-lang" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;">
          <option value="fr">🇫🇷 Français</option>
          <option value="en">🇬🇧 Anglais</option>
          <option value="ar">🇲🇦 Arabe</option>
        </select>
      </div>
      <div>
        <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:6px;">Fréquence de publication</label>
        <select id="f-freq" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;">
          <option value="daily">1 article / jour</option>
          <option value="four_daily">4 articles / jour</option>
          <option value="six_daily">6 articles / jour</option>
          <option value="eight_daily">8 articles / jour</option>
          <option value="ten_daily">10 articles / jour</option>
        </select>
      </div>
      <div>
        <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:6px;">Source des images</label>
        <select id="f-img" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;">
          <option value="pexels">📷 Pexels (photos gratuites)</option>
          <option value="fal">🎨 FAL AI (images générées IA)</option>
        </select>
      </div>
      <div style="grid-column:span 2;">
        <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:6px;">Keywords * <span style="color:#475569;font-weight:400;">(séparés par virgule ou saut de ligne)</span></label>
        <textarea id="f-keywords" rows="4" placeholder="logiciel facturation PME, créer facture en ligne, devis gratuit artisan, comptabilité micro-entreprise..."
          style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;resize:vertical;box-sizing:border-box;"
          onfocus="this.style.borderColor='#8b5cf6'" onblur="this.style.borderColor='#334155'"></textarea>
        <p style="color:#475569;font-size:11px;margin:4px 0 0;">Les keywords sont utilisés en rotation — un article par exécution.</p>
      </div>
    </div>
    <div style="display:flex;gap:10px;">
      <button onclick="createCampaign()" style="padding:9px 20px;background:#8b5cf6;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;">
        🚀 Lancer la campagne
      </button>
      <button onclick="toggleNewForm()" style="padding:9px 16px;background:#334155;color:#94a3b8;border:none;border-radius:8px;font-size:13px;cursor:pointer;">
        Annuler
      </button>
    </div>
  </div>

  <!-- Campaigns list -->
  <div id="camp-list">
    <% if (campaigns.length === 0) { %>
    <div style="text-align:center;padding:60px 20px;background:#1e293b;border:1px solid #334155;border-radius:12px;" id="camp-empty">
      <div style="font-size:48px;margin-bottom:12px;">🤖</div>
      <p style="color:#64748b;font-size:15px;margin:0 0 8px;">Aucune campagne active</p>
      <p style="color:#475569;font-size:13px;margin:0 0 20px;">Créez une campagne pour générer automatiquement des articles SEO avec l'IA.</p>
      <button onclick="toggleNewForm()" style="background:#8b5cf6;color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;">
        + Nouvelle campagne
      </button>
    </div>
    <% } else { %>
    <div id="camp-cards" style="display:flex;flex-direction:column;gap:12px;">
      <% campaigns.forEach(camp => { %>
      <div class="camp-card" data-id="<%= camp.id %>" style="background:#1e293b;border:1px solid <%- camp.is_active ? 'rgba(139,92,246,.3)' : '#334155' %>;border-radius:12px;padding:16px 20px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
              <span style="color:#e2e8f0;font-weight:700;font-size:14px;"><%= camp.name %></span>
              <span style="font-size:11px;padding:2px 8px;border-radius:20px;font-weight:700;<%- camp.is_active ? 'background:rgba(16,185,129,.15);color:#6ee7b7;' : 'background:#334155;color:#64748b;' %>">
                <%= camp.is_active ? '● Actif' : '○ Pausé' %>
              </span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:rgba(99,102,241,.1);color:#818cf8;font-weight:600;"><%= camp.freq_label %></span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:#0f172a;color:#64748b;border:1px solid #334155;">
                <%= camp.language === 'fr' ? '🇫🇷 FR' : camp.language === 'ar' ? '🇲🇦 AR' : '🇬🇧 EN' %>
              </span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:<%- camp.image_source === 'fal' ? 'rgba(251,146,60,.08)' : 'rgba(30,41,59,1)' %>;color:<%- camp.image_source === 'fal' ? '#fb923c' : '#64748b' %>;border:1px solid <%- camp.image_source === 'fal' ? 'rgba(251,146,60,.2)' : '#334155' %>;">
                <%= camp.image_source === 'fal' ? '🎨 FAL AI' : '📷 Pexels' %>
              </span>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;">
              <% (camp.keywords || []).slice(0,4).forEach(kw => { %>
              <span style="font-size:11px;background:#0f172a;color:#94a3b8;padding:2px 8px;border-radius:4px;border:1px solid #334155;"><%= kw %></span>
              <% }); %>
              <% if ((camp.keywords||[]).length > 4) { %>
              <span style="font-size:11px;color:#475569;">+<%= camp.keywords.length - 4 %> autres</span>
              <% } %>
            </div>
            <div style="display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:#475569;">
              <span>✅ <%= camp.success_count %> publiés</span>
              <span>🔄 <%= camp.run_count %> exécutions</span>
              <% if (camp.next_run_at && camp.is_active) { %>
              <span>⏱ Prochain : <%= new Date(camp.next_run_at).toLocaleString('fr-FR', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %></span>
              <% } %>
              <% if (camp.last_error) { %>
              <span style="color:#f87171;">⚠️ <%= camp.last_error.slice(0,60) %></span>
              <% } %>
            </div>
          </div>
          <div style="display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap;">
            <button onclick="runCampaign(<%= camp.id %>)" style="font-size:11px;padding:6px 12px;border-radius:6px;border:1px solid rgba(20,184,166,.3);background:rgba(20,184,166,.08);color:#5eead4;cursor:pointer;font-weight:600;">▶ Lancer</button>
            <button onclick="toggleCampaign(<%= camp.id %>)" style="font-size:11px;padding:6px 12px;border-radius:6px;border:1px solid <%- camp.is_active ? 'rgba(245,158,11,.3)' : 'rgba(16,185,129,.3)' %>;background:<%- camp.is_active ? 'rgba(245,158,11,.08)' : 'rgba(16,185,129,.08)' %>;color:<%- camp.is_active ? '#fbbf24' : '#6ee7b7' %>;cursor:pointer;font-weight:600;">
              <%= camp.is_active ? '⏸ Pause' : '▶ Activer' %>
            </button>
            <button onclick="openEditCamp(<%= camp.id %>)" style="font-size:11px;padding:6px 12px;border-radius:6px;border:1px solid rgba(99,102,241,.3);background:rgba(99,102,241,.08);color:#818cf8;cursor:pointer;font-weight:600;">✏️ Modifier</button>
            <button onclick="deleteCampaign(<%= camp.id %>)" style="font-size:11px;padding:6px 10px;border-radius:6px;border:1px solid rgba(239,68,68,.2);background:rgba(239,68,68,.07);color:#f87171;cursor:pointer;">🗑️</button>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- Edit campaign modal -->
  <div id="edit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:#1e293b;border:1px solid #334155;border-radius:16px;padding:24px;width:100%;max-width:520px;margin:20px;">
      <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 16px;">✏️ Modifier la campagne</h3>
      <input type="hidden" id="edit-id"/>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
        <div>
          <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:5px;">Nom *</label>
          <input id="edit-name" type="text" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:8px 12px;border-radius:8px;outline:none;box-sizing:border-box;"/>
        </div>
        <div>
          <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:5px;">Langue</label>
          <select id="edit-lang" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:8px 12px;border-radius:8px;outline:none;">
            <option value="fr">🇫🇷 Français</option>
            <option value="en">🇬🇧 Anglais</option>
            <option value="ar">🇲🇦 Arabe</option>
          </select>
        </div>
        <div>
          <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:5px;">Fréquence</label>
          <select id="edit-freq" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:8px 12px;border-radius:8px;outline:none;">
            <option value="daily">1/jour</option>
            <option value="four_daily">4/jour</option>
            <option value="six_daily">6/jour</option>
            <option value="eight_daily">8/jour</option>
            <option value="ten_daily">10/jour</option>
          </select>
        </div>
        <div>
          <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:5px;">Source images</label>
          <select id="edit-img" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:8px 12px;border-radius:8px;outline:none;">
            <option value="pexels">📷 Pexels</option>
            <option value="fal">🎨 FAL AI</option>
          </select>
        </div>
        <div style="grid-column:span 2;">
          <label style="display:block;color:#94a3b8;font-size:12px;font-weight:600;margin-bottom:5px;">Keywords *</label>
          <textarea id="edit-keywords" rows="3" style="width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;font-size:13px;padding:8px 12px;border-radius:8px;outline:none;resize:vertical;box-sizing:border-box;"></textarea>
        </div>
      </div>
      <div style="display:flex;gap:8px;">
        <button onclick="saveEditCamp()" style="padding:8px 18px;background:#4F46E5;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;">💾 Sauvegarder</button>
        <button onclick="closeEditModal()" style="padding:8px 14px;background:#334155;color:#94a3b8;border:none;border-radius:8px;font-size:13px;cursor:pointer;">Annuler</button>
      </div>
    </div>
  </div>

</div>

<script>
// ── Tab switching ──
function switchTab(tab) {
  document.getElementById('panel-articles').style.display = tab === 'articles' ? '' : 'none';
  document.getElementById('panel-campaigns').style.display = tab === 'campaigns' ? '' : 'none';
  document.getElementById('tab-articles').style.borderBottomColor = tab === 'articles' ? '#4F46E5' : 'transparent';
  document.getElementById('tab-articles').style.color = tab === 'articles' ? '#e2e8f0' : '#64748b';
  document.getElementById('tab-campaigns').style.borderBottomColor = tab === 'campaigns' ? '#8b5cf6' : 'transparent';
  document.getElementById('tab-campaigns').style.color = tab === 'campaigns' ? '#e2e8f0' : '#64748b';
  if (tab === 'campaigns') history.replaceState(null,'',location.pathname+'?tab=campaigns');
  else history.replaceState(null,'',location.pathname);
}

// Auto-switch if ?tab=campaigns
if (location.search.includes('tab=campaigns')) switchTab('campaigns');

// ── Msg ──
function showMsg(text, ok) {
  const el = document.getElementById('camp-msg');
  el.textContent = text;
  el.style.display = '';
  el.style.background = ok ? 'rgba(16,185,129,.1)' : 'rgba(239,68,68,.1)';
  el.style.border = ok ? '1px solid rgba(16,185,129,.3)' : '1px solid rgba(239,68,68,.3)';
  el.style.color = ok ? '#6ee7b7' : '#fca5a5';
  setTimeout(() => { el.style.display = 'none'; }, 5000);
}

// ── New form ──
function toggleNewForm() {
  const f = document.getElementById('new-camp-form');
  f.style.display = f.style.display === 'none' ? '' : 'none';
}

// ── Create campaign ──
async function createCampaign() {
  const name = document.getElementById('f-name').value.trim();
  const keywords_raw = document.getElementById('f-keywords').value.trim();
  const language = document.getElementById('f-lang').value;
  const frequency = document.getElementById('f-freq').value;
  const image_source = document.getElementById('f-img').value;
  if (!name || !keywords_raw) { showMsg('❌ Nom et keywords requis', false); return; }

  const btn = event.target;
  btn.textContent = '⏳ Création...'; btn.disabled = true;

  try {
    const r = await fetch('/api/admin/campaigns', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, keywords_raw, language, frequency, image_source }),
    });
    const d = await r.json();
    if (!r.ok) { showMsg('❌ ' + (d.error || 'Erreur'), false); return; }
    showMsg('✅ Campagne créée et démarrée !', true);
    document.getElementById('f-name').value = '';
    document.getElementById('f-keywords').value = '';
    toggleNewForm();
    setTimeout(() => location.reload(), 1200);
  } catch(e) { showMsg('❌ ' + e.message, false); }
  finally { btn.textContent = '🚀 Lancer la campagne'; btn.disabled = false; }
}

// ── Toggle active ──
async function toggleCampaign(id) {
  const r = await fetch('/api/admin/campaigns/' + id + '/toggle', { method: 'POST' });
  if (r.ok) setTimeout(() => location.reload(), 300);
}

// ── Run now ──
async function runCampaign(id) {
  const btn = event.target;
  btn.textContent = '⏳'; btn.disabled = true;
  showMsg('🤖 Génération de l\'article en cours...', true);
  try {
    const r = await fetch('/api/admin/campaigns/' + id + '/run', { method: 'POST' });
    const d = await r.json();
    if (r.ok) {
      showMsg('✅ Article généré : "' + d.title + '"', true);
      setTimeout(() => location.reload(), 2000);
    } else {
      showMsg('❌ ' + (d.error || 'Erreur'), false);
    }
  } catch(e) { showMsg('❌ ' + e.message, false); }
  finally { btn.textContent = '▶ Lancer'; btn.disabled = false; }
}

// ── Delete ──
async function deleteCampaign(id) {
  if (!confirm('Supprimer cette campagne ?')) return;
  await fetch('/api/admin/campaigns/' + id + '/delete', { method: 'POST' });
  setTimeout(() => location.reload(), 300);
}

// ── Edit modal ──
function openEditCamp(id) {
  const card = document.querySelector('.camp-card[data-id="' + id + '"]');
  if (!card) return;
  document.getElementById('edit-id').value = id;
  // We reload data from server — for now pre-fill from DOM text
  document.getElementById('edit-modal').style.display = 'flex';
}
function closeEditModal() { document.getElementById('edit-modal').style.display = 'none'; }
async function saveEditCamp() {
  const id = document.getElementById('edit-id').value;
  const name = document.getElementById('edit-name').value.trim();
  const keywords_raw = document.getElementById('edit-keywords').value.trim();
  const language = document.getElementById('edit-lang').value;
  const frequency = document.getElementById('edit-freq').value;
  const image_source = document.getElementById('edit-img').value;
  if (!name || !keywords_raw) { showMsg('❌ Nom et keywords requis', false); return; }
  const r = await fetch('/api/admin/campaigns/' + id + '/update', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name, keywords_raw, language, frequency, image_source }),
  });
  if (r.ok) { closeEditModal(); showMsg('✅ Campagne modifiée', true); setTimeout(() => location.reload(), 1000); }
  else { const d = await r.json(); showMsg('❌ ' + (d.error||'Erreur'), false); }
}
</script>
