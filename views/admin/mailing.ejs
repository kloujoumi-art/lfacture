<!-- Stats emails -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Contacts mailing</p>
    <p style="font-size:28px;font-weight:900;color:#6366f1;margin:0;"><%= contacts.length %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Emails récoltés</p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Emails envoyés</p>
    <p style="font-size:28px;font-weight:900;color:#10b981;margin:0;"><%= totalEmails %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Total funnel</p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Promos −15%</p>
    <p style="font-size:28px;font-weight:900;color:#ef4444;margin:0;"><%= emailStats.discount || 0 %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Offres envoyées</p>
  </div>
</div>

<!-- Séquence funnel stats -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:24px;margin-bottom:24px;">
  <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 20px;">Séquence funnel automatique</h3>
  <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:12px;">
    <%
      const funnelSteps = [
        { type: 'verification', icon: '✉️', label: 'Vérification', timing: 'Inscription', color: '#6366f1' },
        { type: 'welcome', icon: '🎉', label: 'Bienvenue', timing: 'Après vérif.', color: '#10b981' },
        { type: 'trial_ending', icon: '⏰', label: 'J+5 Rappel', timing: 'Jour 5', color: '#f59e0b' },
        { type: 'trial_expired', icon: '😔', label: 'J+7 Expiré', timing: 'Jour 7', color: '#ef4444' },
        { type: 'followup', icon: '💡', label: 'J+9 Relance', timing: 'Jour 9', color: '#3b82f6' },
        { type: 'discount', icon: '🔥', label: 'J+12 −15%', timing: 'Jour 12', color: '#dc2626' },
      ];
    %>
    <% funnelSteps.forEach((step, i) => { %>
    <div style="background:#0f172a;border-radius:10px;padding:16px;text-align:center;border:1px solid #334155;">
      <div style="font-size:24px;margin-bottom:8px;"><%= step.icon %></div>
      <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#e2e8f0;"><%= step.label %></p>
      <p style="margin:0 0 8px;font-size:10px;color:#64748b;"><%= step.timing %></p>
      <p style="margin:0;font-size:20px;font-weight:900;color:<%= step.color %>;"><%= emailStats[step.type] || 0 %></p>
      <p style="margin:2px 0 0;font-size:10px;color:#64748b;">envoyés</p>
    </div>
    <% }); %>
  </div>
</div>

<!-- Contacts mailing -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:20px;margin-bottom:24px;">
  <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 16px;display:flex;align-items:center;justify-content:space-between;">
    <span>📋 Liste des contacts (<%= contacts.length %>)</span>
    <span style="color:#64748b;font-size:11px;font-weight:500;">Emails vérifiés ayant commencé l'essai</span>
  </h3>

  <% if (contacts.length === 0) { %>
  <div style="text-align:center;padding:32px 0;color:#64748b;">
    <p style="font-size:14px;">Aucun contact pour le moment.</p>
    <p style="font-size:12px;margin-top:4px;">Les contacts s'ajoutent automatiquement après vérification d'email.</p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:1px solid #334155;">
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">#</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Nom</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Email</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Source</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Tags</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Ajouté le</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach((c, i) => { %>
        <tr style="border-bottom:1px solid #0f172a;">
          <td style="padding:10px 12px;color:#64748b;font-size:12px;"><%= i + 1 %></td>
          <td style="padding:10px 12px;color:#e2e8f0;font-weight:600;"><%= c.name %></td>
          <td style="padding:10px 12px;color:#94a3b8;"><%= c.email %></td>
          <td style="padding:10px 12px;">
            <span style="background:rgba(99,102,241,.15);color:#818cf8;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;"><%= c.source || 'trial' %></span>
          </td>
          <td style="padding:10px 12px;">
            <% (c.tags || []).forEach(tag => { %>
            <span style="background:#0f172a;color:#94a3b8;font-size:11px;padding:2px 8px;border-radius:4px;margin-right:4px;border:1px solid #334155;"><%= tag %></span>
            <% }); %>
          </td>
          <td style="padding:10px 12px;color:#64748b;font-size:12px;">
            <%= new Date(c.subscribed_at).toLocaleDateString('fr-FR', {day:'numeric',month:'short',year:'numeric'}) %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Log emails envoyés -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:20px;">
  <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 16px;">📨 Historique des emails envoyés (100 derniers)</h3>
  <% if (funnelLogs.length === 0) { %>
  <p style="color:#64748b;text-align:center;padding:20px 0;font-size:14px;">Aucun email envoyé pour le moment.</p>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:1px solid #334155;">
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Type</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Destinataire</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Date envoi</th>
        </tr>
      </thead>
      <tbody>
        <% funnelLogs.forEach(log => { %>
        <%
          const typeLabels = {
            verification: {label:'✉️ Vérification email', color:'#6366f1'},
            welcome: {label:'🎉 Bienvenue', color:'#10b981'},
            trial_ending: {label:'⏰ Rappel fin d\'essai', color:'#f59e0b'},
            trial_expired: {label:'😔 Essai expiré', color:'#ef4444'},
            followup: {label:'💡 Relance J+9', color:'#3b82f6'},
            discount: {label:'🔥 Promo −15% annuel', color:'#dc2626'},
          };
          const tl = typeLabels[log.type] || {label: log.type, color:'#94a3b8'};
        %>
        <tr style="border-bottom:1px solid #0f172a;">
          <td style="padding:10px 12px;">
            <span style="font-size:12px;font-weight:600;color:<%= tl.color %>;"><%= tl.label %></span>
          </td>
          <td style="padding:10px 12px;">
            <p style="margin:0;color:#e2e8f0;font-size:13px;"><%= log.user_name %></p>
            <p style="margin:2px 0 0;color:#64748b;font-size:11px;"><%= log.user_email %></p>
          </td>
          <td style="padding:10px 12px;color:#64748b;font-size:12px;">
            <%= new Date(log.sent_at).toLocaleDateString('fr-FR', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
