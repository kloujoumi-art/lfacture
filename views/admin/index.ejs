<!-- Stats cards -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
  <div class="stat-card">
    <p style="font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Total utilisateurs</p>
    <p style="font-size:32px;font-weight:900;color:#f1f5f9;"><%= stats.total_users %></p>
    <p style="font-size:12px;color:#10b981;margin-top:4px;">+<%= stats.new_today %> aujourd'hui</p>
  </div>
  <div class="stat-card">
    <p style="font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">En essai</p>
    <p style="font-size:32px;font-weight:900;color:#f59e0b;"><%= stats.trial_users %></p>
    <p style="font-size:12px;color:#64748b;margin-top:4px;">Essai actif</p>
  </div>
  <div class="stat-card">
    <p style="font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Abonnés actifs</p>
    <p style="font-size:32px;font-weight:900;color:#10b981;"><%= stats.active_users %></p>
    <p style="font-size:12px;color:#64748b;margin-top:4px;">Plan payant</p>
  </div>
  <div class="stat-card">
    <p style="font-size:11px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Expirés</p>
    <p style="font-size:32px;font-weight:900;color:#ef4444;"><%= stats.expired_users %></p>
    <p style="font-size:12px;color:#64748b;margin-top:4px;">À relancer</p>
  </div>
</div>

<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:24px;">
  <div class="stat-card" style="display:flex;align-items:center;gap:16px;">
    <div style="width:48px;height:48px;border-radius:10px;background:rgba(59,130,246,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg style="width:24px;height:24px;color:#3b82f6;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    </div>
    <div>
      <p style="font-size:28px;font-weight:900;color:#f1f5f9;"><%= stats.total_invoices %></p>
      <p style="font-size:12px;color:#64748b;">Factures créées</p>
    </div>
  </div>
  <div class="stat-card" style="display:flex;align-items:center;gap:16px;">
    <div style="width:48px;height:48px;border-radius:10px;background:rgba(139,92,246,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg style="width:24px;height:24px;color:#8b5cf6;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    </div>
    <div>
      <p style="font-size:28px;font-weight:900;color:#f1f5f9;"><%= stats.total_quotes %></p>
      <p style="font-size:12px;color:#64748b;">Devis créés</p>
    </div>
  </div>
</div>

<!-- Recent users -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;overflow:hidden;">
  <div style="padding:16px 20px;border-bottom:1px solid #334155;display:flex;align-items:center;justify-content:space-between;">
    <h2 style="font-size:14px;font-weight:700;color:#f1f5f9;">Derniers inscrits</h2>
    <a href="/admin/users" style="font-size:12px;color:#3b82f6;font-weight:600;">Voir tous →</a>
  </div>
  <table style="width:100%;border-collapse:collapse;">
    <thead>
      <tr style="background:rgba(255,255,255,.02);">
        <th style="text-align:left;padding:10px 20px;font-size:11px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.5px;">Utilisateur</th>
        <th style="text-align:left;padding:10px 20px;font-size:11px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.5px;">Plan</th>
        <th style="text-align:left;padding:10px 20px;font-size:11px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.5px;">Inscrit le</th>
        <th style="text-align:right;padding:10px 20px;font-size:11px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.5px;">Action</th>
      </tr>
    </thead>
    <tbody>
      <% recentUsers.forEach(u => { %>
      <tr style="border-top:1px solid #1e293b;">
        <td style="padding:12px 20px;">
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:<%= u.is_admin ? '#ef4444' : '#3b82f6' %>;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:12px;flex-shrink:0;"><%= u.name.charAt(0).toUpperCase() %></div>
            <div>
              <p style="font-size:13px;font-weight:600;color:#f1f5f9;"><%= u.name %><%= u.is_admin ? ' 👑' : '' %></p>
              <p style="font-size:11px;color:#64748b;"><%= u.email %></p>
            </div>
          </div>
        </td>
        <td style="padding:12px 20px;">
          <% const now = new Date();
             const isActiveTrial = u.plan === 'trial' && new Date(u.trial_ends_at) > now;
             const isActive = u.plan === 'active' && u.subscription_ends_at && new Date(u.subscription_ends_at) > now;
          %>
          <span style="font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;<%=
            isActiveTrial ? 'background:rgba(245,158,11,.15);color:#fbbf24;' :
            isActive ? 'background:rgba(16,185,129,.15);color:#34d399;' :
            'background:rgba(239,68,68,.15);color:#f87171;'
          %>">
            <%= isActiveTrial ? '⏳ Essai' : isActive ? '✓ Actif' : '✗ Expiré' %>
          </span>
        </td>
        <td style="padding:12px 20px;font-size:12px;color:#64748b;"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
        <td style="padding:12px 20px;text-align:right;">
          <a href="/admin/users/<%= u.id %>" style="font-size:12px;color:#3b82f6;font-weight:600;">Gérer →</a>
        </td>
      </tr>
      <% }); %>
      <% if (!recentUsers || recentUsers.length === 0) { %>
      <tr><td colspan="4" style="padding:32px;text-align:center;color:#475569;font-size:13px;">Aucun utilisateur</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
