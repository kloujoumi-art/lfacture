<!-- Résumé -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div style="background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:14px;padding:20px 24px;">
    <p style="color:rgba(255,255,255,.7);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px;">Total encaissé</p>
    <p style="color:#fff;font-size:28px;font-weight:900;margin:0;"><%= total.toLocaleString('fr-FR',{minimumFractionDigits:2}) %> €</p>
  </div>
  <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px 24px;">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px;">Commandes</p>
    <p style="color:#1e293b;font-size:28px;font-weight:900;margin:0;"><%= payments.length %></p>
  </div>
  <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px 24px;">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px;">Panier moyen</p>
    <p style="color:#1e293b;font-size:28px;font-weight:900;margin:0;"><%= payments.length > 0 ? (total/payments.length).toLocaleString('fr-FR',{minimumFractionDigits:2}) : '0,00' %> €</p>
  </div>
</div>

<!-- Tableau paiements -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <div style="padding:20px 24px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;justify-content:space-between;">
    <h2 style="font-size:16px;font-weight:800;color:#1e293b;margin:0;">Historique des paiements</h2>
    <span style="font-size:12px;color:#94a3b8;">Via Paddle · skacollection.com</span>
  </div>

  <% if(payments.length === 0){ %>
  <div style="padding:48px;text-align:center;">
    <p style="font-size:32px;margin:0 0 8px;">💳</p>
    <p style="color:#94a3b8;font-size:14px;margin:0;">Aucun paiement encore enregistré.</p>
    <p style="color:#cbd5e1;font-size:12px;margin:6px 0 0;">Les paiements apparaissent ici automatiquement après chaque webhook Paddle.</p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="background:#f8fafc;border-bottom:1px solid #f1f5f9;">
        <th style="text-align:left;padding:11px 16px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Date</th>
        <th style="text-align:left;padding:11px 12px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Client</th>
        <th style="text-align:left;padding:11px 12px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Plan</th>
        <th style="text-align:center;padding:11px 12px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Durée</th>
        <th style="text-align:right;padding:11px 16px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Montant</th>
        <th style="text-align:left;padding:11px 12px;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Transaction ID</th>
      </tr>
    </thead>
    <tbody>
      <% payments.forEach((p,i) => { %>
      <tr style="border-bottom:1px solid #f8fafc;background:<%=i%2===0?'#fff':'#fafbfc'%>;">
        <td style="padding:11px 16px;color:#64748b;white-space:nowrap;"><%= new Date(p.created_at).toLocaleDateString('fr-FR') %> <span style="color:#94a3b8;font-size:11px;"><%= new Date(p.created_at).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) %></span></td>
        <td style="padding:11px 12px;">
          <p style="font-weight:700;color:#1e293b;margin:0 0 1px;"><%= p.user_email %></p>
        </td>
        <td style="padding:11px 12px;">
          <span style="background:#eef2ff;color:#4F46E5;font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;"><%= p.plan_label || 'LFacture' %></span>
        </td>
        <td style="padding:11px 12px;text-align:center;color:#64748b;"><%= p.plan_months %> mois</td>
        <td style="padding:11px 16px;text-align:right;font-weight:800;color:#4F46E5;font-size:14px;"><%= (p.amount||0).toLocaleString('fr-FR',{minimumFractionDigits:2}) %> <%= p.currency||'EUR' %></td>
        <td style="padding:11px 12px;"><span style="font-family:monospace;font-size:11px;color:#94a3b8;"><%= p.transaction_id ? p.transaction_id.slice(0,20)+'…' : '—' %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
  <% } %>
</div>
