<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;">
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">En attente vérif.</p>
    <p style="font-size:28px;font-weight:900;color:#f59e0b;margin:0;"><%= pendingUsers.length %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Email non vérifié</p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Plan Gratuit</p>
    <p style="font-size:28px;font-weight:900;color:#6366f1;margin:0;"><%= freeUsers.length %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">8 fact. + 8 devis max</p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Abonnés actifs</p>
    <p style="font-size:28px;font-weight:900;color:#10b981;margin:0;"><%= stats.active_users %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Plans payants</p>
  </div>
  <div class="stat-card">
    <p style="color:#94a3b8;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;">Contacts mailing</p>
    <p style="font-size:28px;font-weight:900;color:#f472b6;margin:0;"><%= stats.total_contacts %></p>
    <p style="color:#64748b;font-size:12px;margin:4px 0 0;">Inscrits funnel</p>
  </div>
</div>

<!-- En attente de vérification -->
<% if (pendingUsers.length > 0) { %>
<div style="background:#1e293b;border:1px solid #f59e0b;border-radius:12px;padding:20px;margin-bottom:24px;">
  <h3 style="color:#fbbf24;font-size:14px;font-weight:700;margin:0 0 16px;">⏳ En attente de vérification email (<%= pendingUsers.length %>)</h3>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead><tr style="border-bottom:1px solid #334155;">
        <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Nom</th>
        <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Email</th>
        <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Inscrit le</th>
        <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Actions</th>
      </tr></thead>
      <tbody>
        <% pendingUsers.forEach(u => { %>
        <tr style="border-bottom:1px solid #0f172a;">
          <td style="padding:10px 12px;color:#e2e8f0;font-weight:600;"><%= u.name %></td>
          <td style="padding:10px 12px;color:#94a3b8;"><%= u.email %></td>
          <td style="padding:10px 12px;color:#64748b;font-size:12px;"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
          <td style="padding:10px 12px;"><a href="/admin/users/<%= u.id %>" style="color:#3b82f6;font-size:12px;font-weight:600;text-decoration:none;">Voir →</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Utilisateurs plan gratuit -->
<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;padding:20px;">
  <h3 style="color:#e2e8f0;font-size:14px;font-weight:700;margin:0 0 6px;">Plan Gratuit — Utilisation des quotas</h3>
  <p style="color:#64748b;font-size:12px;margin:0 0 16px;">Chaque compte gratuit peut créer jusqu'à <strong style="color:#94a3b8;">8 factures</strong> et <strong style="color:#94a3b8;">8 devis</strong>. Pas de limite de temps.</p>

  <% if (freeUsers.length === 0) { %>
  <p style="color:#64748b;text-align:center;padding:20px 0;font-size:14px;">Aucun utilisateur sur le plan gratuit pour le moment.</p>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:1px solid #334155;">
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Utilisateur</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Factures (8 max)</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Devis (8 max)</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Emails funnel</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;">Inscrit le</th>
          <th style="text-align:left;padding:8px 12px;color:#64748b;font-weight:600;"></th>
        </tr>
      </thead>
      <tbody>
        <% freeUsers.forEach(u => { %>
        <%
          const invColor = u.invProgress >= 100 ? '#ef4444' : u.invProgress >= 75 ? '#f59e0b' : '#10b981';
          const quotColor = u.quotProgress >= 100 ? '#ef4444' : u.quotProgress >= 75 ? '#f59e0b' : '#10b981';
          const funnel = {
            verification: u.funnelLogs.some(l => l.type === 'verification'),
            welcome: u.funnelLogs.some(l => l.type === 'welcome'),
            followup: u.funnelLogs.some(l => l.type === 'followup'),
            discount: u.funnelLogs.some(l => l.type === 'discount'),
          };
        %>
        <tr style="border-bottom:1px solid #0f172a;">
          <td style="padding:12px;">
            <p style="margin:0;color:#e2e8f0;font-weight:600;"><%= u.name %></p>
            <p style="margin:2px 0 0;color:#64748b;font-size:12px;"><%= u.email %></p>
          </td>
          <td style="padding:12px;min-width:150px;">
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="flex:1;background:#0f172a;border-radius:6px;height:8px;overflow:hidden;">
                <div style="background:<%= invColor %>;height:100%;width:<%= u.invProgress %>%;border-radius:6px;"></div>
              </div>
              <span style="color:<%= invColor %>;font-weight:700;font-size:12px;flex-shrink:0;"><%= u.quota.invoices.used %>/<%= u.quota.invoices.max %></span>
            </div>
            <% if (u.quota.invoices.reached) { %><p style="margin:4px 0 0;color:#ef4444;font-size:11px;font-weight:600;">Limite atteinte</p><% } %>
          </td>
          <td style="padding:12px;min-width:150px;">
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="flex:1;background:#0f172a;border-radius:6px;height:8px;overflow:hidden;">
                <div style="background:<%= quotColor %>;height:100%;width:<%= u.quotProgress %>%;border-radius:6px;"></div>
              </div>
              <span style="color:<%= quotColor %>;font-weight:700;font-size:12px;flex-shrink:0;"><%= u.quota.quotes.used %>/<%= u.quota.quotes.max %></span>
            </div>
            <% if (u.quota.quotes.reached) { %><p style="margin:4px 0 0;color:#ef4444;font-size:11px;font-weight:600;">Limite atteinte</p><% } %>
          </td>
          <td style="padding:12px;">
            <div style="display:flex;gap:4px;">
              <span title="Vérif." style="width:20px;height:20px;border-radius:4px;background:<%= funnel.verification ? '#065f46' : '#0f172a' %>;border:1px solid <%= funnel.verification ? '#059669' : '#334155' %>;display:flex;align-items:center;justify-content:center;font-size:10px;">✉</span>
              <span title="Bienvenue" style="width:20px;height:20px;border-radius:4px;background:<%= funnel.welcome ? '#065f46' : '#0f172a' %>;border:1px solid <%= funnel.welcome ? '#059669' : '#334155' %>;display:flex;align-items:center;justify-content:center;font-size:10px;">👋</span>
              <span title="Relance" style="width:20px;height:20px;border-radius:4px;background:<%= funnel.followup ? '#065f46' : '#0f172a' %>;border:1px solid <%= funnel.followup ? '#059669' : '#334155' %>;display:flex;align-items:center;justify-content:center;font-size:10px;">💡</span>
              <span title="-15%" style="width:20px;height:20px;border-radius:4px;background:<%= funnel.discount ? '#7f1d1d' : '#0f172a' %>;border:1px solid <%= funnel.discount ? '#dc2626' : '#334155' %>;display:flex;align-items:center;justify-content:center;font-size:10px;">🔥</span>
            </div>
          </td>
          <td style="padding:12px;color:#64748b;font-size:12px;"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
          <td style="padding:12px;"><a href="/admin/users/<%= u.id %>" class="btn-gray" style="font-size:11px;padding:5px 10px;">Voir</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
