<style>
  .an-card { background:#1e293b; border:1px solid #334155; border-radius:12px; padding:20px; }
  .bar-track { background:#0f172a; border-radius:4px; height:8px; overflow:hidden; }
  .bar-fill  { border-radius:4px; height:8px; transition:width .4s; }
  .tab-btn { padding:8px 18px; border-radius:8px; font-size:13px; font-weight:600; color:#64748b; cursor:pointer; text-decoration:none; transition:all .15s; }
  .tab-btn.active, .tab-btn:hover { background:#334155; color:#f1f5f9; }
  .chart-bar-wrap { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; min-width:0; }
  .chart-bar-outer { width:100%; display:flex; flex-direction:column; justify-content:flex-end; }
  .chart-bar { border-radius:4px 4px 0 0; min-height:2px; background:linear-gradient(180deg,#6366f1,#4f46e5); transition:height .5s; }
  .chart-label { font-size:10px; color:#64748b; text-align:center; margin-top:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:100%; }
  .chart-val   { font-size:10px; color:#94a3b8; text-align:center; }
  .trend-up   { color:#10b981; font-size:11px; font-weight:700; }
  .trend-down { color:#ef4444; font-size:11px; font-weight:700; }
  .trend-neut { color:#64748b; font-size:11px; font-weight:700; }
</style>

<!-- Period tabs -->
<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:20px;">
  <a href="/admin/analytics?period=today"     class="tab-btn <%= period==='today'     ? 'active':'' %>">Aujourd'hui</a>
  <a href="/admin/analytics?period=yesterday" class="tab-btn <%= period==='yesterday' ? 'active':'' %>">Hier</a>
  <a href="/admin/analytics?period=7d"        class="tab-btn <%= period==='7d'        ? 'active':'' %>">7 jours</a>
  <a href="/admin/analytics?period=30d"       class="tab-btn <%= period==='30d'       ? 'active':'' %>">30 jours</a>
  <!-- Custom -->
  <form method="GET" action="/admin/analytics" style="display:flex;align-items:center;gap:6px;margin-left:8px;">
    <input type="hidden" name="period" value="custom"/>
    <input type="date" name="from_date" value="<%= from_date %>"
      style="background:#1e293b;border:1px solid #334155;border-radius:8px;padding:7px 10px;font-size:12px;color:#e2e8f0;"/>
    <span style="color:#475569;font-size:12px;">→</span>
    <input type="date" name="to_date" value="<%= to_date %>"
      style="background:#1e293b;border:1px solid #334155;border-radius:8px;padding:7px 10px;font-size:12px;color:#e2e8f0;"/>
    <button type="submit" style="background:#4f46e5;color:#fff;border:none;border-radius:8px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;">OK</button>
  </form>
</div>

<!-- Quick cards: Aujourd'hui + Hier -->
<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px;">
  <div class="an-card" style="display:flex;align-items:center;gap:14px;">
    <div style="width:42px;height:42px;border-radius:10px;background:rgba(99,102,241,.15);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">📅</div>
    <div>
      <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;">Aujourd'hui</p>
      <p style="font-size:24px;font-weight:900;color:#f1f5f9;line-height:1;"><%= todayViews %> <span style="font-size:13px;color:#64748b;font-weight:500;">vues</span></p>
      <p style="font-size:12px;color:#94a3b8;margin-top:2px;"><%= todayUniq %> visiteurs uniques</p>
    </div>
  </div>
  <div class="an-card" style="display:flex;align-items:center;gap:14px;">
    <div style="width:42px;height:42px;border-radius:10px;background:rgba(99,102,241,.1);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">📆</div>
    <div>
      <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;">Hier</p>
      <p style="font-size:24px;font-weight:900;color:#f1f5f9;line-height:1;"><%= yesterdayViews %> <span style="font-size:13px;color:#64748b;font-weight:500;">vues</span></p>
      <p style="font-size:12px;color:#94a3b8;margin-top:2px;"><%= yesterdayUniq %> visiteurs uniques</p>
    </div>
  </div>
</div>

<!-- Stat cards période -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:24px;">

  <div class="an-card">
    <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Vues totales</p>
    <p style="font-size:32px;font-weight:900;color:#f1f5f9;line-height:1;"><%= totalViews.toLocaleString('fr-FR') %></p>
    <p class="<%= viewsPct.startsWith('+') ? 'trend-up' : viewsPct.startsWith('-') ? 'trend-down' : 'trend-neut' %>" style="margin-top:6px;">
      <%= viewsPct %> vs période préc.
    </p>
  </div>

  <div class="an-card">
    <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Visiteurs uniques</p>
    <p style="font-size:32px;font-weight:900;color:#6366f1;line-height:1;"><%= uniqueVisitors.toLocaleString('fr-FR') %></p>
    <p class="<%= uniqPct.startsWith('+') ? 'trend-up' : uniqPct.startsWith('-') ? 'trend-down' : 'trend-neut' %>" style="margin-top:6px;">
      <%= uniqPct %> vs période préc.
    </p>
  </div>

  <div class="an-card">
    <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Sessions</p>
    <p style="font-size:32px;font-weight:900;color:#10b981;line-height:1;"><%= uniqueSessions.toLocaleString('fr-FR') %></p>
    <p style="font-size:11px;color:#64748b;margin-top:6px;">Navigations distinctes</p>
  </div>

  <div class="an-card">
    <p style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Pages / visiteur</p>
    <p style="font-size:32px;font-weight:900;color:#f59e0b;line-height:1;"><%= uniqueVisitors > 0 ? (totalViews / uniqueVisitors).toFixed(1) : '—' %></p>
    <p style="font-size:11px;color:#64748b;margin-top:6px;">Engagement moyen</p>
  </div>

</div>

<!-- Graphique bar chart -->
<div class="an-card" style="margin-bottom:20px;">
  <p style="font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:4px;">Vues par jour</p>
  <p style="font-size:11px;color:#64748b;margin-bottom:16px;"><%= startDate %> → <%= endDate %></p>
  <div style="display:flex;align-items:flex-end;gap:4px;height:120px;padding-bottom:0;">
    <% chartDays.forEach(day => { %>
    <div class="chart-bar-wrap">
      <div class="chart-val"><%= day.views > 0 ? day.views : '' %></div>
      <div class="chart-bar-outer" style="height:100px;">
        <div class="chart-bar" style="height:<%- Math.round((day.views / chartMax) * 100) %>%;min-height:<%= day.views>0?'4':'0' %>px;"></div>
      </div>
      <div class="chart-label" title="<%= day.date %>"><%= day.label %></div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Pays + Sources -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">

  <!-- Pays -->
  <div class="an-card">
    <p style="font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:16px;">🌍 Pays des visiteurs</p>
    <% if (countries.length === 0) { %>
      <p style="font-size:12px;color:#475569;text-align:center;padding:20px 0;">En attente de données…<br/><span style="font-size:11px;">Les pays sont détectés progressivement via IP.</span></p>
    <% } else { %>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <% countries.forEach((c, i) => { %>
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:18px;line-height:1;"><%= c.flag %></span>
            <span style="font-size:13px;color:#e2e8f0;font-weight:<%= i===0?'700':'500' %>"><%= c.name %></span>
            <span style="font-size:10px;color:#475569;font-weight:600;"><%= c.code %></span>
          </div>
          <span style="font-size:13px;font-weight:700;color:<%= i===0?'#6366f1':'#94a3b8' %>"><%= c.count %></span>
        </div>
        <div class="bar-track">
          <div class="bar-fill" style="width:<%- Math.round((c.count/countryMax)*100) %>%;background:<%= i===0?'linear-gradient(90deg,#6366f1,#8b5cf6)':'#334155' %>"></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- Sources de trafic -->
  <div class="an-card">
    <p style="font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:16px;">📡 Sources de trafic</p>
    <% if (sources.length === 0) { %>
      <p style="font-size:12px;color:#475569;text-align:center;padding:20px 0;">Aucune donnée sur cette période.</p>
    <% } else { %>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <% sources.forEach((s, i) => { %>
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:16px;"><%= s.icon %></span>
            <span style="font-size:13px;color:#e2e8f0;font-weight:<%= i===0?'700':'500' %>"><%= s.label %></span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;color:#64748b;"><%= totalViews > 0 ? Math.round((s.count/totalViews)*100) : 0 %>%</span>
            <span style="font-size:13px;font-weight:700;color:#e2e8f0;"><%= s.count %></span>
          </div>
        </div>
        <div class="bar-track">
          <div class="bar-fill" style="width:<%- Math.round((s.count/sourceMax)*100) %>%;background:<%= s.color %>"></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<!-- Top pages -->
<div class="an-card">
  <p style="font-size:13px;font-weight:700;color:#f1f5f9;margin-bottom:16px;">📄 Pages les plus visitées</p>
  <% if (topPages.length === 0) { %>
    <p style="font-size:12px;color:#475569;text-align:center;padding:20px 0;">Aucune donnée sur cette période.</p>
  <% } else { %>
  <table style="width:100%;border-collapse:collapse;">
    <thead>
      <tr style="border-bottom:1px solid #334155;">
        <th style="text-align:left;font-size:11px;color:#475569;font-weight:600;padding:0 0 10px;text-transform:uppercase;letter-spacing:.5px;">#</th>
        <th style="text-align:left;font-size:11px;color:#475569;font-weight:600;padding:0 0 10px;text-transform:uppercase;letter-spacing:.5px;">Page</th>
        <th style="text-align:right;font-size:11px;color:#475569;font-weight:600;padding:0 0 10px;text-transform:uppercase;letter-spacing:.5px;">Vues</th>
        <th style="text-align:right;font-size:11px;color:#475569;font-weight:600;padding:0 0 10px;text-transform:uppercase;letter-spacing:.5px;">%</th>
      </tr>
    </thead>
    <tbody>
      <% topPages.forEach((p, i) => { %>
      <tr style="border-bottom:1px solid #1e293b;">
        <td style="padding:10px 0;font-size:12px;color:#475569;font-weight:700;width:28px;"><%= i+1 %></td>
        <td style="padding:10px 8px 10px 0;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:12px;color:#94a3b8;font-family:monospace;"><%= p.path %></span>
          </div>
          <div class="bar-track" style="margin-top:4px;max-width:200px;">
            <div class="bar-fill" style="width:<%- Math.round((p.count/pageMax)*100) %>%;background:#4f46e5;"></div>
          </div>
        </td>
        <td style="padding:10px 0;font-size:13px;font-weight:700;color:#f1f5f9;text-align:right;"><%= p.count %></td>
        <td style="padding:10px 0;font-size:12px;color:#64748b;text-align:right;"><%= totalViews > 0 ? Math.round((p.count/totalViews)*100) : 0 %>%</td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>
