<style>
.feat-row { display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center; padding:64px 0; border-bottom:1px solid #f1f5f9; }
.feat-row:last-child { border-bottom:none; }
@media(max-width:768px){ .feat-row { grid-template-columns:1fr; gap:32px; } .feat-row.reverse-mobile .text-col { order:1; } .feat-row.reverse-mobile .visual-col { order:2; } }
.feat-icon-box { width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; margin-bottom:16px; flex-shrink:0; }
.mini-card { background:#fff; border:1px solid #e8edf3; border-radius:12px; padding:14px 16px; margin-bottom:10px; }
</style>

<!-- Hero -->
<section class="pt-12 pb-16 text-center" style="background:linear-gradient(160deg,#f8faff,#f0f4ff);">
  <div class="max-w-3xl mx-auto px-4">
    <span class="inline-block bg-indigo-50 text-indigo-600 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4">Features</span>
    <h1 class="text-5xl font-black text-gray-900 mb-4">
      Everything in your<br/>
      <span class="gradient-text">free invoice generator</span>
    </h1>
    <p class="text-xl text-gray-500 mb-8">Professional invoicing tools for freelancers and small businesses — all included free</p>
    <a href="/register" class="btn-primary text-white font-bold text-base px-8 py-4 rounded-xl inline-block">
      Try all features free →
    </a>
  </div>
</section>

<!-- Feature stats -->
<section class="py-12 bg-white border-b border-gray-100">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      <% [
        {num:'9', label:'Invoice templates', color:'#4F46E5'},
        {num:'PDF+', label:'Word export', color:'#2563eb'},
        {num:'∞', label:'Clients (free)', color:'#059669'},
        {num:'30s', label:'To create invoice', color:'#7C3AED'},
      ].forEach(s=>{ %>
      <div>
        <p class="text-4xl font-black mb-1" style="color:<%= s.color %>"><%= s.num %></p>
        <p class="text-sm font-semibold text-gray-500"><%= s.label %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Feature deep-dives -->
<section class="py-10">
  <div class="max-w-6xl mx-auto px-4">

    <!-- 1. PDF Invoice Generator -->
    <div class="feat-row">
      <div class="text-col">
        <div class="feat-icon-box" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
          <svg width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-3xl font-black text-gray-900 mb-4">PDF Invoice Generator</h2>
        <p class="text-gray-500 leading-relaxed mb-6">Generate professional, pixel-perfect A4 PDF invoices instantly. Every invoice looks great whether viewed on screen, emailed, or printed. No design skills needed — the format is always perfect.</p>
        <ul class="space-y-3">
          <% ['A4 format — print-ready', 'Instant download after creation', 'Professional layout on every template', 'Includes all invoice fields: number, date, due date, payment terms'].forEach(f=>{ %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <span class="w-5 h-5 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
            <%= f %>
          </li>
          <% }) %>
        </ul>
      </div>
      <div class="visual-col">
        <div style="background:linear-gradient(160deg,#eef2ff,#faf5ff);border-radius:20px;padding:28px;">
          <div style="background:#fff;border-radius:12px;padding:20px;box-shadow:0 8px 24px rgba(79,70,229,.1);">
            <div style="height:8px;background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:4px;margin-bottom:14px;"></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
              <div>
                <div style="width:80px;height:8px;background:#f1f5f9;border-radius:4px;margin-bottom:5px;"></div>
                <div style="width:60px;height:6px;background:#f8fafc;border-radius:3px;"></div>
              </div>
              <div style="text-align:right;">
                <div style="width:70px;height:10px;background:#4F46E5;border-radius:4px;margin-bottom:5px;"></div>
                <div style="width:50px;height:6px;background:#f1f5f9;border-radius:3px;"></div>
              </div>
            </div>
            <div style="background:#f8fafc;border-radius:8px;padding:10px;margin-bottom:10px;">
              <div style="display:grid;grid-template-columns:1fr auto;gap:8px;margin-bottom:6px;">
                <div style="height:6px;background:#e2e8f0;border-radius:3px;"></div>
                <div style="height:6px;background:#e2e8f0;border-radius:3px;width:40px;"></div>
              </div>
              <div style="display:grid;grid-template-columns:1fr auto;gap:8px;margin-bottom:4px;">
                <div style="height:5px;background:#f1f5f9;border-radius:3px;"></div>
                <div style="height:5px;background:#4F46E5;border-radius:3px;width:30px;"></div>
              </div>
              <div style="display:grid;grid-template-columns:1fr auto;gap:8px;">
                <div style="height:5px;background:#f1f5f9;border-radius:3px;width:80%;"></div>
                <div style="height:5px;background:#4F46E5;border-radius:3px;width:30px;"></div>
              </div>
            </div>
            <div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
              <div style="width:120px;background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:6px;padding:6px 10px;display:flex;justify-content:space-between;">
                <span style="color:#fff;font-size:10px;font-weight:700;">TOTAL</span>
                <span style="color:#fff;font-size:11px;font-weight:900;">$2,145</span>
              </div>
            </div>
            <div style="background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:8px;padding:10px;text-align:center;color:#fff;font-size:12px;font-weight:800;">⬇ Download PDF — Instant</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Word Export -->
    <div class="feat-row reverse-mobile" style="direction:rtl;">
      <div class="text-col" style="direction:ltr;">
        <div class="feat-icon-box" style="background:linear-gradient(135deg,#2563eb,#1d4ed8);">
          <svg width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-3xl font-black text-gray-900 mb-4">Word (.docx) Export</h2>
        <p class="text-gray-500 leading-relaxed mb-6">Export any invoice to Microsoft Word format. Edit the document locally before sending, add custom sections, or share in a format your clients can edit. Unique feature rarely found in free invoice generators.</p>
        <ul class="space-y-3">
          <% ['Full .docx format — opens in Word & LibreOffice', 'Preserves your template colors', 'Editable after download', 'Same professional layout as the PDF'].forEach(f=>{ %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <span class="w-5 h-5 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
            <%= f %>
          </li>
          <% }) %>
        </ul>
      </div>
      <div class="visual-col" style="direction:ltr;">
        <div style="background:linear-gradient(160deg,#eff6ff,#dbeafe);border-radius:20px;padding:28px;text-align:center;">
          <div style="display:inline-flex;flex-direction:column;gap:12px;width:100%;max-width:280px;">
            <div style="background:#fff;border-radius:10px;padding:14px 16px;box-shadow:0 4px 12px rgba(37,99,235,.1);display:flex;align-items:center;gap:12px;">
              <div style="width:36px;height:36px;background:#2563eb;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;font-weight:900;flex-shrink:0;">W</div>
              <div style="text-align:left;">
                <p style="font-weight:800;color:#1e293b;font-size:13px;margin:0 0 2px;">FAC-2024-042.docx</p>
                <p style="font-size:11px;color:#64748b;margin:0;">Microsoft Word Document</p>
              </div>
              <div style="margin-left:auto;background:#dbeafe;color:#2563eb;font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;">⬇ DOCX</div>
            </div>
            <div style="background:#fff;border-radius:10px;padding:14px 16px;box-shadow:0 4px 12px rgba(79,70,229,.08);display:flex;align-items:center;gap:12px;">
              <div style="width:36px;height:36px;background:#dc2626;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;font-weight:900;flex-shrink:0;">P</div>
              <div style="text-align:left;">
                <p style="font-weight:800;color:#1e293b;font-size:13px;margin:0 0 2px;">FAC-2024-042.pdf</p>
                <p style="font-size:11px;color:#64748b;margin:0;">PDF Document</p>
              </div>
              <div style="margin-left:auto;background:#fee2e2;color:#dc2626;font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;">⬇ PDF</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 3. Templates -->
    <div class="feat-row">
      <div class="text-col">
        <div class="feat-icon-box" style="background:linear-gradient(135deg,#059669,#047857);">
          <svg width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
        </div>
        <h2 class="text-3xl font-black text-gray-900 mb-4">9 Professional Invoice Templates</h2>
        <p class="text-gray-500 leading-relaxed mb-6">Every invoice template is professionally designed and free to use. Switch template at any time — your invoice data is preserved. Choose the style that matches your brand.</p>
        <div class="grid grid-cols-3 gap-2">
          <% [
            {name:'Classic',color:'#4F46E5'},{name:'Minimal',color:'#111827'},{name:'Blue',color:'#1d4ed8'},
            {name:'Green',color:'#059669'},{name:'Orange',color:'#f97316'},{name:'Red',color:'#dc2626'},
            {name:'Navy',color:'#0f172a'},{name:'Slate',color:'#334155'},{name:'Creative',color:'#9333ea'},
          ].forEach(t=>{ %>
          <div style="background:<%=t.color%>11;border:1.5px solid <%=t.color%>33;border-radius:8px;padding:8px;text-align:center;">
            <div style="width:24px;height:24px;background:<%=t.color%>;border-radius:5px;margin:0 auto 5px;"></div>
            <p style="font-size:10px;font-weight:700;color:#64748b;margin:0;"><%= t.name %></p>
          </div>
          <% }) %>
        </div>
      </div>
      <div class="visual-col">
        <div style="background:linear-gradient(160deg,#ecfdf5,#d1fae5);border-radius:20px;padding:24px;">
          <div class="grid grid-cols-3 gap-3">
            <% [
              {color:'#4F46E5'},{color:'#1d4ed8'},{color:'#059669'},
              {color:'#f97316'},{color:'#9333ea'},{color:'#dc2626'},
            ].forEach(t=>{ %>
            <div style="background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.06);">
              <div style="height:28px;background:<%=t.color%>;"></div>
              <div style="padding:8px;">
                <div style="height:4px;background:<%=t.color%>33;border-radius:2px;margin-bottom:4px;width:70%;"></div>
                <div style="height:3px;background:<%=t.color%>22;border-radius:2px;margin-bottom:3px;"></div>
                <div style="height:3px;background:<%=t.color%>22;border-radius:2px;width:80%;"></div>
              </div>
            </div>
            <% }) %>
          </div>
          <p style="text-align:center;font-size:12px;color:#059669;font-weight:700;margin-top:12px;">Switch templates instantly — all 9 are free</p>
        </div>
      </div>
    </div>

    <!-- 4. Client Management -->
    <div class="feat-row reverse-mobile" style="direction:rtl;">
      <div class="text-col" style="direction:ltr;">
        <div class="feat-icon-box" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
          <svg width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
        </div>
        <h2 class="text-3xl font-black text-gray-900 mb-4">Client Management</h2>
        <p class="text-gray-500 leading-relaxed mb-6">Save your clients once and reuse their details on every invoice. Build a professional client database — addresses, logos, tax numbers, contacts — all at your fingertips.</p>
        <ul class="space-y-3">
          <% ['Unlimited clients stored', 'Client logo on invoices', 'Full address & contact details', 'Client history — all invoices in one view', 'Pre-fill invoice form from saved client'].forEach(f=>{ %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <span class="w-5 h-5 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
            <%= f %>
          </li>
          <% }) %>
        </ul>
      </div>
      <div class="visual-col" style="direction:ltr;">
        <div style="background:linear-gradient(160deg,#fffbeb,#fef3c7);border-radius:20px;padding:24px;">
          <% [
            {name:'Acme Corp',role:'Web Design Client',tag:'3 invoices',color:'#4F46E5'},
            {name:'StartupXYZ',role:'Marketing Consultant',tag:'7 invoices',color:'#059669'},
            {name:'Media Group',role:'Development',tag:'12 invoices',color:'#7C3AED'},
          ].forEach(c=>{ %>
          <div class="mini-card" style="display:flex;align-items:center;gap:12px;">
            <div style="width:38px;height:38px;background:<%=c.color%>;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;font-size:14px;flex-shrink:0;"><%= c.name[0] %></div>
            <div style="flex:1;">
              <p style="font-weight:800;color:#1e293b;font-size:13px;margin:0 0 2px;"><%= c.name %></p>
              <p style="font-size:11px;color:#64748b;margin:0;"><%= c.role %></p>
            </div>
            <span style="background:<%=c.color%>15;color:<%=c.color%>;font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;"><%= c.tag %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- 5. Quotes -->
    <div class="feat-row">
      <div class="text-col">
        <div class="feat-icon-box" style="background:linear-gradient(135deg,#7c3aed,#6d28d9);">
          <svg width="24" height="24" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <h2 class="text-3xl font-black text-gray-900 mb-4">Free Quote Generator</h2>
        <p class="text-gray-500 leading-relaxed mb-6">Create professional quotes (estimates) with the same templates as invoices. Send to clients for approval, then convert accepted quotes to invoices with a single click — no re-entering data.</p>
        <ul class="space-y-3">
          <% ['8 free quotes included', 'Same 9 professional templates', 'One-click convert quote → invoice', 'Quote validity date', 'Accepted/Rejected/Pending status'].forEach(f=>{ %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <span class="w-5 h-5 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
            <%= f %>
          </li>
          <% }) %>
        </ul>
      </div>
      <div class="visual-col">
        <div style="background:linear-gradient(160deg,#f5f3ff,#ede9fe);border-radius:20px;padding:24px;">
          <div class="mini-card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div>
                <p style="font-size:12px;font-weight:900;color:#1e293b;margin:0 0 2px;">QUOTE #Q-2024-018</p>
                <p style="font-size:11px;color:#64748b;margin:0;">Valid until Jan 31, 2025</p>
              </div>
              <span style="background:#fef3c7;color:#d97706;font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;">PENDING</span>
            </div>
            <div style="background:#f8fafc;border-radius:8px;padding:10px;margin-bottom:10px;">
              <div style="display:flex;justify-content:space-between;font-size:11px;color:#64748b;margin-bottom:4px;">
                <span>Web Redesign Package</span><span style="font-weight:700;color:#1e293b;">$3,500</span>
              </div>
              <div style="display:flex;justify-content:space-between;font-size:11px;color:#64748b;">
                <span>SEO Optimization</span><span style="font-weight:700;color:#1e293b;">$800</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;">
              <div style="flex:1;background:linear-gradient(135deg,#10b981,#059669);color:#fff;border-radius:7px;padding:8px;text-align:center;font-size:11px;font-weight:800;">✓ Convert to Invoice</div>
              <div style="background:#fee2e2;color:#dc2626;border-radius:7px;padding:8px 10px;text-align:center;font-size:11px;font-weight:800;">✗</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- All features list -->
<section class="py-16 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-3xl font-black text-gray-900 text-center mb-10">Complete feature list</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% [
        'Free invoice generator (no credit card)',
        'PDF download — instant, A4 format',
        'Word (.docx) export',
        '9 professional invoice templates',
        'Free quote generator (8 free)',
        'Client management (unlimited clients)',
        'Company logo on invoices',
        'Client logo on invoices',
        'Custom tax rate per line item',
        'Multi-line items (unlimited)',
        'Invoice notes / payment terms',
        'Bank details in invoice footer',
        'Invoice number auto-increment',
        'Issue date + due date',
        'Payment status tracking',
        'Quote → Invoice conversion',
        'Dashboard with stats',
        'Secure cloud storage',
        'Account with email verification',
        'Mobile-friendly interface',
        'USD / EUR / any currency',
        'Email support',
      ].forEach(f=>{ %>
      <div style="background:#fff;border:1px solid #e8edf3;border-radius:12px;padding:12px 16px;display:flex;align-items:center;gap:10px;">
        <span style="color:#10b981;font-weight:800;flex-shrink:0;">✓</span>
        <span style="font-size:13px;color:#374151;font-weight:500;"><%= f %></span>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
  <div class="max-w-2xl mx-auto px-4 text-center">
    <h2 class="text-4xl font-black text-white mb-4">Ready to create your first free invoice?</h2>
    <p class="text-indigo-200 mb-8">8 free invoices + 8 free quotes. No credit card. Start in 30 seconds.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/register" style="display:inline-block;background:#fff;color:#4F46E5;font-weight:900;font-size:16px;padding:16px 36px;border-radius:14px;text-decoration:none;">
        Create Free Account →
      </a>
      <a href="/en/pricing" style="display:inline-block;background:rgba(255,255,255,.15);color:#fff;font-weight:700;font-size:16px;padding:16px 36px;border-radius:14px;text-decoration:none;border:2px solid rgba(255,255,255,.3);">
        View Pricing
      </a>
    </div>
  </div>
</section>

<%- include('./_footer') %>
