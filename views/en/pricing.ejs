      <span class="text-green-600 font-bold text-sm">✓ Unlimited invoices + quotes — no credit card required</span>
    </div>
  </div>
</section>

<!-- Plan -->
<section class="py-16">
  <div class="max-w-lg mx-auto px-4">
    <div class="plan-card">
      <div class="mb-6 text-center">
        <h2 class="text-xl font-black text-gray-900 mb-1">Free</h2>
        <p class="text-sm text-gray-500">For everyone, right now</p>
      </div>
      <div class="mb-6 text-center">
        <span class="text-5xl font-black text-gray-900">$0</span>
        <span class="text-gray-400 text-sm"> / forever</span>
      </div>
      <ul class="space-y-3 mb-8 flex-1 text-sm">
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Unlimited invoices</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Unlimited quotes</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">PDF download</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Word (.docx) export</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Invoice templates</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Client management</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Custom tax rates</span></li>
        <li class="flex gap-2"><span class="check">✓</span> <span class="text-gray-700">Company logo</span></li>
      </ul>
