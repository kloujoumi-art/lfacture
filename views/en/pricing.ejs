</section>

<!-- FAQ -->
<section class="py-16 bg-white">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-3xl font-black text-gray-900 text-center mb-10">Frequently asked questions</h2>
    <div class="space-y-4">
      <% [
        { q:'Is LFacture really free?', a:'Yes. LFacture is entirely free right now — no credit card required, no hidden fees.' },
        { q:'Is there a limit on invoices or quotes?', a:'No. You can create as many invoices and quotes as you need.' },
        { q:'Is my data saved securely?', a:'Yes. All your invoices, quotes, and client data are saved securely.' },
      ].forEach(item=>{ %>
      <details class="border border-gray-200 rounded-2xl">
        <summary class="flex items-center justify-between p-5 font-bold text-gray-900 cursor-pointer" style="list-style:none;">
          <%= item.q %>
          <span class="text-indigo-500 text-xl ml-4 flex-shrink-0">+</span>
        </summary>
        <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed"><%= item.a %></div>
      </details>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
