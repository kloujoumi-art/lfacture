<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "LFacture — Online Invoice Generator",
  "description": "Free professional invoice generator for freelancers and small businesses. Create unlimited PDF invoices online.",
  "url": "https://lfacture.com/en/pricing",
  "offers": { "@type": "Offer", "name": "Free Plan", "price": "0", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
}
