<!-- Free Hero -->
<section class="pt-20 pb-6 sm:pb-8 bg-white text-center">
  <div class="max-w-3xl mx-auto px-4">
    <div class="inline-flex items-center gap-2 bg-green-50 border border-green-100 rounded-full px-4 py-1.5 mb-6 sm:mb-8">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      <span class="text-xs sm:text-sm font-medium text-green-700">100% gratuit, sans limite</span>
    </div>
    <h1 class="text-3xl sm:text-5xl font-black text-gray-900 mb-3 sm:mb-4">LFacture est gratuit</h1>
    <p class="text-base sm:text-xl text-gray-500">Créez vos factures et devis en illimité, sans carte bancaire.</p>
  </div>
</section>

<!-- Free Banner -->
<section class="pb-16 sm:pb-24 bg-white">
  <div class="max-w-3xl mx-auto px-4">
    <div class="rounded-2xl border-2 border-primary-200 p-5 sm:p-8 text-center" style="background:linear-gradient(135deg,#eef2ff,#f5f3ff)">
      <h2 class="text-xl sm:text-2xl font-black text-gray-900 mb-2">🎁 Factures et devis illimités, gratuitement</h2>
      <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-2 sm:gap-x-8 my-4 sm:my-6">
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Aucune carte bancaire requise</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Factures et devis illimités</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Activation immédiate</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Sans engagement</span>
      </div>
      <a href="/register" class="btn-primary text-white font-bold text-base sm:text-lg px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl inline-block">
        Créer mon compte gratuit →
      </a>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-8 sm:mt-10 max-w-2xl mx-auto">
      <% [
        'Factures illimitées',
        'Devis illimités',
        'Clients illimités',
        'Téléchargement PDF',
        'Impression',
        'Logo personnalisé',
        'Plusieurs modèles de factures et devis',
        'Mises à jour incluses',
      ].forEach(f => { %>
      <li class="flex items-center gap-3 text-sm text-gray-700">
        <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        <%= f %>
      </li>
      <% }); %>
    </ul>

    <!-- FAQ -->
    <div class="mt-14 sm:mt-20 max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-black text-gray-900 text-center mb-6 sm:mb-10">Questions fréquentes</h2>
      <div class="space-y-3 sm:space-y-4">
        <% const faqs = [
          { q: 'Est-ce vraiment gratuit ?', a: 'Oui, entièrement. Vous créez votre compte sans carte bancaire et vous pouvez créer autant de factures et devis que vous le souhaitez.' },
          { q: 'Y a-t-il une limite de temps ou de documents ?', a: 'Non, aucune limite. Le service est gratuit pour l\'instant, sans restriction sur le nombre de factures ou de devis.' },
          { q: 'Mes données sont-elles sauvegardées ?', a: 'Oui, toutes vos données (factures, clients, devis) sont sauvegardées de façon sécurisée.' },
        ]; %>
        <% faqs.forEach(faq => { %>
        <div class="bg-gray-50 rounded-xl border border-gray-100 p-4 sm:p-6">
          <h3 class="font-bold text-gray-900 mb-2 text-sm sm:text-base"><%= faq.q %></h3>
          <p class="text-gray-600 text-sm leading-relaxed"><%= faq.a %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="pb-16 sm:pb-24">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <p class="text-gray-500 mb-4">Prêt à démarrer ?</p>
    <a href="/register" class="btn-primary text-white font-bold text-base sm:text-xl px-6 sm:px-10 py-4 sm:py-5 rounded-2xl inline-block">
      Commencer gratuitement →
    </a>
    <p class="text-xs sm:text-sm text-gray-400 mt-4">Aucune carte bancaire • Activation immédiate • Résiliation libre</p>
  </div>
</section>

<style>
  .btn-primary { background: linear-gradient(135deg, #4F46E5, #7C3AED); transition: all 0.2s; box-shadow: 0 4px 15px rgba(79,70,229,0.3); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 25px rgba(79,70,229,0.4); }
</style>
