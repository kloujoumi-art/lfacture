<!-- Pricing Hero -->
<section class="pt-20 pb-8 bg-white text-center">
  <div class="max-w-3xl mx-auto px-4">
    <div class="inline-flex items-center gap-2 bg-green-50 border border-green-100 rounded-full px-4 py-1.5 mb-8">
      <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      <span class="text-sm font-medium text-green-700">Plan gratuit — 8 factures + 8 devis offerts</span>
    </div>
    <h1 class="text-5xl font-black text-gray-900 mb-4">Tarifs simples et transparents</h1>
    <p class="text-xl text-gray-500">Choisissez la formule qui vous convient. Changez ou résiliez à tout moment.</p>
  </div>
</section>

<!-- Free Trial Banner -->
<section class="pb-12 bg-white">
  <div class="max-w-3xl mx-auto px-4">
    <div class="rounded-2xl border-2 border-primary-200 p-8 text-center" style="background:linear-gradient(135deg,#eef2ff,#f5f3ff)">
      <h2 class="text-2xl font-black text-gray-900 mb-2">🎁 Commencez avec 8 factures + 8 devis gratuits</h2>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 my-6">
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Aucune carte bancaire requise</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>8 factures + 8 devis offerts</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Activation immédiate</span>
        <span class="flex items-center gap-2 text-sm text-gray-700 font-medium"><svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Sans engagement</span>
      </div>
      <a href="/register" class="btn-primary text-white font-bold text-lg px-8 py-4 rounded-xl inline-block">
        Commencer gratuitement →
      </a>
    </div>
  </div>
</section>

<!-- Pricing Cards -->
<section class="pb-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">

      <!-- Plan Mensuel -->
      <div class="bg-white rounded-2xl border-2 border-gray-200 p-8 flex flex-col hover:border-primary-300 hover:shadow-lg transition-all duration-300">
        <div class="mb-8">
          <h3 class="text-lg font-bold text-gray-900 mb-1">Mensuel</h3>
          <p class="text-sm text-gray-500 mb-6">Idéal pour commencer</p>
          <div class="flex items-end gap-1 mb-2">
            <span class="text-5xl font-black text-gray-900">5€</span>
            <span class="text-gray-500 mb-2">/mois</span>
          </div>
          <p class="text-sm text-gray-400">Soit 60€/an</p>
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          <% const monthlyFeatures = [
            'Factures illimitées',
            'Devis illimités',
            'Clients illimités',
            'Produits illimités',
            'Téléchargement PDF',
            'Impression',
            'Logo personnalisé',
            'Plusieurs modèles de factures',
            'Plusieurs modèles de devis',
            'Support par email',
            'Mises à jour incluses',
          ]; %>
          <% monthlyFeatures.forEach(f => { %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%= f %>
          </li>
          <% }); %>
        </ul>

        <a href="/register" class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3 px-6 rounded-xl transition">
          Commencer
        </a>
      </div>

      <!-- Plan Annuel — LE PLUS POPULAIRE -->
      <div class="relative rounded-2xl flex flex-col" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 20px 60px rgba(79,70,229,0.35);transform:scale(1.04)">
        <!-- Popular badge -->
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <div class="bg-amber-400 text-amber-900 font-black text-xs px-4 py-1.5 rounded-full shadow-lg flex items-center gap-1.5 whitespace-nowrap">
            ⭐ LE PLUS POPULAIRE
          </div>
        </div>

        <div class="p-8 flex flex-col flex-1 pt-10">
          <div class="mb-8">
            <h3 class="text-lg font-bold text-white mb-1">Annuel</h3>
            <p class="text-primary-200 text-sm mb-6">La meilleure offre</p>
            <div class="flex items-end gap-1 mb-2">
              <span class="text-5xl font-black text-white">50€</span>
              <span class="text-primary-200 mb-2">/an</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="bg-amber-400 text-amber-900 text-xs font-black px-2.5 py-1 rounded-full">Économisez plus de 35 %</span>
            </div>
            <p class="text-primary-300 text-xs mt-2">Soit 4,17€/mois — au lieu de 60€</p>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            <% const annualFeatures = [
              'Toutes les fonctionnalités',
              'Mises à jour gratuites',
              'Support prioritaire',
              'Accès aux nouvelles fonctionnalités',
              'Sauvegardes automatiques',
              'Personnalisation complète',
              'Factures illimitées',
              'Devis illimités',
              'Clients illimités',
              'Logo personnalisé',
              'Plusieurs modèles',
            ]; %>
            <% annualFeatures.forEach(f => { %>
            <li class="flex items-center gap-3 text-sm text-white">
              <svg class="w-5 h-5 text-primary-200 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <%= f %>
            </li>
            <% }); %>
          </ul>

          <a href="/register" class="block w-full text-center bg-white text-primary-700 font-black py-4 px-6 rounded-xl transition hover:bg-gray-50 shadow-lg text-lg">
            Commencer maintenant →
          </a>
        </div>
      </div>

      <!-- Plan 6 Mois -->
      <div class="bg-white rounded-2xl border-2 border-gray-200 p-8 flex flex-col hover:border-primary-300 hover:shadow-lg transition-all duration-300">
        <div class="mb-8">
          <h3 class="text-lg font-bold text-gray-900 mb-1">Semestriel</h3>
          <p class="text-sm text-gray-500 mb-6">Pour tester sur la durée</p>
          <div class="flex items-end gap-1 mb-2">
            <span class="text-5xl font-black text-gray-900">30€</span>
            <span class="text-gray-500 mb-2">/6 mois</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">Économisez 10 %</span>
          </div>
          <p class="text-sm text-gray-400 mt-2">Soit 5€/mois — au lieu de 30€</p>
        </div>

        <ul class="space-y-3 mb-8 flex-1">
          <% monthlyFeatures.forEach(f => { %>
          <li class="flex items-center gap-3 text-sm text-gray-700">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <%= f %>
          </li>
          <% }); %>
        </ul>

        <a href="/register" class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3 px-6 rounded-xl transition">
          Commencer
        </a>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mt-20 max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-gray-900 text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-4">
        <% const faqs = [
          { q: 'Puis-je annuler à tout moment ?', a: 'Oui, vous pouvez résilier votre abonnement à tout moment depuis votre espace compte. Sans frais ni engagement.' },
          { q: 'Le plan gratuit nécessite-t-il une carte bancaire ?', a: 'Non. Vous créez votre compte et commencez immédiatement avec 8 factures + 8 devis offerts, sans aucune information de paiement. Quand vous atteignez la limite, vous choisissez librement de passer en Premium.' },
          { q: 'Mes données sont-elles sauvegardées ?', a: 'Oui, toutes vos données (factures, clients, devis) sont sauvegardées de façon sécurisée. Avec l\'offre annuelle, vous bénéficiez des sauvegardes automatiques quotidiennes.' },
          { q: 'Puis-je changer d\'offre ?', a: 'Absolument. Vous pouvez passer à une offre supérieure ou inférieure à tout moment depuis vos paramètres.' },
        ]; %>
        <% faqs.forEach(faq => { %>
        <div class="bg-gray-50 rounded-xl border border-gray-100 p-6">
          <h3 class="font-bold text-gray-900 mb-2"><%= faq.q %></h3>
          <p class="text-gray-600 text-sm leading-relaxed"><%= faq.a %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="pb-24">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <p class="text-gray-500 mb-4">Prêt à démarrer ?</p>
    <a href="/register" class="btn-primary text-white font-bold text-xl px-10 py-5 rounded-2xl inline-block">
      Commencer gratuitement — 8 factures offertes
    </a>
    <p class="text-sm text-gray-400 mt-4">Aucune carte bancaire • Activation immédiate • Résiliation libre</p>
  </div>
</section>

<style>
  .btn-primary { background: linear-gradient(135deg, #4F46E5, #7C3AED); transition: all 0.2s; box-shadow: 0 4px 15px rgba(79,70,229,0.3); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 25px rgba(79,70,229,0.4); }
</style>
