<!-- Hero Section -->
<section class="relative overflow-hidden bg-white pt-20 pb-32">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(79,70,229,0.08) 0%, transparent 70%)"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-primary-50 border border-primary-100 rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-sm font-medium text-primary-700">Essai gratuit 7 jours — Aucune carte requise</span>
    </div>

    <!-- Heading -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-gray-900 tracking-tight leading-tight mb-6">
      Créez vos factures<br/>
      <span style="background:linear-gradient(135deg,#4F46E5,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">en quelques secondes</span>
    </h1>

    <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
      LFacture est l'outil de facturation le plus simple pour les indépendants et les PME françaises. Créez des factures et devis professionnels en PDF en quelques clics.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/register" class="btn-primary text-white font-bold text-lg px-8 py-4 rounded-xl w-full sm:w-auto">
        Commencer mon essai gratuit →
      </a>
      <a href="/pricing" class="bg-white border border-gray-200 text-gray-700 font-semibold text-lg px-8 py-4 rounded-xl hover:bg-gray-50 transition w-full sm:w-auto">
        Voir les tarifs
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500">
      <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Aucune carte bancaire</span>
      <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>7 jours gratuits</span>
      <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Résiliation libre</span>
      <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Support français</span>
    </div>
  </div>

  <!-- Dashboard Preview -->
  <div class="max-w-6xl mx-auto px-4 mt-20">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-2xl overflow-hidden" style="box-shadow:0 40px 80px rgba(0,0,0,0.12)">
      <!-- Browser bar -->
      <div class="bg-gray-100 border-b border-gray-200 px-4 py-3 flex items-center gap-3">
        <div class="flex gap-2"><div class="w-3 h-3 rounded-full bg-red-400"></div><div class="w-3 h-3 rounded-full bg-yellow-400"></div><div class="w-3 h-3 rounded-full bg-green-400"></div></div>
        <div class="flex-1 bg-white rounded-md px-3 py-1 text-xs text-gray-500 max-w-sm mx-auto text-center">lfacture.com/dashboard</div>
      </div>
      <!-- Mock dashboard -->
      <div class="flex h-80">
        <div class="w-48 bg-gray-50 border-r border-gray-200 p-4 flex-shrink-0">
          <div class="flex items-center gap-2 mb-6"><div class="w-6 h-6 rounded bg-primary-600"></div><span class="text-sm font-bold text-gray-800">LFacture</span></div>
          <div class="space-y-1">
            <div class="bg-primary-600 text-white text-xs font-medium px-3 py-2 rounded-lg">Tableau de bord</div>
            <div class="text-xs text-gray-500 px-3 py-2">Factures</div>
            <div class="text-xs text-gray-500 px-3 py-2">Devis</div>
            <div class="text-xs text-gray-500 px-3 py-2">Clients</div>
          </div>
        </div>
        <div class="flex-1 p-6">
          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm"><p class="text-2xl font-bold text-gray-900">12</p><p class="text-xs text-gray-500 mt-1">Factures</p></div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm"><p class="text-2xl font-bold text-gray-900">3 480 €</p><p class="text-xs text-gray-500 mt-1">Chiffre d'affaires</p></div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm"><p class="text-2xl font-bold text-gray-900">8</p><p class="text-xs text-gray-500 mt-1">Clients</p></div>
          </div>
          <div class="bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
            <div class="flex items-center justify-between mb-3"><p class="text-sm font-semibold text-gray-700">Dernières factures</p><button class="text-xs text-primary-600 font-medium">+ Nouvelle</button></div>
            <div class="space-y-2">
              <div class="flex items-center justify-between py-2 border-b border-gray-50"><span class="text-xs text-gray-600">FAC-2024-0012 — Client Martin</span><span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">Payée</span></div>
              <div class="flex items-center justify-between py-2 border-b border-gray-50"><span class="text-xs text-gray-600">FAC-2024-0011 — Société Dupont</span><span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-medium">Envoyée</span></div>
              <div class="flex items-center justify-between py-2"><span class="text-xs text-gray-600">FAC-2024-0010 — Auto SARL</span><span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full font-medium">Brouillon</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-black text-gray-900 mb-4">Tout ce dont vous avez besoin</h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">Une solution complète pour gérer votre facturation, sans complexité.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% const features = [
        { icon: '📄', title: 'Factures & Devis illimités', desc: 'Créez autant de factures et de devis que vous voulez, sans restriction. Numérotation automatique incluse.' },
        { icon: '⚡', title: 'PDF professionnel en 1 clic', desc: 'Téléchargez vos documents en PDF haute qualité avec votre logo et vos informations en quelques secondes.' },
        { icon: '👥', title: 'Gestion des clients', desc: 'Carnet d\'adresses intégré. Retrouvez l\'historique de chaque client en un instant.' },
        { icon: '🎨', title: 'Modèles personnalisables', desc: 'Plusieurs modèles de factures et devis. Ajoutez votre logo pour une image professionnelle.' },
        { icon: '📊', title: 'Tableau de bord', desc: 'Visualisez votre chiffre d\'affaires, vos factures en attente et vos performances en temps réel.' },
        { icon: '🔒', title: 'Données sécurisées', desc: 'Vos données sont sauvegardées et sécurisées. Accédez à vos documents depuis n\'importe quel appareil.' },
      ]; %>
      <% features.forEach(f => { %>
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-200">
        <div class="text-4xl mb-4"><%= f.icon %></div>
        <h3 class="text-lg font-bold text-gray-900 mb-2"><%= f.title %></h3>
        <p class="text-gray-500 text-sm leading-relaxed"><%= f.desc %></p>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Pricing Teaser -->
<section class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <h2 class="text-4xl font-black text-gray-900 mb-4">Des tarifs simples et transparents</h2>
    <p class="text-lg text-gray-500 mb-8">À partir de <strong class="text-gray-900">5€/mois</strong>. Commencez avec 7 jours d'essai gratuit.</p>
    <a href="/pricing" class="btn-primary text-white font-bold text-lg px-8 py-4 rounded-xl inline-block">Voir les tarifs →</a>
  </div>
</section>

<!-- Testimonials -->
<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl font-black text-gray-900 text-center mb-16">Ils nous font confiance</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% const testimonials = [
        { name: 'Marie L.', role: 'Graphiste freelance', quote: 'LFacture m\'a sauvé des heures chaque mois. Mes factures sont prêtes en moins d\'une minute !', stars: 5 },
        { name: 'Thomas R.', role: 'Consultant IT', quote: 'Interface simple et factures professionnelles. Mes clients sont impressionnés par le rendu.', stars: 5 },
        { name: 'Sophie M.', role: 'Coach certifiée', quote: 'Enfin une solution française facile à utiliser. Le support est réactif et très sympa.', stars: 5 },
      ]; %>
      <% testimonials.forEach(t => { %>
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
        <div class="flex mb-4">
          <% for(let i = 0; i < t.stars; i++) { %><span class="text-yellow-400 text-lg">★</span><% } %>
        </div>
        <p class="text-gray-700 text-sm leading-relaxed mb-6 italic">"<%= t.quote %>"</p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)"><%= t.name.charAt(0) %></div>
          <div><p class="text-sm font-semibold text-gray-900"><%= t.name %></p><p class="text-xs text-gray-500"><%= t.role %></p></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-24">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="rounded-3xl p-16" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
      <h2 class="text-4xl font-black text-white mb-4">Prêt à simplifier votre facturation ?</h2>
      <p class="text-primary-200 text-lg mb-8">Rejoignez des centaines d'indépendants et PME qui utilisent LFacture chaque jour.</p>
      <a href="/register" class="bg-white text-primary-700 font-bold text-lg px-8 py-4 rounded-xl hover:bg-gray-50 transition inline-block">
        Commencer gratuitement — 7 jours offerts
      </a>
    </div>
  </div>
</section>
