<!-- ═══════════════════════════════════════════════════
     HOW IT WORKS — 3 étapes
     ═══════════════════════════════════════════════════ -->
<section class="py-16 sm:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-4xl font-black text-gray-900 mb-3">Démarrez en 3 minutes</h2>
      <p class="text-gray-500 text-base sm:text-lg">Pas de formation, pas d'installation. Juste de la facturation.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 relative">
      <% [
        { n:'1', icon:'🎯', title:'Créez votre compte', desc:'Inscription en 30 secondes. Aucune carte bancaire.' },
        { n:'2', icon:'⚡', title:'Renseignez vos infos', desc:'Ajoutez votre logo, SIRET et coordonnées une seule fois.' },
        { n:'3', icon:'🚀', title:'Envoyez votre facture', desc:'Créez et téléchargez votre premier PDF professionnel.' },
      ].forEach((step, i) => { %>
      <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 text-center feature-card relative">
        <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-black text-lg mx-auto mb-4" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
          <%= step.n %>
        </div>
        <div class="text-3xl mb-3"><%= step.icon %></div>
        <h3 class="text-base font-bold text-gray-900 mb-2"><%= step.title %></h3>
        <p class="text-gray-500 text-sm leading-relaxed"><%= step.desc %></p>
      </div>
      <% }); %>
    </div>
    <div class="text-center mt-10">
      <a href="/register" class="inline-flex items-center gap-2 text-white font-bold px-8 py-4 rounded-xl text-base" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 6px 20px rgba(79,70,229,.3);">
        Commencer gratuitement
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>
</section>

