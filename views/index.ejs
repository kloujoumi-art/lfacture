          <h3 class="font-black text-red-800 text-lg">Avant LFacture</h3>
        </div>
        <ul class="space-y-3">
          <% [
            'Factures créées sur Word/Excel, mises en forme à la main',
            'Numérotation manuelle, oubli des mentions obligatoires',
            'PDF approximatif, impression bizarre, logo déformé',
            'Calculs TVA à refaire à chaque fois',
            'Impossible de retrouver une facture de 6 mois',
            'Client se plaint : "ta facture ne respecte pas la loi"',
          ].forEach(t => { %>
          <li class="flex items-start gap-2.5 text-sm text-red-800">
            <span class="text-red-400 mt-0.5 flex-shrink-0">✗</span><%= t %>
          </li>
          <% }); %>
