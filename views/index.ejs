<!-- JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "LFacture",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  "description": "Logiciel de facturation gratuit en ligne pour créer des factures et devis professionnels.",
  "url": "https://lfacture.com",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127" }
}
</script>

<style>
  .pack-img {
    width: clamp(180px, 30vw, 380px);
    filter: drop-shadow(0 20px 40px rgba(79,70,229,.22)) drop-shadow(0 6px 16px rgba(0,0,0,.1));
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @media(max-width:640px){ .pack-img{width:clamp(160px,65vw,280px);animation:none;} }

  .pack-glow {
    position:absolute; inset:-30px;
    background:radial-gradient(ellipse 80% 80% at 50% 50%, rgba(79,70,229,.12) 0%, transparent 70%);
    border-radius:50%; animation:pulse-g 3s ease-in-out infinite;
  }
  @keyframes pulse-g { 0%,100%{transform:scale(1);opacity:.6} 50%{transform:scale(1.06);opacity:1} }

  .vs-col { border-radius:16px; padding:24px; }
  .faq-item summary { cursor:pointer; list-style:none; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item[open] summary .faq-icon { transform:rotate(45deg); }
  .faq-icon { transition:transform .2s; }
  .feature-card:hover { transform:translateY(-3px); box-shadow:0 10px 32px rgba(0,0,0,.09); }
  .feature-card { transition:transform .2s, box-shadow .2s; }
  section { overflow-x:hidden; }
</style>

<!-- ══════════════════════════════════════════════
