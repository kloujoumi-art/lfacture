                  { label:'Développement web', price:'1 200,00 €', w:'60%' },
                  { label:'Design UI/UX', price:'800,00 €', w:'45%' },
                  { label:'Maintenance mensuelle', price:'350,00 €', w:'75%' },
                ].forEach(item => { %>
                <div class="mock-row">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:<%= item.w %>;max-width:130px;" class="mock-line" style="height:7px;margin:0;"></div>
                  </div>
                  <span style="font-size:11px;font-weight:700;color:#1e293b;white-space:nowrap;"><%= item.price %></span>
                </div>
                <% }); %>
              </div>

              <!-- TVA + Total -->
              <div style="display:flex;justify-content:flex-end;margin-bottom:8px;">
                <div style="width:200px;">
                  <div style="display:flex;justify-content:space-between;padding:4px 0;font-size:11px;color:#64748b;">
                    <span>Total HT</span><span style="font-weight:600;color:#1e293b;">2 350,00 €</span>
                  </div>
                  <div style="display:flex;justify-content:space-between;padding:4px 0;font-size:11px;color:#64748b;">
                    <span>TVA 20%</span><span style="font-weight:600;color:#1e293b;">470,00 €</span>
                  </div>
                </div>
              </div>
              <div class="mock-total">
                <span style="color:rgba(255,255,255,.8);font-size:12px;font-weight:600;">TOTAL TTC</span>
                <span style="color:#fff;font-size:16px;font-weight:900;">2 820,00 €</span>
              </div>
            </div>

            <!-- Bouton PDF -->
            <div style="margin-top:12px;display:flex;gap:8px;">
              <div style="flex:1;background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:8px;padding:10px;display:flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;">
                <span style="color:#fff;font-size:12px;font-weight:700;">⬇ Télécharger PDF</span>
              </div>
              <div style="background:#f1f5f9;border-radius:8px;padding:10px 14px;display:flex;align-items:center;cursor:pointer;">
                <span style="font-size:14px;">🖨</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

