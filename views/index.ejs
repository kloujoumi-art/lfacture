  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "description": "Plan gratuit : 8 factures + 8 devis"
  },
  "description": "Logiciel de facturation gratuit en ligne pour créer des factures et devis professionnels en quelques secondes.",
  "url": "https://lfacture.com",
