<!-- JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "LFacture",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  "description": "Logiciel de facturation gratuit en ligne pour créer des factures et devis professionnels.",
  "url": "https://lfacture.com",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "127" }
}
</script>

<style>
/* ── Animations ── */
@keyframes floatY   { 0%,100%{transform:translateY(0)}   50%{transform:translateY(-8px)} }
@keyframes floatY2  { 0%,100%{transform:translateY(-4px)} 50%{transform:translateY(4px)} }
@keyframes pulse-glow { 0%,100%{box-shadow:0 0 0 0 rgba(99,102,241,.15)} 50%{box-shadow:0 0 0 18px rgba(99,102,241,0)} }
@keyframes fadeSlideUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
@keyframes shimmer  { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
@keyframes check-pop{ 0%{transform:scale(0)}70%{transform:scale(1.15)}100%{transform:scale(1)} }

.float1 { animation: floatY  4s ease-in-out infinite; }
.float2 { animation: floatY2 5s ease-in-out infinite; }
.float3 { animation: floatY  6s ease-in-out infinite .5s; }

/* ── Hero mockup ── */
.hero-mockup { width:100%; max-width:560px; }
.mock-window { background:#fff; border-radius:14px; box-shadow:0 30px 80px rgba(0,0,0,.18),0 8px 24px rgba(79,70,229,.12); overflow:hidden; }
.mock-topbar { background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:10px 14px; display:flex; align-items:center; gap:6px; }
.mock-dot    { width:10px; height:10px; border-radius:50%; }
.mock-addr   { flex:1; background:#fff; border:1px solid #e2e8f0; border-radius:6px; height:22px; margin:0 10px; }
.mock-body   { padding:18px; }
.mock-invoice{ background:#fff; border:1px solid #e8eaf0; border-radius:10px; padding:16px; }
.mock-line   { height:8px; border-radius:4px; background:#eef2ff; margin-bottom:7px; }
.mock-line.dark { background:#c7d2fe; }
.mock-line.sm   { width:55%; }
.mock-line.xs   { width:35%; }
.mock-row    { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid #f1f5f9; }
.mock-total  { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:linear-gradient(135deg,#4F46E5,#7C3AED); border-radius:8px; margin-top:10px; }

/* ── Floating badges ── */
.badge-float { background:#fff; border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,.12); padding:10px 14px; display:flex; align-items:center; gap:8px; white-space:nowrap; font-size:12px; font-weight:700; }

/* ── Feature cards ── */
.feat-card { background:#fff; border:1px solid #e8edf3; border-radius:18px; overflow:hidden; transition:transform .2s,box-shadow .2s; }
.feat-card:hover { transform:translateY(-4px); box-shadow:0 16px 40px rgba(0,0,0,.1); }

/* ── Template cards ── */
.tpl-card { background:#fff; border-radius:16px; box-shadow:0 8px 32px rgba(0,0,0,.1); overflow:hidden; transition:transform .2s,box-shadow .2s; cursor:pointer; }
.tpl-card:hover { transform:translateY(-5px) scale(1.01); box-shadow:0 20px 50px rgba(79,70,229,.18); }

/* ── Testimonial ── */
.testi-card { background:#fff; border:1px solid #e8edf3; border-radius:16px; padding:24px; transition:transform .2s,box-shadow .2s; }
.testi-card:hover { transform:translateY(-3px); box-shadow:0 10px 30px rgba(0,0,0,.08); }

/* ── Steps connector ── */
.step-line { position:absolute; left:27px; top:52px; bottom:-20px; width:2px; background:linear-gradient(180deg,#c7d2fe,transparent); }

/* ── Misc ── */
.faq-item summary { cursor:pointer; list-style:none; }
.faq-item summary::-webkit-details-marker { display:none; }
.faq-item[open] .faq-icon { transform:rotate(45deg); }
.faq-icon { transition:transform .2s; flex-shrink:0; }
.gradient-heading { background:linear-gradient(135deg,#4F46E5,#7C3AED); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.check-green { color:#10b981; font-weight:700; }
.cross-red   { color:#ef4444; font-weight:700; }

@media(max-width:768px){
  .hero-mockup { max-width:100%; }
  .step-line { display:none; }
  .hide-mobile { display:none !important; }
}
</style>

<!-- ══════════════════════════════════════════════════════════
     1. HERO
══════════════════════════════════════════════════════════ -->
<section class="relative bg-white overflow-hidden" style="padding-top:64px;">
  <!-- Background gradients -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 65% 80% at 80% 30%,rgba(99,102,241,.08) 0%,transparent 65%),radial-gradient(ellipse 45% 55% at 10% 85%,rgba(124,58,237,.06) 0%,transparent 60%)"></div>
  <!-- Grid subtle -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(99,102,241,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,.03) 1px,transparent 1px);background-size:40px 40px;"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16 lg:py-20">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- ── Texte gauche ── -->
      <div class="flex-1 min-w-0 text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 rounded-full px-4 py-1.5 mb-5">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
          <span class="text-sm font-semibold text-indigo-700">Plan gratuit — 8 factures + 8 devis offerts</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-black text-gray-900 tracking-tight leading-[1.08] mb-5">
          Le logiciel de<br/>
          <span class="gradient-heading">facturation gratuit</span><br/>
          des pros français
        </h1>

        <p class="text-lg text-gray-500 leading-relaxed mb-7 max-w-lg mx-auto lg:mx-0">
          Créez vos <strong class="text-gray-700">factures et devis PDF professionnels</strong> en 2 minutes. Sans Excel. Sans Word. Sans erreur de TVA. Conforme à la loi française.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 mb-6">
          <a href="/register" class="w-full sm:w-auto text-center text-white font-black text-base px-7 py-4 rounded-xl transition" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 8px 28px rgba(79,70,229,.38);">
            Créer mon compte gratuit →
          </a>
          <a href="#templates" class="w-full sm:w-auto text-center bg-white border-2 border-gray-200 text-gray-700 font-bold text-base px-7 py-4 rounded-xl hover:border-indigo-200 hover:text-indigo-700 transition">
            Voir les modèles
          </a>
        </div>

        <!-- Trust items -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 text-sm text-gray-500 mb-5">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Sans carte bancaire
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Conforme loi française
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            100% en ligne
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Résiliation libre
          </span>
        </div>

        <!-- Stars + avis -->
        <div class="flex items-center gap-3 justify-center lg:justify-start">
          <div class="flex"><%for(let i=0;i<5;i++){%><span style="color:#F59E0B;font-size:18px;">★</span><%}%></div>
          <span class="text-sm font-semibold text-gray-700">4,9/5</span>
          <span class="text-sm text-gray-400">·</span>
          <div class="flex -space-x-2">
            <% ['#6366f1','#8b5cf6','#ec4899','#f59e0b','#10b981'].forEach((c,i)=>{ %>
            <div class="w-7 h-7 rounded-full border-2 border-white flex items-center justify-center text-white text-xs font-bold" style="background:<%= c %>"><%= ['M','T','S','A','L'][i] %></div>
            <% }); %>
          </div>
          <span class="text-sm text-gray-500">127 utilisateurs satisfaits</span>
        </div>
      </div>

      <!-- ── Mockup droite ── -->
      <div class="flex-shrink-0 w-full lg:w-auto relative" style="max-width:520px;margin:0 auto;">
        <!-- Badge flottant haut-gauche -->
        <div class="badge-float float2 absolute -left-4 top-6 z-10 hide-mobile" style="color:#10b981;">
          <span style="font-size:18px;">✓</span>
          <span style="color:#1f2937;">PDF généré !</span>
        </div>
        <!-- Badge flottant bas-droite -->
        <div class="badge-float float3 absolute -right-2 bottom-12 z-10 hide-mobile" style="color:#4F46E5;">
          <span style="font-size:18px;">⚡</span>
          <span style="color:#1f2937;">2 min chrono</span>
        </div>
        <!-- Badge TVA -->
        <div class="badge-float float1 absolute -right-6 top-20 z-10 hide-mobile" style="color:#f59e0b;">
          <span style="font-size:16px;">🧮</span>
          <span style="color:#1f2937;">TVA auto</span>
        </div>

        <!-- Fenêtre navigateur mockup -->
        <div class="mock-window float1" style="max-width:460px;margin:0 auto;">
          <div class="mock-topbar">
            <div class="mock-dot" style="background:#ff5f57;"></div>
            <div class="mock-dot" style="background:#febc2e;"></div>
            <div class="mock-dot" style="background:#28c840;"></div>
            <div class="mock-addr"></div>
            <div style="font-size:11px;color:#94a3b8;font-weight:600;">lfacture.com</div>
          </div>
          <div class="mock-body">
            <!-- Header invoice -->
            <div class="mock-invoice">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
                <div>
                  <div style="width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,#4F46E5,#7C3AED);display:flex;align-items:center;justify-content:center;margin-bottom:8px;">
                    <span style="color:#fff;font-weight:900;font-size:16px;">L</span>
                  </div>
                  <div class="mock-line dark" style="width:90px;margin-bottom:4px;"></div>
                  <div class="mock-line" style="width:65px;height:6px;"></div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:15px;font-weight:900;color:#1e293b;margin-bottom:4px;">FACTURE</div>
                  <div style="font-size:11px;color:#4F46E5;font-weight:700;background:#eef2ff;padding:2px 8px;border-radius:6px;">#2024-042</div>
                  <div style="font-size:10px;color:#94a3b8;margin-top:4px;">28 juin 2025</div>
                </div>
              </div>

              <!-- Client info -->
              <div style="background:#f8fafc;border-radius:8px;padding:10px 12px;margin-bottom:12px;display:flex;justify-content:space-between;">
                <div>
                  <div style="font-size:9px;color:#94a3b8;font-weight:700;text-transform:uppercase;margin-bottom:4px;">Facturé à</div>
                  <div class="mock-line dark sm" style="margin-bottom:3px;height:7px;"></div>
                  <div class="mock-line xs" style="height:6px;"></div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:9px;color:#94a3b8;font-weight:700;text-transform:uppercase;margin-bottom:4px;">Échéance</div>
                  <div style="font-size:11px;font-weight:700;color:#ef4444;">28 juil. 2025</div>
                </div>
              </div>

              <!-- Items -->
              <div style="margin-bottom:10px;">
                <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f1f5f9;font-size:9px;font-weight:700;color:#64748b;text-transform:uppercase;">
