<section class="py-12 sm:py-16 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8">
      <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-2">Questions fréquentes</h2>
