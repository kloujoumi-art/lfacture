            Voir les tarifs
          </a>
        </div>

        <!-- Trust micro -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-4 gap-y-2 text-sm text-gray-500">
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Sans carte bancaire</span>
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>8 factures + 8 devis gratuits</span>
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Résiliation libre</span>
        </div>

        <!-- Stars -->
        <div class="flex items-center gap-2 mt-5 justify-center lg:justify-start">
          <div class="flex"><%for(let i=0;i<5;i++){%><span style="color:#F59E0B;font-size:18px;">★</span><%}%></div>
          <span class="text-sm text-gray-500 font-medium">4,9/5 · <strong class="text-gray-700">127 avis</strong></span>
        </div>
      </div>

