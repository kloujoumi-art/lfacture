            <span style="color:#a5f3fc;font-weight:700;">✓</span><%= f %>
          </li>
          <% }); %>
        </ul>
        <a href="/pricing" style="display:block;text-align:center;background:#fff;color:#4F46E5;font-weight:800;font-size:14px;padding:12px;border-radius:10px;text-decoration:none;" class="hover:bg-gray-50 transition">
          Choisir annuel →
        </a>
      </div>
    </div>
    <p class="text-center text-xs text-gray-400 mt-5">Tous les plans incluent : PDF, Logo, 3 modèles, TVA automatique, conformité légale.</p>
  </div>
</section>

