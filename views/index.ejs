            'Toutes vos factures classées, retrouvables en 1 clic',
            'Documents conformes 100% à la législation française',
          ].forEach(t => { %>
          <li class="flex items-start gap-2.5 text-sm text-green-700">
            <span class="check-green mt-0.5 flex-shrink-0" style="font-size:16px;">✓</span><%= t %>
          </li>
          <% }); %>
        </ul>
      </div>
    </div>
    <div class="text-center mt-7">
      <a href="/register" class="inline-flex items-center gap-2 text-white font-bold px-8 py-4 rounded-xl" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 6px 22px rgba(79,70,229,.3);">
        Je veux des factures pro — c'est gratuit →
      </a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     5. FONCTIONNALITÉS — grille riche
══════════════════════════════════════════════════════════ -->
<section class="py-12 sm:py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <span style="background:#eef2ff;color:#4F46E5;font-size:12px;font-weight:700;padding:4px 14px;border-radius:20px;display:inline-block;margin-bottom:10px;border:1px solid #c7d2fe;">Fonctionnalités</span>
      <h2 class="text-2xl sm:text-4xl font-black text-gray-900 mb-2">Tout ce qu'il vous faut, rien de plus</h2>
      <p class="text-gray-500 max-w-lg mx-auto">Simple à prendre en main le premier jour. Puissant pour votre croissance.</p>
