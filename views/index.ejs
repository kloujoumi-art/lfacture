<style>
  /* ── Hero ── */
  .hero-section { background: #fff; position:relative; overflow:hidden; padding-top:64px; }
  .hero-glow {
    position:absolute; inset:0; pointer-events:none;
    background: radial-gradient(ellipse 70% 60% at 70% 30%, rgba(79,70,229,.1) 0%, transparent 70%),
                radial-gradient(ellipse 50% 40% at 20% 80%, rgba(124,58,237,.07) 0%, transparent 60%);
  }
  .pack-img-wrapper {
    position:relative; display:flex; align-items:center; justify-content:center;
  }
  .pack-img-wrapper::before {
    content:'';
    position:absolute; inset:-40px;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(79,70,229,.12) 0%, transparent 70%);
    border-radius:50%;
    animation: pulse-glow 3s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%,100% { transform:scale(1); opacity:.7; }
    50% { transform:scale(1.08); opacity:1; }
  }
  .pack-img {
    position:relative; z-index:1;
    filter: drop-shadow(0 24px 48px rgba(79,70,229,.25)) drop-shadow(0 8px 24px rgba(0,0,0,.12));
    animation: float 4s ease-in-out infinite;
    max-width:100%;
    width: clamp(280px, 42vw, 560px);
  }
  @keyframes float {
    0%,100% { transform:translateY(0); }
    50% { transform:translateY(-12px); }
  }

  /* ── Steps ── */
  .step-line { position:absolute; top:20px; left:calc(50% + 20px); width:calc(100% - 40px); height:2px; background:linear-gradient(90deg,#e0e7ff,#c7d2fe); }

  /* ── Responsive dashboard preview ── */
  @media (max-width:640px) {
    .dash-sidebar { display:none !important; }
    .dash-preview { height:auto !important; }
  }

  /* ── Cards hover ── */
  .feature-card { transition: transform .2s, box-shadow .2s; }
  .feature-card:hover { transform:translateY(-4px); box-shadow:0 12px 40px rgba(0,0,0,.1); }

  /* ── Responsive tweaks ── */
  @media (max-width: 1024px) {
    .pack-img { width: clamp(240px, 55vw, 440px); }
  }
  @media (max-width: 640px) {
    .pack-img { width: clamp(200px, 80vw, 340px); animation:none; }
    .pack-img-wrapper::before { display:none; }
  }
</style>

