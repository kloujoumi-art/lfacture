<div class="min-h-screen flex items-center justify-center py-6 sm:py-12 px-4 bg-gray-50">
  <div class="max-w-md w-full">
    <!-- Logo -->
    <div class="text-center mb-6">
      <a href="/" class="inline-flex items-center gap-2 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
          <span class="text-white font-black">L</span>
        </div>
        <span class="text-2xl font-black text-gray-900">LFacture</span>
      </a>
      <h1 class="text-2xl sm:text-3xl font-black text-gray-900 mb-1">Créer votre compte</h1>
      <p class="text-gray-500 text-sm sm:text-base">Factures et devis illimités, gratuitement — Sans carte bancaire</p>
    </div>

    <!-- Trial badge -->
    <div class="bg-green-50 border border-green-200 rounded-xl p-3 sm:p-4 mb-5 text-center">
      <p class="text-green-800 font-semibold text-xs sm:text-sm">🎁 Factures et devis illimités dès l'inscription — sans carte bancaire</p>
    </div>

    <!-- Error messages -->
    <% if (errors && errors.length > 0) { %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-3 sm:p-4 mb-5">
      <ul class="space-y-1">
        <% errors.forEach(err => { %>
        <li class="text-red-700 text-sm flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
          <%= err %>
        </li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <!-- Form -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5 sm:p-8">
      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nom complet</label>
          <input type="text" name="name" value="<%= old.name || '' %>" required placeholder="Marie Dupont"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition text-sm" style="--tw-ring-color:#4F46E5">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Adresse email</label>
          <input type="email" name="email" value="<%= old.email || '' %>" required placeholder="marie@exemple.fr"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mot de passe</label>
          <input type="password" name="password" required placeholder="Minimum 8 caractères"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirmer le mot de passe</label>
          <input type="password" name="password_confirm" required placeholder="Répétez votre mot de passe"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Pays</label>
          <select name="country" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:border-transparent transition text-sm bg-white">
            <option value="">— Sélectionner votre pays —</option>
            <option value="France" <%= (old.country==='France'||!old.country)?'selected':'' %>>🇫🇷 France</option>
            <option value="Maroc" <%= old.country==='Maroc'?'selected':'' %>>🇲🇦 Maroc</option>
            <option value="Algérie" <%= old.country==='Algérie'?'selected':'' %>>🇩🇿 Algérie</option>
            <option value="Tunisie" <%= old.country==='Tunisie'?'selected':'' %>>🇹🇳 Tunisie</option>
            <option value="Belgique" <%= old.country==='Belgique'?'selected':'' %>>🇧🇪 Belgique</option>
            <option value="Suisse" <%= old.country==='Suisse'?'selected':'' %>>🇨🇭 Suisse</option>
            <option value="Luxembourg" <%= old.country==='Luxembourg'?'selected':'' %>>🇱🇺 Luxembourg</option>
            <option value="Canada" <%= old.country==='Canada'?'selected':'' %>>🇨🇦 Canada</option>
            <option value="Sénégal" <%= old.country==='Sénégal'?'selected':'' %>>🇸🇳 Sénégal</option>
            <option value="Côte d'Ivoire" <%= old.country==="Côte d'Ivoire"?'selected':'' %>>🇨🇮 Côte d'Ivoire</option>
            <option value="Cameroun" <%= old.country==='Cameroun'?'selected':'' %>>🇨🇲 Cameroun</option>
            <option value="Mauritanie" <%= old.country==='Mauritanie'?'selected':'' %>>🇲🇷 Mauritanie</option>
            <option value="United States" <%= old.country==='United States'?'selected':'' %>>🇺🇸 United States</option>
            <option value="United Kingdom" <%= old.country==='United Kingdom'?'selected':'' %>>🇬🇧 United Kingdom</option>
            <option value="Autre" <%= old.country==='Autre'?'selected':'' %>>🌍 Autre</option>
          </select>
        </div>
        <button type="submit" class="w-full py-4 rounded-xl text-white font-bold text-base transition" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 4px 15px rgba(79,70,229,0.3)">
          Créer mon compte gratuitement →
        </button>
        <p class="text-xs text-gray-400 text-center">En vous inscrivant, vous acceptez nos conditions d'utilisation.</p>
      </form>
    </div>

    <p class="text-center text-sm text-gray-500 mt-5">
      Vous avez déjà un compte ? <a href="/login" class="font-semibold hover:underline" style="color:#4F46E5">Se connecter</a>
    </p>
  </div>
</div>

<style>
  input:focus, select:focus { border-color: #4F46E5; box-shadow: 0 0 0 3px rgba(79,70,229,0.12); }
</style>
