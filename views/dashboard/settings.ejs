<div class="max-w-3xl">
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
    <form action="/dashboard/settings" method="POST" enctype="multipart/form-data" class="space-y-8">

      <!-- Profil utilisateur -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Profil</h3>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Pays</label>
          <select name="user_country" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm bg-white">
            <option value="">— Sélectionner —</option>
            <option value="France" <%= user && user.country==='France' ? 'selected' : (!user || !user.country)?'selected':'' %>>🇫🇷 France</option>
            <option value="Maroc" <%= user && user.country==='Maroc' ? 'selected' : '' %>>🇲🇦 Maroc</option>
            <option value="Algérie" <%= user && user.country==='Algérie' ? 'selected' : '' %>>🇩🇿 Algérie</option>
            <option value="Tunisie" <%= user && user.country==='Tunisie' ? 'selected' : '' %>>🇹🇳 Tunisie</option>
            <option value="Belgique" <%= user && user.country==='Belgique' ? 'selected' : '' %>>🇧🇪 Belgique</option>
            <option value="Suisse" <%= user && user.country==='Suisse' ? 'selected' : '' %>>🇨🇭 Suisse</option>
            <option value="Luxembourg" <%= user && user.country==='Luxembourg' ? 'selected' : '' %>>🇱🇺 Luxembourg</option>
            <option value="Canada" <%= user && user.country==='Canada' ? 'selected' : '' %>>🇨🇦 Canada</option>
            <option value="Sénégal" <%= user && user.country==='Sénégal' ? 'selected' : '' %>>🇸🇳 Sénégal</option>
            <option value="Côte d'Ivoire" <%= user && user.country==="Côte d'Ivoire" ? 'selected' : '' %>>🇨🇮 Côte d'Ivoire</option>
            <option value="Cameroun" <%= user && user.country==='Cameroun' ? 'selected' : '' %>>🇨🇲 Cameroun</option>
            <option value="Mauritanie" <%= user && user.country==='Mauritanie' ? 'selected' : '' %>>🇲🇷 Mauritanie</option>
            <option value="United States" <%= user && user.country==='United States' ? 'selected' : '' %>>🇺🇸 United States</option>
            <option value="United Kingdom" <%= user && user.country==='United Kingdom' ? 'selected' : '' %>>🇬🇧 United Kingdom</option>
            <option value="Autre" <%= user && user.country==='Autre' ? 'selected' : '' %>>🌍 Autre</option>
          </select>
        </div>
      </div>

      <!-- Logo -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Logo de l'entreprise</h3>
        <div class="flex items-start gap-6">
          <% if (settings && settings.company_logo) { %>
          <div class="flex-shrink-0">
            <img src="<%= settings.company_logo %>" alt="Logo" class="h-20 w-auto rounded-lg border border-gray-200 p-2 bg-white object-contain" style="max-width:160px;" />
            <label class="flex items-center gap-2 mt-2 cursor-pointer">
              <input type="checkbox" name="remove_logo" value="1" class="rounded">
              <span class="text-xs text-red-500 font-medium">Supprimer le logo</span>
            </label>
          </div>
          <% } %>
          <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
              <%= (settings && settings.company_logo) ? 'Changer le logo' : 'Ajouter un logo' %>
            </label>
            <input type="file" name="company_logo_file" accept="image/*"
              class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
            <p class="text-xs text-gray-400 mt-1.5">Format : JPG, PNG, SVG, WebP — Max 2 Mo. Le logo apparaît sur vos factures et devis.</p>
          </div>
        </div>
      </div>

      <!-- Company info -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Informations de l'entreprise</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nom de l'entreprise / Nom complet</label>
            <input type="text" name="company_name" value="<%= settings && settings.company_name ? settings.company_name : '' %>"
              placeholder="Marie Dupont Consulting"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Adresse</label>
            <input type="text" name="company_address" value="<%= settings && settings.company_address ? settings.company_address : '' %>"
              placeholder="12 rue de la Paix"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Code postal</label>
            <input type="text" name="company_postal" value="<%= settings && settings.company_postal ? settings.company_postal : '' %>"
              placeholder="75001"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Ville</label>
            <input type="text" name="company_city" value="<%= settings && settings.company_city ? settings.company_city : '' %>"
              placeholder="Paris"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Téléphone</label>
            <input type="tel" name="company_phone" value="<%= settings && settings.company_phone ? settings.company_phone : '' %>"
              placeholder="06 00 00 00 00"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email professionnel</label>
            <input type="email" name="company_email" value="<%= settings && settings.company_email ? settings.company_email : '' %>"
              placeholder="contact@exemple.fr"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">SIRET</label>
            <input type="text" name="company_siret" value="<%= settings && settings.company_siret ? settings.company_siret : '' %>"
              placeholder="12345678901234"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Numéro de TVA intracommunautaire</label>
            <input type="text" name="company_tva" value="<%= settings && settings.company_tva ? settings.company_tva : '' %>"
              placeholder="FR12345678901"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
        </div>
      </div>

      <!-- Template -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Modèle de document</h3>
        <p class="text-sm text-gray-500 mb-4">Choisissez l'apparence de vos factures et devis. Vous pouvez aussi changer le modèle directement sur chaque document.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% [
            { value: 'classic', label: 'Classique', desc: 'En-tête violet dégradé, tableau coloré. Style moderne et professionnel.', color: '#4F46E5' },
            { value: 'modern', label: 'Moderne', desc: 'Sidebar sombre à gauche, contenu épuré à droite. Haut de gamme.', color: '#1e293b' },
            { value: 'minimal', label: 'Épuré', desc: 'Noir & blanc minimaliste. Élégant et intemporel.', color: '#000' },
          ].forEach(tpl => { %>
          <label style="cursor:pointer;display:block;">
            <input type="radio" name="invoice_template" value="<%= tpl.value %>"
              <%= (settings && settings.invoice_template === tpl.value) || (!settings || !settings.invoice_template) && tpl.value === 'classic' ? 'checked' : '' %>
              style="position:absolute;opacity:0;" onchange="this.form.submit()">
            <div class="template-card" style="border:2px solid <%= (settings && settings.invoice_template === tpl.value) || (!settings || !settings.invoice_template) && tpl.value === 'classic' ? tpl.color : '#e5e7eb' %>;border-radius:12px;padding:16px;transition:border-color .2s;"
              onclick="this.previousElementSibling.click()">
              <!-- Mini aperçu -->
              <div style="background:#f9fafb;border-radius:8px;padding:10px;margin-bottom:12px;height:70px;overflow:hidden;position:relative;">
                <% if (tpl.value === 'classic') { %>
                <div style="background:<%= tpl.color %>;height:14px;border-radius:4px;margin-bottom:6px;"></div>
                <div style="background:#e5e7eb;height:6px;border-radius:3px;width:70%;margin-bottom:3px;"></div>
                <div style="background:#e5e7eb;height:6px;border-radius:3px;width:50%;"></div>
                <% } else if (tpl.value === 'modern') { %>
                <div style="display:flex;height:100%;gap:6px;">
                  <div style="background:<%= tpl.color %>;width:28px;border-radius:4px;"></div>
                  <div style="flex:1;"><div style="background:#e5e7eb;height:6px;border-radius:3px;width:80%;margin-bottom:4px;"></div><div style="background:#e5e7eb;height:6px;border-radius:3px;width:60%;"></div></div>
                </div>
                <% } else { %>
                <div style="border-bottom:2px solid #000;padding-bottom:6px;margin-bottom:6px;">
                  <div style="background:#e5e7eb;height:8px;border-radius:3px;width:50%;"></div>
                </div>
                <div style="background:#e5e7eb;height:5px;border-radius:3px;width:90%;margin-bottom:3px;"></div>
                <div style="background:#e5e7eb;height:5px;border-radius:3px;width:75%;"></div>
                <% } %>
              </div>
              <p class="font-bold text-gray-900 text-sm mb-1"><%= tpl.label %></p>
              <p class="text-xs text-gray-500"><%= tpl.desc %></p>
            </div>
          </label>
          <% }); %>
        </div>
      </div>

      <!-- Invoice settings -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Paramètres de facturation</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Préfixe factures</label>
            <input type="text" name="invoice_prefix" value="<%= settings && settings.invoice_prefix ? settings.invoice_prefix : 'FAC' %>"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Préfixe devis</label>
            <input type="text" name="quote_prefix" value="<%= settings && settings.quote_prefix ? settings.quote_prefix : 'DEV' %>"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">TVA par défaut (%)</label>
            <select name="default_tva" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm bg-white">
              <option value="0" <%= (settings && settings.default_tva == 0) ? 'selected' : '' %>>0% (exonéré)</option>
              <option value="5.5" <%= (settings && settings.default_tva == 5.5) ? 'selected' : '' %>>5,5%</option>
              <option value="10" <%= (settings && settings.default_tva == 10) ? 'selected' : '' %>>10%</option>
              <option value="20" <%= (!settings || settings.default_tva == 20) ? 'selected' : '' %>>20% (standard)</option>
            </select>
          </div>
          <div class="md:col-span-3">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Conditions de paiement par défaut</label>
            <input type="text" name="payment_terms" value="<%= settings && settings.payment_terms ? settings.payment_terms : 'Paiement à 30 jours' %>"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
        </div>
      </div>

      <!-- Bank details -->
      <div>
        <h3 class="text-lg font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Coordonnées bancaires</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Banque</label>
            <input type="text" name="bank_name" value="<%= settings && settings.bank_name ? settings.bank_name : '' %>"
              placeholder="BNP Paribas"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">IBAN</label>
            <input type="text" name="bank_iban" value="<%= settings && settings.bank_iban ? settings.bank_iban : '' %>"
              placeholder="FR76 1234 5678 9012 3456 7890 123"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm font-mono">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">BIC / SWIFT</label>
            <input type="text" name="bank_bic" value="<%= settings && settings.bank_bic ? settings.bank_bic : '' %>"
              placeholder="BNPAFRPPXXX"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm font-mono">
          </div>
        </div>
      </div>

      <button type="submit" class="btn-primary text-white font-bold px-8 py-3 rounded-xl">
        Enregistrer les paramètres
      </button>
    </form>
  </div>
</div>

<style>.btn-primary{background:linear-gradient(135deg,#4F46E5,#7C3AED);transition:all .2s;box-shadow:0 4px 12px rgba(79,70,229,.25)}.btn-primary:hover{transform:translateY(-1px)}</style>
