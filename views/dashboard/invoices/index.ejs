<% if (invoices && invoices.length > 0) { %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Numéro</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Client</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Date</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Montant TTC</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
          <th class="text-right px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% invoices.forEach(invoice => { %>
        <tr class="table-row">
          <td class="px-6 py-4">
            <a href="/dashboard/invoices/<%= invoice.id %>" class="font-semibold text-primary-600 hover:underline text-sm"><%= invoice.invoice_number %></a>
          </td>
          <td class="px-6 py-4 hidden md:table-cell">
            <span class="text-sm text-gray-700"><%= invoice.client_name || '—' %></span>
          </td>
          <td class="px-6 py-4 hidden lg:table-cell">
            <span class="text-sm text-gray-500"><%= new Date(invoice.issue_date).toLocaleDateString('fr-FR') %></span>
          </td>
          <td class="px-6 py-4">
            <span class="text-sm font-bold text-gray-900"><%= invoice.total.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) %> €</span>
          </td>
          <td class="px-6 py-4">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%=
              invoice.status === 'paid' ? 'bg-green-100 text-green-700' :
              invoice.status === 'sent' ? 'bg-blue-100 text-blue-700' :
              invoice.status === 'cancelled' ? 'bg-red-100 text-red-700' :
              'bg-gray-100 text-gray-600'
            %>">
              <%=
                invoice.status === 'paid' ? 'Payée' :
                invoice.status === 'sent' ? 'Envoyée' :
                invoice.status === 'cancelled' ? 'Annulée' : 'Brouillon'
              %>
            </span>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-3">
              <a href="/dashboard/invoices/<%= invoice.id %>" class="text-xs text-primary-600 font-medium hover:underline">Voir</a>
              <form action="/dashboard/invoices/<%= invoice.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer ce document ?')">
                <button type="submit" class="text-xs text-red-400 hover:text-red-600 font-medium">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } else { %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm py-20 text-center">
  <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
  </div>
  <p class="text-gray-500 font-medium mb-2">Aucun <%= type === 'invoice' ? 'facture' : 'devis' %> pour le moment</p>
  <a href="/dashboard/invoices/create?type=<%= type %>" class="btn-primary text-white font-semibold px-6 py-2.5 rounded-lg text-sm inline-block mt-4">
    + <%= type === 'invoice' ? 'Créer une facture' : 'Créer un devis' %>
  </a>
</div>
<% } %>
<style>.btn-primary{background:linear-gradient(135deg,#4F46E5,#7C3AED);transition:all .2s;box-shadow:0 4px 12px rgba(79,70,229,.25)}.btn-primary:hover{transform:translateY(-1px)}</style>
