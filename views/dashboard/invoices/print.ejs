      <p style="color:rgba(255,255,255,.7);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:#fff;font-size:26px;font-weight:900;margin:0;"><%=invoice.invoice_number%></p>
      <p style="color:rgba(255,255,255,.7);font-size:11px;margin:5px 0 0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> → <%=d(invoice.due_date)%><% } %></p>
    </div>
  </div>
</div>
<% } %>

<!-- ══ INFOS ÉMETTEUR / DESTINATAIRE ══ -->
<div style="display:flex;gap:16px;margin-bottom:18px;">
  <!-- Émetteur (masqué pour modern qui a déjà la sidebar) -->
  <% if(tpl!=='modern'){ %>
  <div style="flex:1;padding:12px 14px;background:#f8fafc;border-radius:8px;font-size:11px;">
    <p style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 5px;">Émetteur</p>
    <p style="font-size:12px;font-weight:800;color:#1e293b;margin:0 0 2px;"><%=companyName||'Mon Entreprise'%></p>
    <% if(settings&&settings.company_address){ %><p style="color:#64748b;margin:1px 0;"><%=settings.company_address%></p><% } %>
    <% if(settings&&settings.company_city){ %><p style="color:#64748b;margin:1px 0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
    <% if(settings&&settings.company_siret){ %><p style="color:#9ca3af;margin:4px 0 0;font-size:10px;">SIRET : <%=settings.company_siret%></p><% } %>
    <% if(settings&&settings.company_tva){ %><p style="color:#9ca3af;margin:1px 0 0;font-size:10px;">N° TVA : <%=settings.company_tva%></p><% } %>
  </div>
  <% } %>
  <!-- Destinataire -->
  <% if(invoice.client_name){ %>
  <div style="flex:1;padding:12px 14px;background:#f0f4ff;border-radius:8px;font-size:11px;border-left:3px solid <%=accentColor||'#4F46E5'%>;">
    <p style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 5px;">Facturé à</p>
    <% if(invoice.client_logo){ %><img src="<%=invoice.client_logo%>" style="max-height:32px;max-width:90px;object-fit:contain;margin-bottom:5px;display:block;"/><% } %>
    <p style="font-size:12px;font-weight:800;color:#1e293b;margin:0 0 2px;"><%=invoice.client_name%></p>
    <% if(invoice.client_company){ %><p style="color:#374151;margin:1px 0;"><%=invoice.client_company%></p><% } %>
    <% if(invoice.client_address){ %><p style="color:#64748b;margin:1px 0;"><%=invoice.client_address%></p><% } %>
    <% if(invoice.client_city){ %><p style="color:#64748b;margin:1px 0;"><%=invoice.client_postal||''%> <%=invoice.client_city%></p><% } %>
  </div>
  <% } %>
</div>

<!-- ══ TABLEAU DES LIGNES ══ -->
<table class="inv-table" style="--acc:<%=accentColor%>;">
  <thead>
    <tr>
      <th style="width:45%;text-align:left;">Description</th>
      <th style="width:8%;">Qté</th>
      <th style="width:14%;text-align:right;">PU HT</th>
      <th style="width:10%;">TVA</th>
      <th style="width:10%;text-align:right;">Total HT</th>
      <th style="width:13%;text-align:right;">TTC</th>
    </tr>
  </thead>
  <tbody>
    <% if(invoice.items&&invoice.items.length>0){invoice.items.forEach((item,i)=>{ %>
    <tr>
      <td style="text-align:left;color:#1e293b;font-weight:500;"><%=item.description%></td>
      <td><%=item.quantity%></td>
      <td style="text-align:right;"><%=fmt(item.unit_price)%> €</td>
      <td><%=item.tva_rate||0%>%</td>
      <td style="text-align:right;"><%=fmt(item.unit_price*(item.quantity||1))%> €</td>
      <td style="text-align:right;color:<%=accentColor%>;"><%=fmt(item.total)%> €</td>
    </tr>
    <% });}else{ %>
    <tr><td colspan="6" style="text-align:center;color:#94a3b8;padding:16px;">Aucune ligne</td></tr>
    <% } %>
  </tbody>
</table>

<!-- ══ TOTAUX ══ -->
<div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
  <div style="width:230px;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
    <div style="display:flex;justify-content:space-between;padding:7px 12px;font-size:11px;color:#64748b;border-bottom:1px solid #f1f5f9;background:#f9fafb;"><span>Sous-total HT</span><span><%=fmt(invoice.subtotal)%> €</span></div>
    <div style="display:flex;justify-content:space-between;padding:7px 12px;font-size:11px;color:#64748b;border-bottom:1px solid #f1f5f9;"><span>TVA</span><span><%=fmt(invoice.tva_amount)%> €</span></div>
    <div style="display:flex;justify-content:space-between;padding:10px 12px;background:<%=accentColor%>;"><span style="color:#fff;font-weight:800;font-size:12px;">TOTAL TTC</span><span style="color:#fff;font-weight:900;font-size:14px;"><%=fmt(invoice.total)%> €</span></div>
  </div>
</div>

<!-- ══ PIED DE PAGE ══ -->
<div style="border-top:1px solid #f1f5f9;padding-top:14px;font-size:11px;color:#64748b;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;">
  <div>
    <% if(invoice.payment_terms){ %><p style="margin:0 0 2px;"><strong>Conditions :</strong> <%=invoice.payment_terms%></p><% } %>
    <% if(invoice.notes){ %><p style="margin:0;"><%=invoice.notes%></p><% } %>
    <% if(settings&&settings.company_siret&&tpl!=='classic'&&tpl!=='minimal'){ %><p style="margin-top:4px;color:#9ca3af;font-size:10px;">SIRET : <%=settings.company_siret%><% if(settings.company_tva){ %> · N° TVA : <%=settings.company_tva%><% } %></p><% } %>
  </div>
  <% if(settings&&settings.bank_iban){ %>
  <div style="text-align:right;">
    <p style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px;">Coordonnées bancaires</p>
    <% if(settings.bank_name){ %><p style="margin:0 0 2px;font-weight:600;color:#374151;"><%=settings.bank_name%></p><% } %>
    <p style="margin:0 0 2px;font-family:monospace;"><%=settings.bank_iban%></p>
    <% if(settings.bank_bic){ %><p style="margin:0;font-family:monospace;">BIC : <%=settings.bank_bic%></p><% } %>
  </div>
  <% } %>
</div>

</div><!-- fin .page -->

<script>
  // Auto-print après chargement complet
  window.addEventListener('load', function() {
    setTimeout(function() { window.print(); }, 600);
  });
  // Fermer après impression
  window.addEventListener('afterprint', function() {
    setTimeout(function() { window.close(); }, 300);
  });
</script>
</body>
</html>
