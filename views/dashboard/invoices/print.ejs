<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%=invoice.invoice_number%> — LFacture</title>
<style>
  *{box-sizing:border-box;-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important;}
  body{margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f0f0f0;}
  @page{size:A4;margin:0;}
  @media print{
    body{background:#fff;}
    .no-print{display:none!important;}
    .page{margin:0;border-radius:0!important;box-shadow:none!important;width:210mm!important;min-height:297mm!important;padding:15mm!important;}
  }
  .page{width:210mm;min-height:297mm;background:#fff;margin:20px auto;padding:15mm;box-shadow:0 4px 32px rgba(0,0,0,.15);}
  /* Bouton print */
  .print-bar{width:210mm;margin:0 auto 12px;display:flex;gap:10px;align-items:center;}
  .btn-pdf{background:linear-gradient(135deg,#4F46E5,#7C3AED);color:#fff;border:none;padding:10px 22px;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:8px;}
  .btn-close{background:#f1f5f9;color:#64748b;border:1px solid #e2e8f0;padding:10px 18px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;}
  .hint{font-size:12px;color:#94a3b8;margin-left:4px;}
  /* Logo container */
  .logo-box{display:inline-block;margin-bottom:8px;}
  .logo-box img{max-height:72px;max-width:180px;object-fit:contain;display:block;}
  .logo-dark img{background:rgba(255,255,255,.9);border-radius:6px;padding:4px 8px;}
</style>
</head>
<body>

<!-- Barre d'actions (masquée à l'impression) -->
<div class="print-bar no-print">
  <button class="btn-pdf" onclick="window.print()">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    Télécharger en PDF
  </button>
  <button class="btn-close" onclick="window.close()">✕ Fermer</button>
  <span class="hint">Dans la boîte d'impression → choisir "Enregistrer en PDF"</span>
</div>

<%
const tpl = invoice.template || 'classic';
const fmt = n => (n||0).toLocaleString('fr-FR',{minimumFractionDigits:2});
const d   = s => s ? new Date(s).toLocaleDateString('fr-FR') : '';
const statusLabel = s => s==='paid'?'✓ Payée':s==='sent'?'→ Envoyée':s==='cancelled'?'✗ Annulée':'● Brouillon';
const statusStyle = s => s==='paid'?'background:#d1fae5;color:#065f46':s==='sent'?'background:#dbeafe;color:#1e40af':s==='cancelled'?'background:#fee2e2;color:#991b1b':'background:#f3f4f6;color:#374151';
const logo = settings && settings.company_logo;
const companyName = settings && settings.company_name ? settings.company_name : '';
%>

<!-- ═══ PAGE A4 ═══ -->
<div class="page">

<% if(tpl==='classic'){ %>
<div style="background:linear-gradient(135deg,#4F46E5,#7C3AED);padding:28px 32px;border-radius:10px 10px 0 0;margin:-15mm -15mm 24px;">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#fff;font-size:18px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){ %><p style="color:rgba(255,255,255,.75);font-size:11px;margin:2px 0 0;"><%=settings.company_address%></p><% } %>
      <% if(settings&&settings.company_city){ %><p style="color:rgba(255,255,255,.75);font-size:11px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
      <% if(settings&&settings.company_siret){ %><p style="color:rgba(255,255,255,.5);font-size:10px;margin:3px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
    </div>
    <div style="text-align:right;">
      <p style="color:#fff;font-size:30px;font-weight:900;margin:0;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:rgba(255,255,255,.8);font-size:15px;font-weight:700;margin:3px 0 0;"><%=invoice.invoice_number%></p>
      <p style="color:rgba(255,255,255,.7);font-size:11px;margin:6px 0 2px;">Date : <%=d(invoice.issue_date)%></p>
      <% if(invoice.due_date){ %><p style="color:rgba(255,255,255,.7);font-size:11px;margin:0;">Échéance : <%=d(invoice.due_date)%></p><% } %>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='modern'){ %>
<div style="display:flex;margin:-15mm -15mm 24px;min-height:140px;">
  <div style="width:180px;background:#1e293b;flex-shrink:0;padding:24px 18px;border-radius:10px 0 0 0;">
    <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
    <p style="color:#fff;font-weight:900;font-size:13px;margin:0 0 4px;"><%=companyName||'Mon Entreprise'%></p>
    <% if(settings&&settings.company_address){ %><p style="color:#94a3b8;font-size:10px;margin:0 0 2px;"><%=settings.company_address%></p><% } %>
    <% if(settings&&settings.company_city){ %><p style="color:#94a3b8;font-size:10px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
    <% if(settings&&settings.company_siret){ %><p style="color:#64748b;font-size:9px;margin:6px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
  </div>
  <div style="flex:1;background:#f8fafc;padding:24px 24px;border-radius:0 10px 0 0;">
    <p style="font-size:28px;font-weight:900;color:#1e293b;margin:0;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
    <p style="font-size:15px;font-weight:700;color:#64748b;margin:3px 0 8px;"><%=invoice.invoice_number%></p>
    <p style="font-size:11px;color:#64748b;margin:0;">Date : <strong><%=d(invoice.issue_date)%></strong><% if(invoice.due_date){ %> · Échéance : <strong><%=d(invoice.due_date)%></strong><% } %></p>
    <span style="display:inline-block;margin-top:6px;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;<%=statusStyle(invoice.status)%>"><%=statusLabel(invoice.status)%></span>
  </div>
</div>
<% } %>

<% if(tpl==='minimal'){ %>
<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;padding-bottom:16px;border-bottom:2px solid #000;">
  <div>
    <% if(logo){ %><div class="logo-box"><img src="<%=logo%>"/></div><% } %>
    <p style="font-size:18px;font-weight:900;color:#000;margin:0;"><%=companyName||'Mon Entreprise'%></p>
    <% if(settings&&settings.company_address){ %><p style="color:#6b7280;font-size:11px;margin:2px 0 0;"><%=settings.company_address%></p><% } %>
    <% if(settings&&settings.company_city){ %><p style="color:#6b7280;font-size:11px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
    <% if(settings&&settings.company_siret){ %><p style="color:#9ca3af;font-size:10px;margin:4px 0 0;">SIRET <%=settings.company_siret%></p><% } %>
  </div>
  <div style="text-align:right;">
    <p style="font-size:11px;font-weight:700;color:#9ca3af;letter-spacing:2px;text-transform:uppercase;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
    <p style="font-size:24px;font-weight:900;color:#000;margin:0 0 8px;"><%=invoice.invoice_number%></p>
    <p style="font-size:11px;color:#6b7280;margin:0 0 2px;">Émis le <%=d(invoice.issue_date)%></p>
    <% if(invoice.due_date){ %><p style="font-size:11px;color:#6b7280;margin:0;">Échéance <%=d(invoice.due_date)%></p><% } %>
  </div>
</div>
<% } %>

<% if(tpl==='blue'){ %>
<div style="background:linear-gradient(135deg,#1d4ed8,#2563eb);padding:28px 32px;border-radius:10px 10px 0 0;margin:-15mm -15mm 24px;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#fff;font-size:17px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){ %><p style="color:rgba(255,255,255,.75);font-size:11px;margin:2px 0 0;"><%=settings.company_address%><% if(settings.company_city){ %>, <%=settings.company_postal||''%> <%=settings.company_city%><% } %></p><% } %>
    </div>
    <div style="text-align:right;">
      <p style="color:rgba(255,255,255,.65);font-size:10px;letter-spacing:2px;text-transform:uppercase;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:#fff;font-size:26px;font-weight:900;margin:0;"><%=invoice.invoice_number%></p>
      <p style="color:rgba(255,255,255,.75);font-size:11px;margin:5px 0 0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> · Éch. <%=d(invoice.due_date)%><% } %></p>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='green'){ %>
<div style="display:flex;margin:-15mm -15mm 24px;">
  <div style="width:10px;background:linear-gradient(180deg,#059669,#047857);flex-shrink:0;"></div>
  <div style="flex:1;padding:28px 28px 20px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <% if(logo){ %><div class="logo-box"><img src="<%=logo%>"/></div><% } %>
        <p style="font-size:18px;font-weight:900;color:#064e3b;margin:0;"><%=companyName||'Mon Entreprise'%></p>
        <% if(settings&&settings.company_address){ %><p style="color:#6b7280;font-size:11px;margin:2px 0 0;"><%=settings.company_address%></p><% } %>
        <% if(settings&&settings.company_city){ %><p style="color:#6b7280;font-size:11px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
        <% if(settings&&settings.company_siret){ %><p style="color:#9ca3af;font-size:10px;margin:4px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
      </div>
      <div style="text-align:right;">
        <div style="background:#ecfdf5;border:2px solid #6ee7b7;border-radius:10px;padding:14px 18px;display:inline-block;">
          <p style="color:#059669;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
          <p style="color:#064e3b;font-size:20px;font-weight:900;margin:0 0 6px;"><%=invoice.invoice_number%></p>
          <p style="color:#6b7280;font-size:10px;margin:0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> · <%=d(invoice.due_date)%><% } %></p>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='orange'){ %>
<div style="background:linear-gradient(135deg,#f97316,#ea580c);padding:20px 28px;border-radius:10px 10px 0 0;margin:-15mm -15mm 20px;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#fff;font-size:17px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
    </div>
    <div style="text-align:right;">
      <p style="color:#fff;font-size:26px;font-weight:900;margin:0;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:rgba(255,255,255,.8);font-size:14px;font-weight:700;margin:2px 0 0;"><%=invoice.invoice_number%></p>
      <p style="color:rgba(255,255,255,.7);font-size:11px;margin:4px 0 0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> · Éch. <%=d(invoice.due_date)%><% } %></p>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='red'){ %>
<div style="display:flex;margin:-15mm -15mm 24px;">
  <div style="width:8px;background:linear-gradient(180deg,#ef4444,#dc2626);flex-shrink:0;"></div>
  <div style="flex:1;padding:28px 28px 20px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <% if(logo){ %><div class="logo-box"><img src="<%=logo%>"/></div><% } %>
        <p style="font-size:18px;font-weight:900;color:#1e293b;margin:0;"><%=companyName||'Mon Entreprise'%></p>
        <% if(settings&&settings.company_address){ %><p style="color:#6b7280;font-size:11px;margin:2px 0 0;"><%=settings.company_address%></p><% } %>
        <% if(settings&&settings.company_city){ %><p style="color:#6b7280;font-size:11px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><% } %>
        <% if(settings&&settings.company_siret){ %><p style="color:#9ca3af;font-size:10px;margin:4px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
      </div>
      <div style="text-align:right;">
        <p style="font-size:30px;font-weight:900;color:#dc2626;margin:0;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
        <p style="font-size:15px;font-weight:700;color:#64748b;margin:3px 0;"><%=invoice.invoice_number%></p>
        <p style="font-size:11px;color:#94a3b8;margin:0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> → <%=d(invoice.due_date)%><% } %></p>
        <span style="display:inline-block;margin-top:5px;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;<%=statusStyle(invoice.status)%>"><%=statusLabel(invoice.status)%></span>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='navy'){ %>
<div style="background:#0f172a;padding:28px 32px;border-radius:10px 10px 0 0;margin:-15mm -15mm 0;margin-bottom:0;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#f59e0b;font-size:18px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){ %><p style="color:#94a3b8;font-size:11px;margin:2px 0 0;"><%=settings.company_address%><% if(settings.company_city){ %> · <%=settings.company_postal||''%> <%=settings.company_city%><% } %></p><% } %>
      <% if(settings&&settings.company_siret){ %><p style="color:#64748b;font-size:10px;margin:3px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
    </div>
    <div style="text-align:right;border-left:2px solid #f59e0b;padding-left:24px;">
      <p style="color:#64748b;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:#fff;font-size:24px;font-weight:900;margin:0;"><%=invoice.invoice_number%></p>
      <p style="color:#94a3b8;font-size:11px;margin:5px 0 0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> · Éch. <%=d(invoice.due_date)%><% } %></p>
    </div>
  </div>
</div>
<div style="height:4px;background:linear-gradient(90deg,#f59e0b,#fbbf24,#f59e0b);margin:-15mm -15mm 24px;margin-top:0;"></div>
<% } %>

<% if(tpl==='slate'){ %>
<div style="background:linear-gradient(135deg,#334155,#475569);padding:24px 28px;border-radius:10px 10px 0 0;margin:-15mm -15mm 24px;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#fff;font-size:17px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){ %><p style="color:rgba(255,255,255,.65);font-size:11px;margin:2px 0 0;"><%=settings.company_address%><% if(settings.company_city){ %>, <%=settings.company_postal||''%> <%=settings.company_city%><% } %></p><% } %>
    </div>
    <div style="text-align:right;">
      <div style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:8px;padding:12px 16px;display:inline-block;">
        <p style="color:rgba(255,255,255,.6);font-size:10px;letter-spacing:2px;text-transform:uppercase;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
        <p style="color:#fff;font-size:20px;font-weight:900;margin:0 0 5px;"><%=invoice.invoice_number%></p>
        <p style="color:rgba(255,255,255,.65);font-size:10px;margin:0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> · <%=d(invoice.due_date)%><% } %></p>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if(tpl==='creative'){ %>
<div style="background:linear-gradient(135deg,#7c3aed,#9333ea,#c026d3);padding:28px 32px;border-radius:10px 10px 0 0;margin:-15mm -15mm 24px;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <div>
      <% if(logo){ %><div class="logo-box logo-dark"><img src="<%=logo%>"/></div><% } %>
      <p style="color:#fff;font-size:18px;font-weight:900;margin:0;"><%=companyName||'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){ %><p style="color:rgba(255,255,255,.7);font-size:11px;margin:2px 0 0;"><%=settings.company_address%><% if(settings.company_city){ %> · <%=settings.company_postal||''%> <%=settings.company_city%><% } %></p><% } %>
      <% if(settings&&settings.company_siret){ %><p style="color:rgba(255,255,255,.5);font-size:10px;margin:3px 0 0;">SIRET : <%=settings.company_siret%></p><% } %>
    </div>
    <div style="text-align:right;">
      <p style="color:rgba(255,255,255,.7);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin:0 0 3px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="color:#fff;font-size:26px;font-weight:900;margin:0;"><%=invoice.invoice_number%></p>
      <p style="color:rgba(255,255,255,.7);font-size:11px;margin:5px 0 0;"><%=d(invoice.issue_date)%><% if(invoice.due_date){ %> → <%=d(invoice.due_date)%><% } %></p>
    </div>
  </div>
</div>
<% } %>

<!-- ══ SECTION CLIENT (tous les modèles non-couverts par sidebar) ══ -->
<% if(tpl!=='modern' && invoice.client_name){ %>
<div style="margin-bottom:20px;padding:14px 18px;background:#f8fafc;border-radius:8px;border-left:4px solid <%=
  tpl==='classic'?'#4F46E5':tpl==='blue'?'#2563eb':tpl==='green'?'#059669':tpl==='orange'?'#f97316':tpl==='red'?'#dc2626':tpl==='navy'?'#f59e0b':tpl==='slate'?'#475569':tpl==='creative'?'#9333ea':'#94a3b8'
%>;max-width:320px;">
  <p style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 5px;">Facturé à</p>
  <% if(invoice.client_logo){ %><img src="<%=invoice.client_logo%>" style="max-height:38px;max-width:110px;object-fit:contain;margin-bottom:6px;display:block;"/><% } %>
  <p style="font-size:13px;font-weight:800;color:#1e293b;margin:0 0 2px;"><%=invoice.client_name%></p>
  <% if(invoice.client_company){ %><p style="font-size:11px;color:#374151;margin:0 0 2px;"><%=invoice.client_company%></p><% } %>
  <% if(invoice.client_address){ %><p style="font-size:11px;color:#64748b;margin:0 0 2px;"><%=invoice.client_address%></p><% } %>
  <% if(invoice.client_city){ %><p style="font-size:11px;color:#64748b;margin:0;"><%=invoice.client_postal||''%> <%=invoice.client_city%></p><% } %>
</div>
<% } %>
<% if(tpl==='modern' && invoice.client_name){ %>
<div style="margin-bottom:20px;padding:14px 18px;background:#f1f5f9;border-radius:8px;max-width:280px;">
  <p style="font-size:9px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin:0 0 5px;">Client</p>
  <% if(invoice.client_logo){ %><img src="<%=invoice.client_logo%>" style="max-height:38px;max-width:110px;object-fit:contain;margin-bottom:6px;display:block;"/><% } %>
  <p style="font-size:13px;font-weight:800;color:#1e293b;margin:0 0 2px;"><%=invoice.client_name%></p>
  <% if(invoice.client_company){ %><p style="font-size:11px;color:#374151;margin:0 0 2px;"><%=invoice.client_company%></p><% } %>
  <% if(invoice.client_address){ %><p style="font-size:11px;color:#64748b;margin:0 0 2px;"><%=invoice.client_address%></p><% } %>
  <% if(invoice.client_city){ %><p style="font-size:11px;color:#64748b;margin:0;"><%=invoice.client_postal||''%> <%=invoice.client_city%></p><% } %>
</div>
<% } %>

<!-- ══ TABLEAU DES LIGNES ══ -->
<%
const accentColor =
  tpl==='classic'?'#4F46E5':tpl==='modern'?'#1e293b':tpl==='minimal'?'#000':
  tpl==='blue'?'#2563eb':tpl==='green'?'#059669':tpl==='orange'?'#f97316':
  tpl==='red'?'#dc2626':tpl==='navy'?'#0f172a':tpl==='slate'?'#334155':'#9333ea';
const accentLight =
  tpl==='classic'?'#eef2ff':tpl==='blue'?'#eff6ff':tpl==='green'?'#f0fdf4':
  tpl==='orange'?'#fff7ed':tpl==='red'?'#fef2f2':tpl==='navy'?'#0f172a10':
  tpl==='slate'?'#f8fafc':tpl==='creative'?'#faf5ff':'#f8fafc';
%>
<table style="width:100%;border-collapse:collapse;font-size:12px;margin-bottom:16px;">
  <thead><tr style="background:<%=accentColor%>;">
    <th style="text-align:left;padding:9px 11px;color:#fff;font-weight:700;font-size:10px;border-radius:6px 0 0 6px;">Description</th>
    <th style="text-align:center;padding:9px 8px;color:#fff;font-weight:700;font-size:10px;">Qté</th>
    <th style="text-align:right;padding:9px 8px;color:#fff;font-weight:700;font-size:10px;">PU HT</th>
    <th style="text-align:center;padding:9px 8px;color:#fff;font-weight:700;font-size:10px;">TVA</th>
    <th style="text-align:right;padding:9px 11px;color:#fff;font-weight:700;font-size:10px;border-radius:0 6px 6px 0;">TTC</th>
  </tr></thead>
  <tbody>
    <% if(invoice.items&&invoice.items.length>0){invoice.items.forEach((item,i)=>{ %>
    <tr style="background:<%=i%2===0?'#fff':accentLight%>;border-bottom:1px solid #f1f5f9;">
      <td style="padding:9px 11px;color:#374151;"><%=item.description%></td>
      <td style="padding:9px 8px;color:#64748b;text-align:center;"><%=item.quantity%></td>
      <td style="padding:9px 8px;color:#64748b;text-align:right;"><%=fmt(item.unit_price)%> €</td>
      <td style="padding:9px 8px;color:#64748b;text-align:center;"><%=item.tva_rate%>%</td>
      <td style="padding:9px 11px;font-weight:700;color:<%=tpl==='minimal'?'#000':accentColor%>;text-align:right;"><%=fmt(item.total)%> €</td>
    </tr>
    <% });}%>
  </tbody>
</table>

<!-- ══ TOTAUX ══ -->
<div style="display:flex;justify-content:flex-end;margin-bottom:18px;">
  <div style="width:220px;">
    <div style="display:flex;justify-content:space-between;padding:5px 0;color:#64748b;font-size:12px;border-bottom:1px solid #f1f5f9;"><span>Total HT</span><span><%=fmt(invoice.subtotal)%> €</span></div>
    <div style="display:flex;justify-content:space-between;padding:5px 0;color:#64748b;font-size:12px;border-bottom:1px solid #f1f5f9;"><span>TVA</span><span><%=fmt(invoice.tva_amount)%> €</span></div>
    <div style="display:flex;justify-content:space-between;padding:11px 13px;background:<%=accentColor%>;border-radius:8px;margin-top:6px;"><span style="color:#fff;font-weight:800;font-size:13px;">Total TTC</span><span style="color:#fff;font-weight:900;font-size:15px;"><%=fmt(invoice.total)%> €</span></div>
  </div>
</div>

<!-- ══ PIED DE PAGE ══ -->
<div style="border-top:1px solid #f1f5f9;padding-top:14px;font-size:11px;color:#64748b;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;">
  <div>
    <% if(invoice.payment_terms){ %><p style="margin:0 0 2px;"><strong>Conditions :</strong> <%=invoice.payment_terms%></p><% } %>
    <% if(invoice.notes){ %><p style="margin:0;"><%=invoice.notes%></p><% } %>
    <% if(settings&&settings.company_siret&&tpl!=='classic'&&tpl!=='minimal'){ %><p style="margin-top:4px;color:#9ca3af;font-size:10px;">SIRET : <%=settings.company_siret%><% if(settings.company_tva){ %> · N° TVA : <%=settings.company_tva%><% } %></p><% } %>
  </div>
  <% if(settings&&settings.bank_iban){ %>
  <div style="text-align:right;">
    <p style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px;">Coordonnées bancaires</p>
    <% if(settings.bank_name){ %><p style="margin:0 0 2px;font-weight:600;color:#374151;"><%=settings.bank_name%></p><% } %>
    <p style="margin:0 0 2px;font-family:monospace;"><%=settings.bank_iban%></p>
    <% if(settings.bank_bic){ %><p style="margin:0;font-family:monospace;">BIC : <%=settings.bank_bic%></p><% } %>
  </div>
  <% } %>
</div>

</div><!-- fin .page -->

<script>
  // Auto-print après chargement complet
  window.addEventListener('load', function() {
    setTimeout(function() { window.print(); }, 600);
  });
  // Fermer après impression
  window.addEventListener('afterprint', function() {
    setTimeout(function() { window.close(); }, 300);
  });
</script>
</body>
</html>
