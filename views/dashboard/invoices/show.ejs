<!-- Actions bar -->
<div class="flex flex-wrap items-center gap-3 mb-6">
  <a href="<%= invoice.type === 'invoice' ? '/dashboard/invoices' : '/dashboard/quotes' %>" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
    ← Retour aux <%= invoice.type === 'invoice' ? 'factures' : 'devis' %>
  </a>
  <div class="flex-1"></div>

  <!-- Status update -->
  <form action="/dashboard/invoices/<%= invoice.id %>/status" method="POST" class="flex items-center gap-2">
    <select name="status" class="px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
      <option value="draft" <%= invoice.status === 'draft' ? 'selected' : '' %>>Brouillon</option>
      <option value="sent" <%= invoice.status === 'sent' ? 'selected' : '' %>>Envoyée</option>
      <option value="paid" <%= invoice.status === 'paid' ? 'selected' : '' %>>Payée</option>
      <option value="cancelled" <%= invoice.status === 'cancelled' ? 'selected' : '' %>>Annulée</option>
    </select>
    <button type="submit" class="btn-secondary text-sm font-semibold px-4 py-2 rounded-lg">Mettre à jour</button>
  </form>

  <button onclick="window.print()" class="btn-secondary text-sm font-semibold px-4 py-2 rounded-lg flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
    Imprimer / PDF
  </button>
</div>

<!-- Invoice Document -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden" id="invoiceDoc">
  <div class="p-10">
    <!-- Header -->
    <div class="flex items-start justify-between mb-10">
      <div>
        <% if (settings && settings.company_name) { %>
          <h2 class="text-2xl font-black text-gray-900"><%= settings.company_name %></h2>
          <% if (settings.company_address) { %><p class="text-sm text-gray-500 mt-1"><%= settings.company_address %></p><% } %>
          <% if (settings.company_city) { %><p class="text-sm text-gray-500"><%= settings.company_postal || '' %> <%= settings.company_city %></p><% } %>
          <% if (settings.company_siret) { %><p class="text-xs text-gray-400 mt-1">SIRET : <%= settings.company_siret %></p><% } %>
          <% if (settings.company_tva) { %><p class="text-xs text-gray-400">N° TVA : <%= settings.company_tva %></p><% } %>
        <% } else { %>
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
              <span class="text-white font-black text-sm">L</span>
            </div>
            <span class="text-xl font-black">LFacture</span>
          </div>
          <p class="text-xs text-gray-400 mt-2">Complétez vos paramètres d'entreprise</p>
        <% } %>
      </div>
      <div class="text-right">
        <p class="text-3xl font-black" style="color:#4F46E5"><%= invoice.type === 'invoice' ? 'FACTURE' : 'DEVIS' %></p>
        <p class="text-xl font-bold text-gray-700 mt-1"><%= invoice.invoice_number %></p>
        <div class="mt-3 space-y-1">
          <p class="text-sm text-gray-500">Date : <strong class="text-gray-700"><%= new Date(invoice.issue_date).toLocaleDateString('fr-FR') %></strong></p>
          <% if (invoice.due_date) { %><p class="text-sm text-gray-500">Échéance : <strong class="text-gray-700"><%= new Date(invoice.due_date).toLocaleDateString('fr-FR') %></strong></p><% } %>
        </div>
        <span class="inline-block mt-3 text-xs font-bold px-3 py-1 rounded-full <%=
          invoice.status === 'paid' ? 'bg-green-100 text-green-700' :
          invoice.status === 'sent' ? 'bg-blue-100 text-blue-700' :
          invoice.status === 'cancelled' ? 'bg-red-100 text-red-700' :
          'bg-gray-100 text-gray-600'
        %>">
          <%=
            invoice.status === 'paid' ? '✓ Payée' :
            invoice.status === 'sent' ? '→ Envoyée' :
            invoice.status === 'cancelled' ? '✗ Annulée' : '● Brouillon'
          %>
        </span>
      </div>
    </div>

    <!-- Client -->
    <% if (invoice.client_name) { %>
    <div class="mb-10 bg-gray-50 rounded-xl p-6 max-w-xs">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Facturé à</p>
      <p class="font-bold text-gray-900"><%= invoice.client_name %></p>
      <% if (invoice.client_company) { %><p class="text-sm text-gray-600"><%= invoice.client_company %></p><% } %>
      <% if (invoice.client_address) { %><p class="text-sm text-gray-500 mt-1"><%= invoice.client_address %></p><% } %>
      <% if (invoice.client_postal || invoice.client_city) { %><p class="text-sm text-gray-500"><%= invoice.client_postal || '' %> <%= invoice.client_city || '' %></p><% } %>
      <% if (invoice.client_siret) { %><p class="text-xs text-gray-400 mt-1">SIRET : <%= invoice.client_siret %></p><% } %>
    </div>
    <% } %>

    <!-- Items table -->
    <table class="w-full mb-8">
      <thead>
        <tr style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
          <th class="text-left px-4 py-3 text-white text-sm font-semibold rounded-l-xl">Description</th>
          <th class="text-center px-4 py-3 text-white text-sm font-semibold">Qté</th>
          <th class="text-right px-4 py-3 text-white text-sm font-semibold">PU HT</th>
          <th class="text-center px-4 py-3 text-white text-sm font-semibold">TVA</th>
          <th class="text-right px-4 py-3 text-white text-sm font-semibold rounded-r-xl">Total TTC</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (invoice.items && invoice.items.length > 0) { invoice.items.forEach(item => { %>
        <tr>
          <td class="px-4 py-4 text-sm text-gray-800"><%= item.description %></td>
          <td class="px-4 py-4 text-sm text-gray-600 text-center"><%= item.quantity %></td>
          <td class="px-4 py-4 text-sm text-gray-600 text-right"><%= item.unit_price.toLocaleString('fr-FR', {minimumFractionDigits:2}) %> €</td>
          <td class="px-4 py-4 text-sm text-gray-600 text-center"><%= item.tva_rate %>%</td>
          <td class="px-4 py-4 text-sm font-semibold text-gray-900 text-right"><%= item.total.toLocaleString('fr-FR', {minimumFractionDigits:2}) %> €</td>
        </tr>
        <% }); } else { %>
        <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400 text-sm">Aucune ligne</td></tr>
        <% } %>
      </tbody>
    </table>

    <!-- Totals -->
    <div class="flex justify-end mb-8">
      <div class="w-64">
        <div class="flex justify-between py-2 text-sm text-gray-600 border-b border-gray-100"><span>Total HT</span><span><%= invoice.subtotal.toLocaleString('fr-FR', {minimumFractionDigits:2}) %> €</span></div>
        <div class="flex justify-between py-2 text-sm text-gray-600 border-b border-gray-100"><span>TVA</span><span><%= invoice.tva_amount.toLocaleString('fr-FR', {minimumFractionDigits:2}) %> €</span></div>
        <div class="flex justify-between py-3 font-black text-lg text-gray-900"><span>Total TTC</span><span style="color:#4F46E5"><%= invoice.total.toLocaleString('fr-FR', {minimumFractionDigits:2}) %> €</span></div>
      </div>
    </div>

    <!-- Notes & Payment terms -->
    <% if (invoice.notes || invoice.payment_terms) { %>
    <div class="border-t border-gray-100 pt-6 space-y-2">
      <% if (invoice.payment_terms) { %><p class="text-sm text-gray-600"><strong>Conditions :</strong> <%= invoice.payment_terms %></p><% } %>
      <% if (invoice.notes) { %><p class="text-sm text-gray-500"><%= invoice.notes %></p><% } %>
    </div>
    <% } %>

    <!-- Bank details -->
    <% if (settings && settings.bank_iban) { %>
    <div class="mt-6 bg-gray-50 rounded-xl p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Coordonnées bancaires</p>
      <% if (settings.bank_name) { %><p class="text-sm text-gray-700">Banque : <%= settings.bank_name %></p><% } %>
      <p class="text-sm font-mono text-gray-700">IBAN : <%= settings.bank_iban %></p>
      <% if (settings.bank_bic) { %><p class="text-sm font-mono text-gray-700">BIC : <%= settings.bank_bic %></p><% } %>
    </div>
    <% } %>
  </div>
</div>

<style>
.btn-secondary{background:#f1f5f9;color:#374151;border:1px solid #e2e8f0;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px}.btn-secondary:hover{background:#e2e8f0}
@media print {
  aside, header, .flex.flex-wrap.items-center.gap-3.mb-6 { display: none !important; }
  body { background: white !important; }
  #invoiceDoc { box-shadow: none !important; border: none !important; }
}
</style>
