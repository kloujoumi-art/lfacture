<%
  const tplRaw = invoice.template || 'classic';
  const tpl = tplRaw === 'modern' ? 'classic' : tplRaw;
  const templates = [
    { id:'classic',  label:'Classique',   color:'#4F46E5' },
    { id:'minimal',  label:'Épuré',       color:'#000000' },
    { id:'blue',     label:'Bleu Pro',    color:'#2563eb' },
    { id:'green',    label:'Vert',        color:'#059669' },
    { id:'orange',   label:'Orange',      color:'#f97316' },
    { id:'red',      label:'Rouge',       color:'#dc2626' },
    { id:'navy',     label:'Marine',      color:'#0f172a' },
    { id:'slate',    label:'Ardoise',     color:'#475569' },
    { id:'creative', label:'Créatif',     color:'#9333ea' },
  ];
%>

<!-- ── Actions bar ── -->
<div class="flex flex-wrap items-center gap-3 mb-6" id="actionsBar">
  <a href="<%= invoice.type==='invoice' ? '/dashboard/invoices' : '/dashboard/quotes' %>" class="text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1">
    ← Retour aux <%= invoice.type==='invoice' ? 'factures' : 'devis' %>
  </a>
  <div class="flex-1"></div>

  <!-- Template selector (swatches colorés) -->
  <div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap;">
    <span style="font-size:11px;color:#9ca3af;font-weight:600;margin-right:4px;">Modèle :</span>
    <% templates.forEach(function(t) { %>
    <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/template" style="display:inline;">
      <input type="hidden" name="template" value="<%= t.id %>">
      <button type="submit" title="<%= t.label %>" style="width:28px;height:28px;border-radius:6px;cursor:pointer;border:2px solid <%= tpl===t.id ? t.color : 'transparent' %>;background:<%= t.color %>;box-shadow:<%= tpl===t.id ? '0 0 0 2px white, 0 0 0 4px '+t.color : 'none' %>;transition:all .15s;position:relative;" title="<%= t.label %>"></button>
    </form>
    <% }); %>
  </div>

  <form action="/dashboard/invoices/<%= invoice.id %>/status" method="POST" class="flex items-center gap-2">
    <select name="status" class="px-3 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white">
      <option value="draft" <%= invoice.status==='draft'?'selected':'' %>>Brouillon</option>
      <option value="sent"  <%= invoice.status==='sent' ?'selected':'' %>>Envoyée</option>
      <option value="paid"  <%= invoice.status==='paid' ?'selected':'' %>>Payée</option>
      <option value="cancelled" <%= invoice.status==='cancelled'?'selected':'' %>>Annulée</option>
    </select>
    <button type="submit" class="btn-secondary text-sm font-semibold px-4 py-2 rounded-lg">Mettre à jour</button>
  </form>

  <a href="/dashboard/invoices/<%= invoice.id %>/print" target="_blank" style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#4F46E5,#7C3AED);color:#fff;font-weight:700;font-size:13px;padding:9px 18px;border-radius:10px;text-decoration:none;box-shadow:0 2px 8px rgba(79,70,229,.35);">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    Télécharger PDF
  </a>
  <a href="/dashboard/invoices/<%= invoice.id %>/print" target="_blank" class="btn-secondary text-sm font-semibold px-4 py-2 rounded-lg flex items-center gap-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
    Imprimer
  </a>
</div>

<%
// Helpers partagés
const fmt = n => (n||0).toLocaleString('fr-FR',{minimumFractionDigits:2});
const d   = s => s ? new Date(s).toLocaleDateString('fr-FR') : '';
const statusLabel = s => s==='paid'?'✓ Payée':s==='sent'?'→ Envoyée':s==='cancelled'?'✗ Annulée':'● Brouillon';
const statusStyle = s => s==='paid'?'background:#d1fae5;color:#065f46':s==='sent'?'background:#dbeafe;color:#1e40af':s==='cancelled'?'background:#fee2e2;color:#991b1b':'background:#f3f4f6;color:#374151';
%>

<!-- ══════════════════════════════════════════════════════════
     MODÈLE 1 : CLASSIQUE (violet indigo)
══════════════════════════════════════════════════════════ -->
<% if (tpl==='classic') { %>
<div id="invoiceDoc" style="background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08),0 4px 20px rgba(0,0,0,.08);">
  <div style="background:linear-gradient(135deg,#4F46E5,#7C3AED);padding:32px 40px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <% if(settings&&settings.company_logo){%><div style="display:inline-block;background:rgba(255,255,255,.92);border-radius:8px;padding:5px 10px;margin-bottom:8px;"><img src="<%=settings.company_logo%>" style="max-height:72px;max-width:180px;object-fit:contain;display:block;"/></div><%}%>
        <p style="color:#fff;font-size:20px;font-weight:900;margin:0;"><%=settings&&settings.company_name?settings.company_name:'Mon Entreprise'%></p>
        <% if(settings&&settings.company_address){%><p style="color:rgba(255,255,255,.7);font-size:12px;margin:2px 0 0;"><%=settings.company_address%></p><%}%>
        <% if(settings&&settings.company_city){%><p style="color:rgba(255,255,255,.7);font-size:12px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><%}%>
        <% if(settings&&settings.company_siret){%><p style="color:rgba(255,255,255,.5);font-size:11px;margin:4px 0 0;">SIRET : <%=settings.company_siret%></p><%}%>
      </div>
      <div style="text-align:right;">
        <p style="color:#fff;font-size:36px;font-weight:900;margin:0;letter-spacing:-1px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
        <p style="color:rgba(255,255,255,.8);font-size:16px;font-weight:700;margin:4px 0 0;"><%=invoice.invoice_number%></p>
        <p style="color:rgba(255,255,255,.7);font-size:12px;margin:8px 0 0;">Date : <%=d(invoice.issue_date)%></p>
        <% if(invoice.due_date){%><p style="color:rgba(255,255,255,.7);font-size:12px;margin:2px 0 0;">Échéance : <%=d(invoice.due_date)%></p><%}%>
        <span style="display:inline-block;margin-top:8px;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;background:rgba(255,255,255,.2);color:#fff;"><%=statusLabel(invoice.status)%></span>
      </div>
    </div>
  </div>
  <div style="padding:32px 40px;">
    <% if(invoice.client_name){%>
    <div style="margin-bottom:24px;background:#f8fafc;border-radius:10px;padding:16px 20px;max-width:300px;">
      <p style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.8px;margin:0 0 8px;">Facturé à</p>
      <% if(invoice.client_logo){%><img src="<%=invoice.client_logo%>" style="max-height:40px;max-width:120px;object-fit:contain;margin-bottom:6px;display:block;"/><%}%>
      <p style="font-weight:800;color:#1e293b;margin:0 0 3px;"><%=invoice.client_name%></p>
      <% if(invoice.client_company){%><p style="font-size:13px;color:#374151;margin:0 0 2px;"><%=invoice.client_company%></p><%}%>
      <% if(invoice.client_address){%><p style="font-size:13px;color:#64748b;margin:0 0 2px;"><%=invoice.client_address%></p><%}%>
      <% if(invoice.client_city){%><p style="font-size:13px;color:#64748b;margin:0;"><%=invoice.client_postal||''%> <%=invoice.client_city%></p><%}%>
    </div>
    <%}%>
    <table style="width:100%;border-collapse:collapse;margin-bottom:20px;font-size:13px;">
      <thead><tr style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
        <th style="text-align:left;padding:10px 12px;color:#fff;font-weight:700;font-size:11px;border-radius:8px 0 0 8px;">Description</th>
        <th style="text-align:center;padding:10px;color:#fff;font-weight:700;font-size:11px;">Qté</th>
        <th style="text-align:right;padding:10px;color:#fff;font-weight:700;font-size:11px;">PU HT</th>
        <th style="text-align:center;padding:10px;color:#fff;font-weight:700;font-size:11px;">TVA</th>
        <th style="text-align:right;padding:10px 12px;color:#fff;font-weight:700;font-size:11px;border-radius:0 8px 8px 0;">TTC</th>
      </tr></thead>
      <tbody>
        <% if(invoice.items&&invoice.items.length>0){invoice.items.forEach((item,i)=>{%>
        <tr style="background:<%=i%2===0?'#fff':'#f8faff'%>;border-bottom:1px solid #e0e7ff;">
          <td style="padding:10px 12px;color:#374151;"><%=item.description%></td>
          <td style="padding:10px;color:#64748b;text-align:center;"><%=item.quantity%></td>
          <td style="padding:10px;color:#64748b;text-align:right;"><%=fmt(item.unit_price)%> €</td>
          <td style="padding:10px;color:#64748b;text-align:center;"><%=item.tva_rate%>%</td>
          <td style="padding:10px 12px;font-weight:700;color:#4F46E5;text-align:right;"><%=fmt(item.total)%> €</td>
        </tr>
        <%});}%>
      </tbody>
    </table>
    <div style="display:flex;justify-content:flex-end;margin-bottom:20px;"><div style="width:240px;">
      <div style="display:flex;justify-content:space-between;padding:6px 0;color:#64748b;font-size:13px;border-bottom:1px solid #e0e7ff;"><span>Total HT</span><span><%=fmt(invoice.subtotal)%> €</span></div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;color:#64748b;font-size:13px;border-bottom:1px solid #e0e7ff;"><span>TVA</span><span><%=fmt(invoice.tva_amount)%> €</span></div>
      <div style="display:flex;justify-content:space-between;padding:12px 14px;background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:10px;margin-top:8px;"><span style="color:#fff;font-weight:800;font-size:14px;">Total TTC</span><span style="color:#fff;font-weight:900;font-size:16px;"><%=fmt(invoice.total)%> €</span></div>
    </div></div>
    <% if(invoice.notes||invoice.payment_terms||(settings&&settings.bank_iban)){%>
    <div style="border-top:1px solid #e0e7ff;padding-top:16px;font-size:12px;color:#64748b;display:flex;justify-content:space-between;gap:20px;">
      <div><% if(invoice.payment_terms){%><p style="margin:0 0 2px;"><strong>Conditions :</strong> <%=invoice.payment_terms%></p><%}%><% if(invoice.notes){%><p style="margin:0;"><%=invoice.notes%></p><%}%></div>
      <% if(settings&&settings.bank_iban){%><div style="text-align:right;"><% if(settings.bank_name){%><p style="margin:0 0 2px;font-weight:600;"><%=settings.bank_name%></p><%}%><p style="margin:0 0 2px;font-family:monospace;"><%=settings.bank_iban%></p><% if(settings.bank_bic){%><p style="margin:0;font-family:monospace;">BIC : <%=settings.bank_bic%></p><%}%></div><%}%>
    </div>
    <%}%>
    <% if(settings&&settings.company_siret){%><p style="margin-top:12px;font-size:10px;color:#94a3b8;">SIRET : <%=settings.company_siret%><% if(settings.company_tva){%> — N° TVA : <%=settings.company_tva%><%}%></p><%}%>
  </div>
</div>
<% } %>

<!-- ══════════════════════════════════════════════════════════
     MODÈLE 2 : MODERNE (sidebar sombre)
══════════════════════════════════════════════════════════ -->
<% if (tpl==='modern') { %>
<div id="invoiceDoc" style="background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08),0 4px 20px rgba(0,0,0,.08);display:flex;min-height:700px;">
  <div style="width:210px;background:#1e293b;flex-shrink:0;padding:32px 22px;display:flex;flex-direction:column;gap:22px;">
    <div>
      <% if(settings&&settings.company_logo){%><div style="display:inline-block;background:rgba(255,255,255,.92);border-radius:8px;padding:5px 10px;margin-bottom:8px;"><img src="<%=settings.company_logo%>" style="max-height:64px;max-width:150px;object-fit:contain;display:block;"/></div><%}%>
      <p style="color:#fff;font-weight:900;font-size:14px;margin:0;"><%=settings&&settings.company_name?settings.company_name:'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){%><p style="color:#94a3b8;font-size:11px;margin:2px 0 0;"><%=settings.company_address%></p><%}%>
      <% if(settings&&settings.company_city){%><p style="color:#94a3b8;font-size:11px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><%}%>
    </div>
    <div style="border-top:1px solid #334155;padding-top:18px;">
      <p style="color:#64748b;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin:0 0 6px;">Contact</p>
      <% if(settings&&settings.company_phone){%><p style="color:#94a3b8;font-size:11px;margin:0 0 3px;">📞 <%=settings.company_phone%></p><%}%>
      <% if(settings&&settings.company_email){%><p style="color:#94a3b8;font-size:11px;margin:0;">✉ <%=settings.company_email%></p><%}%>
      <% if(settings&&settings.company_siret){%><p style="color:#64748b;font-size:10px;margin:6px 0 0;">SIRET : <%=settings.company_siret%></p><%}%>
    </div>
    <% if(invoice.client_name){%>
    <div style="border-top:1px solid #334155;padding-top:18px;">
      <p style="color:#64748b;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin:0 0 6px;">Client</p>
      <p style="color:#e2e8f0;font-weight:700;font-size:12px;margin:0 0 3px;"><%=invoice.client_name%></p>
      <% if(invoice.client_company){%><p style="color:#94a3b8;font-size:11px;margin:0 0 2px;"><%=invoice.client_company%></p><%}%>
      <% if(invoice.client_address){%><p style="color:#94a3b8;font-size:11px;margin:0 0 2px;"><%=invoice.client_address%></p><%}%>
      <% if(invoice.client_city){%><p style="color:#94a3b8;font-size:11px;margin:0;"><%=invoice.client_postal||''%> <%=invoice.client_city%></p><%}%>
    </div>
    <%}%>
    <% if(settings&&settings.bank_iban){%>
    <div style="border-top:1px solid #334155;padding-top:18px;margin-top:auto;">
      <p style="color:#64748b;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin:0 0 6px;">Banque</p>
      <% if(settings.bank_name){%><p style="color:#94a3b8;font-size:11px;margin:0 0 2px;"><%=settings.bank_name%></p><%}%>
      <p style="color:#94a3b8;font-size:10px;font-family:monospace;margin:0 0 2px;word-break:break-all;"><%=settings.bank_iban%></p>
      <% if(settings.bank_bic){%><p style="color:#64748b;font-size:10px;font-family:monospace;margin:0;">BIC : <%=settings.bank_bic%></p><%}%>
    </div>
    <%}%>
  </div>
  <div style="flex:1;padding:32px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;">
      <div>
        <p style="font-size:30px;font-weight:900;color:#1e293b;margin:0;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
        <p style="font-size:16px;font-weight:700;color:#64748b;margin:3px 0 0;"><%=invoice.invoice_number%></p>
      </div>
      <div style="text-align:right;">
        <div style="background:#f1f5f9;border-radius:10px;padding:12px 16px;">
          <p style="margin:0 0 3px;color:#64748b;font-size:11px;">Date : <strong style="color:#1e293b;"><%=d(invoice.issue_date)%></strong></p>
          <% if(invoice.due_date){%><p style="margin:0;color:#64748b;font-size:11px;">Échéance : <strong style="color:#1e293b;"><%=d(invoice.due_date)%></strong></p><%}%>
        </div>
        <span style="display:inline-block;margin-top:8px;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;<%=statusStyle(invoice.status)%>"><%=statusLabel(invoice.status)%></span>
      </div>
    </div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:13px;">
      <thead><tr style="border-bottom:2px solid #1e293b;">
        <th style="text-align:left;padding:8px 10px;color:#1e293b;font-weight:800;font-size:11px;text-transform:uppercase;letter-spacing:.5px;">Description</th>
        <th style="text-align:center;padding:8px 10px;color:#1e293b;font-weight:800;font-size:11px;text-transform:uppercase;">Qté</th>
        <th style="text-align:right;padding:8px 10px;color:#1e293b;font-weight:800;font-size:11px;text-transform:uppercase;">PU HT</th>
        <th style="text-align:center;padding:8px 10px;color:#1e293b;font-weight:800;font-size:11px;text-transform:uppercase;">TVA</th>
        <th style="text-align:right;padding:8px 10px;color:#1e293b;font-weight:800;font-size:11px;text-transform:uppercase;">TTC</th>
      </tr></thead>
      <tbody>
        <% if(invoice.items&&invoice.items.length>0){invoice.items.forEach((item,idx)=>{%>
        <tr style="background:<%=idx%2===0?'#fff':'#f8fafc'%>;">
          <td style="padding:10px;color:#374151;"><%=item.description%></td>
          <td style="padding:10px;color:#64748b;text-align:center;"><%=item.quantity%></td>
          <td style="padding:10px;color:#64748b;text-align:right;"><%=fmt(item.unit_price)%> €</td>
          <td style="padding:10px;color:#64748b;text-align:center;"><%=item.tva_rate%>%</td>
          <td style="padding:10px;font-weight:700;color:#1e293b;text-align:right;"><%=fmt(item.total)%> €</td>
        </tr>
        <%});}%>
      </tbody>
    </table>
    <div style="display:flex;justify-content:flex-end;margin:16px 0;"><div style="width:240px;">
      <div style="display:flex;justify-content:space-between;padding:5px 0;color:#64748b;font-size:13px;border-bottom:1px solid #f1f5f9;"><span>Total HT</span><span><%=fmt(invoice.subtotal)%> €</span></div>
      <div style="display:flex;justify-content:space-between;padding:5px 0;color:#64748b;font-size:13px;border-bottom:1px solid #f1f5f9;"><span>TVA</span><span><%=fmt(invoice.tva_amount)%> €</span></div>
      <div style="display:flex;justify-content:space-between;padding:10px 12px;background:#1e293b;border-radius:8px;margin-top:8px;"><span style="color:#fff;font-weight:800;font-size:14px;">Total TTC</span><span style="color:#fff;font-weight:900;font-size:16px;"><%=fmt(invoice.total)%> €</span></div>
    </div></div>
    <% if(invoice.notes||invoice.payment_terms){%><div style="border-top:1px solid #f1f5f9;padding-top:14px;font-size:12px;color:#6b7280;">
      <% if(invoice.payment_terms){%><p style="margin:0 0 3px;"><strong style="color:#374151;">Conditions :</strong> <%=invoice.payment_terms%></p><%}%>
      <% if(invoice.notes){%><p style="margin:0;"><%=invoice.notes%></p><%}%>
    </div><%}%>
  </div>
</div>
<% } %>

<!-- ══════════════════════════════════════════════════════════
     MODÈLE 3 : ÉPURÉ (noir & blanc)
══════════════════════════════════════════════════════════ -->
<% if (tpl==='minimal') { %>
<div id="invoiceDoc" style="background:#fff;border-radius:16px;padding:52px;box-shadow:0 1px 3px rgba(0,0,0,.08),0 4px 20px rgba(0,0,0,.08);">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;padding-bottom:20px;border-bottom:2px solid #000;">
    <div>
      <% if(settings&&settings.company_logo){%><img src="<%=settings.company_logo%>" style="max-height:80px;max-width:200px;object-fit:contain;margin-bottom:8px;display:block;"/><%}%>
      <p style="font-size:20px;font-weight:900;color:#000;margin:0;"><%=settings&&settings.company_name?settings.company_name:'Mon Entreprise'%></p>
      <% if(settings&&settings.company_address){%><p style="color:#6b7280;font-size:12px;margin:2px 0 0;"><%=settings.company_address%></p><%}%>
      <% if(settings&&settings.company_city){%><p style="color:#6b7280;font-size:12px;margin:0;"><%=settings.company_postal||''%> <%=settings.company_city%></p><%}%>
      <% if(settings&&settings.company_siret){%><p style="color:#9ca3af;font-size:11px;margin:4px 0 0;">SIRET <%=settings.company_siret%></p><%}%>
    </div>
    <div style="text-align:right;">
      <p style="font-size:12px;font-weight:700;color:#9ca3af;letter-spacing:2px;text-transform:uppercase;margin:0 0 4px;"><%=invoice.type==='invoice'?'FACTURE':'DEVIS'%></p>
      <p style="font-size:26px;font-weight:900;color:#000;margin:0 0 10px;"><%=invoice.invoice_number%></p>
      <p style="font-size:12px;color:#6b7280;margin:0 0 2px;">Émis le <%=d(invoice.issue_date)%></p>
      <% if(invoice.due_date){%><p style="font-size:12px;color:#6b7280;margin:0;">Échéance <%=d(invoice.due_date)%></p><%}%>
    </div>
  </div>
  <% if(invoice.client_name){%>
  <div style="margin-bottom:36px;">
    <p style="font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:1.5px;margin:0 0 8px;">Destinataire</p>
    <p style="font-size:15px;font-weight:700;color:#000;margin:0 0 4px;"><%=invoice.client_name%></p>
    <% if(invoice.client_company){%><p style="font-size:13px;color:#6b7280;margin:0 0 2px;"><%=invoice.client_company%></p><%}%>
    <% if(invoice.client_address){%><p style="font-size:13px;color:#6b7280;margin:0 0 2px;"><%=invoice.client_address%></p><%}%>
