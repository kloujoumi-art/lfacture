<% if (clients && clients.length > 0) { %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Client</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Email</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Téléphone</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Ville</th>
          <th class="text-right px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% clients.forEach(client => { %>
        <tr class="table-row">
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background:linear-gradient(135deg,#4F46E5,#7C3AED)">
                <%= client.name.charAt(0).toUpperCase() %>
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm"><%= client.name %></p>
                <% if (client.company) { %><p class="text-xs text-gray-400"><%= client.company %></p><% } %>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 hidden md:table-cell">
            <span class="text-sm text-gray-600"><%= client.email || '—' %></span>
          </td>
          <td class="px-6 py-4 hidden lg:table-cell">
            <span class="text-sm text-gray-600"><%= client.phone || '—' %></span>
          </td>
          <td class="px-6 py-4 hidden lg:table-cell">
            <span class="text-sm text-gray-600"><%= client.city || '—' %></span>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <a href="/dashboard/invoices/create?type=invoice&client_id=<%= client.id %>" class="text-xs text-primary-600 font-medium hover:underline">+ Facture</a>
              <a href="/dashboard/clients/<%= client.id %>/edit" class="text-xs text-gray-500 font-medium hover:text-gray-700">Modifier</a>
              <form action="/dashboard/clients/<%= client.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer ce client ?')">
                <button type="submit" class="text-xs text-red-400 font-medium hover:text-red-600">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } else { %>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm py-20 text-center">
  <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
  </div>
  <p class="text-gray-500 font-medium mb-2">Aucun client enregistré</p>
  <p class="text-sm text-gray-400 mb-6">Commencez par ajouter vos clients</p>
  <a href="/dashboard/clients/create" class="btn-primary text-white font-semibold px-6 py-2.5 rounded-lg text-sm inline-block">+ Ajouter un client</a>
</div>
<% } %>
<style>.btn-primary{background:linear-gradient(135deg,#4F46E5,#7C3AED);transition:all .2s;box-shadow:0 4px 12px rgba(79,70,229,.25)}.btn-primary:hover{transform:translateY(-1px)}</style>
