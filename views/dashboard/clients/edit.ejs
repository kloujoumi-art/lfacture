<% if (errors && errors.length > 0) { %>
<div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
  <% errors.forEach(err => { %><p class="text-red-700 text-sm">• <%= err %></p><% }); %>
</div>
<% } %>

<div class="max-w-2xl">
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
    <form action="/dashboard/clients/<%= client.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nom complet <span class="text-red-500">*</span></label>
          <input type="text" name="name" value="<%= client.name %>" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Entreprise</label>
          <input type="text" name="company" value="<%= client.company || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
          <input type="email" name="email" value="<%= client.email || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Téléphone</label>
          <input type="tel" name="phone" value="<%= client.phone || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Adresse</label>
          <input type="text" name="address" value="<%= client.address || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Code postal</label>
          <input type="text" name="postal_code" value="<%= client.postal_code || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Ville</label>
          <input type="text" name="city" value="<%= client.city || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">SIRET</label>
          <input type="text" name="siret" value="<%= client.siret || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Numéro de TVA</label>
          <input type="text" name="tva" value="<%= client.tva || '' %>" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Logo du client</label>
          <div style="border:2px dashed #e2e8f0;border-radius:12px;padding:16px;background:#f8fafc;">
            <input type="file" name="client_logo_file" accept="image/*" id="clientLogoInput"
              style="display:none;" onchange="previewClientLogo(this)">
            <input type="hidden" name="remove_logo" id="removeLogoInput" value="0">
            <div style="display:flex;align-items:center;gap:14px;">
              <div id="clientLogoPreview" style="width:72px;height:72px;border-radius:8px;background:#e2e8f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;">
                <% if(client.logo){ %>
                  <img src="<%=client.logo%>" style="width:100%;height:100%;object-fit:contain;border-radius:6px;"/>
                <% } else { %>
                  <svg width="28" height="28" fill="none" stroke="#94a3b8" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <% } %>
              </div>
              <div>
                <button type="button" onclick="document.getElementById('clientLogoInput').click()" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);color:#fff;border:none;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;">
                  <%= client.logo ? 'Changer le logo' : '+ Ajouter le logo' %>
                </button>
                <% if(client.logo){ %>
                <button type="button" onclick="removeLogo()" style="background:#fee2e2;color:#dc2626;border:none;padding:8px 14px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;margin-left:8px;">Supprimer</button>
                <% } %>
                <p style="font-size:11px;color:#94a3b8;margin:5px 0 0;">PNG, JPG, SVG — max 2 Mo</p>
              </div>
            </div>
          </div>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Notes</label>
          <textarea name="notes" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm resize-none"><%= client.notes || '' %></textarea>
        </div>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary text-white font-bold px-6 py-3 rounded-xl">Enregistrer</button>
        <a href="/dashboard/clients" class="btn-secondary font-semibold px-6 py-3 rounded-xl">Annuler</a>
      </div>
    </form>
  </div>
</div>
<style>.btn-primary{background:linear-gradient(135deg,#4F46E5,#7C3AED);transition:all .2s;box-shadow:0 4px 12px rgba(79,70,229,.25)}.btn-primary:hover{transform:translateY(-1px)}.btn-secondary{background:#f1f5f9;color:#374151;border:1px solid #e2e8f0;cursor:pointer;transition:all .15s}.btn-secondary:hover{background:#e2e8f0}</style>
<script>
function previewClientLogo(input) {
  if (!input.files[0]) return;
  document.getElementById('removeLogoInput').value = '0';
  const reader = new FileReader();
  reader.onload = function(e) {
    const prev = document.getElementById('clientLogoPreview');
    prev.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:contain;border-radius:6px;">';
  };
  reader.readAsDataURL(input.files[0]);
}
function removeLogo() {
  document.getElementById('removeLogoInput').value = '1';
  document.getElementById('clientLogoInput').value = '';
  const prev = document.getElementById('clientLogoPreview');
  prev.innerHTML = '<svg width="28" height="28" fill="none" stroke="#94a3b8" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>';
}
</script>
